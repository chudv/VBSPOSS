<script>
    var userPermission = @Html.Raw(Json.Serialize(userPermission ?? new RolePermissionModel()));
    // Khởi tạo Kendo Notification
    var notification = $("#notification").kendoNotification({
        position: {
            top: 20,
            right: 20
        },
        autoHideAfter: 5000
    }).data("kendoNotification");
    var mainWindow = $("#myPopup");
    function paramLoadListBranchFind() {
         return {
             pFlagCondi: "5",
             pStatus: "O",
             pShortName: "1",
             pTitleChoice: "",
             pFlagTextShow: "1",
             pUserPosCode: "",
             pUserName: "",
             pFlagWholeBank: 1
         };
    }

    function paramLoadGridData() {
        return {
            pPosCodeFind: $("#PosCode_Find").val(),
      
            pTranspointCode: $("#TXNCode_Find").data("kendoComboBox").value(),
            pTranspointName: $("#TXNName_Find").val(),
            pBeginDateFind: $("#CircularDateBegin_Find").val(),
            pEndDateFind: $("#CircularDateEnd_Find").val()
        };
    }

    
        
    function refreshGridCasaRateConfigure() {
        var grid = $("#gridMainTranspoint").data("kendoGrid");
        if (grid != null) {
            grid.dataSource.read();
        }
    }
    function onSearch(e) {
            var posCode = $("#PosCode_Find").data("kendoComboBox").value();

        if (posCode === "000100" || posCode === "") {
            alert("Vui lòng chọn đơn vị cấp nhỏ hơn");
            return; 
        }
        refreshGridCasaRateConfigure();
    }
    function onRowBoundTranspoint(e) {
        var rows = e.sender.tbody.children();
        var isRed = true;

        // for (var j = 0; j < rows.length; j++) {
        //     var row = $(rows[j]);
        //     var dataItem = e.sender.dataItem(row);
        //     var trangthaiRow = dataItem.get("Status");
        //     if (trangthaiRow == "C" || trangthaiRow == null || trangthaiRow == 0 || trangthaiRow == 4)
        //         row.css({ "background-color": "#f8f9fa", "color": "#6c757d" });
        //     if (trangthaiRow != null && trangthaiRow == 4)
        //         row.css({ "background-color": "#fff5f5", "color": "#dc3545" });
        //     if (trangthaiRow != null && trangthaiRow == 3) // Đã duyệt
        //         row.css({ "background-color": "#e8f5e9", "color": "#2e7d32" });

        // }
       
  
        var grid = this;
        grid.tbody.find("tr").each(function () {
            var dataItem = grid.dataItem(this);
            if (userPermission.EditPermissionFlag == 0) {
                $(this).find(".k-grid-ViewEdit").hide();
            }
            if (userPermission.DeletePermissionFlag == 0) {
                $(this).find(".k-grid-Delete").hide();
            }
            if (userPermission.AuthorizePermissionFlag == 0) {
                $(this).find(".k-grid-Authorize").hide();
            }
            if (userPermission.ReportPermissionFlag == 0) {
                $(this).find(".k-grid-Approval").hide();
            }
        });


        // Checkbox logic
        $("#gridMainTranspoint").on("click", ".chkbx", function () {
            var grid = $("#gridMainTranspoint").data("kendoGrid");
            var dataItem = grid.dataItem($(this).closest("tr"));
            var checked = $(this).is(":checked");
            if (checked) {
                var dataItems = grid.dataSource.view();
                for (var i = 0; i < dataItems.length; i++) {
                    if (dataItems[i] && dataItems[i].Id && dataItems[i].Id !== dataItem.Id) {
                        dataItems[i].set("IsSelected", false);
                    }
                }
                dataItem.set("IsSelected", true);
            } else {
                dataItem.set("IsSelected", false);
            }
            $("#gridMainTranspoint .chkbx").each(function () {
                var rowDataItem = grid.dataItem($(this).closest("tr"));
                $(this).prop("checked", rowDataItem.IsSelected);
            });
        });
    }
    var dataChangeCasaRateConfigure = false;
    function onCloseCasaRateConfigure() {
        if (dataChangeCasaRateConfigure == true) {
            refreshGridCasaRateConfigure();
            dataChangeCasaRateConfigure = false;
        }
    }
    function doCompleteWindow() {
        mainWindow.data("kendoWindow").close();
    }
   
   






    function showTransDetail(pNotiType, pPosCode, pTransPoint, pTransDate, pTxnPointName) {
        var pNotiType = pNotiType;
        var pPosCode = pPosCode;
        var pTransPoint = pTransPoint;
        var pTransDate = pTransDate;
        if (pNotiType && pNotiType !== "null") {
            // var myWidth = screenUtil.getWidth() - 80;
            //var myHeight = screenUtil.getHeight() - 30;
            var myWidth = 1200;
            var myHeight = 400;
            mainWindow.kendoWindow({
                width: myWidth, //"1100px",
                height: myHeight,
                title: "Yêu cầu gửi lại thông báo",
                content: { url: "../Noti/ResendNotiInfo", data: { pNotiType: pNotiType, pPosCode: pPosCode, pTransPoint: pTransPoint, pTransDate: pTransDate, pTxnPointName: pTxnPointName } },
                resizable: true,
                visible: false,
                modal: true,
                actions: ["Refresh", "Close"]
            });
            mainWindow.data("kendoWindow").wrapper.css({ height: myHeight, width: myWidth });
            mainWindow.data("kendoWindow").center().open().title("Thông tin người dùng đi giao dịch xã");
        }
        else alert(" Vui lòng kiểm tra lại!");
    }

</script>
