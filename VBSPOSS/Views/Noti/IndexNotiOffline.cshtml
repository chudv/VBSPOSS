<script>


     function onSaveGridCompleted(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {
                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }
    function error_handler(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
            console.error("Kendo Grid Error:", e.errors); //
        }
    }
    $(document).ready(function () {
        // $(".k-grid-excel").after("<label id='lbl_space' style='padding-top:5px;padding-left: 10px;width:70%; font-size: 11px; font-weight: bold; color: blue;text-align:center;line-height: 25px;'>DANH SÁCH QUYẾT ĐỊNH CẤU HÌNH LÃI SUẤT CASA</label>");
    });


    function onChangePosCode() {
        var posCode = $("#PosCode_Find").data("kendoComboBox").value();
        
        $.ajax({
            url: '/Noti/GetTXNPointChange',
            type: 'GET',
            data: { posCode: posCode },   // 👈 truyền posCode lên controller
            success: function (data) {

                var combo = $("#TXNCode_Find").data("kendoComboBox");
                console.log(combo);
                // clear dữ liệu cũ
                combo.dataSource.data([]);

                // set datasource mới
                combo.setDataSource(new kendo.data.DataSource({
                    data: data
                }));

                // chọn item đầu tiên
                combo.select(0);
            },
            error: function () {
                alert("Lỗi load TXNCode");
            }
        });
    }
</script>