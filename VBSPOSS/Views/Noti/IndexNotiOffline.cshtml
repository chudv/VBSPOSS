        console.log("Document with filter:", currentFilter);  // Debug
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        mainWindow.kendoWindow({
            width: "1200px",
            height: "750px",
            title: "Tờ trình cấu hình lãi suất CASA",
            content: {
                url: '@Url.Action("ShowDocumentConfig", "Noti")',
                data: {
                    filter: JSON.stringify(currentFilter),  // Pass filter để load multiple
                    pFlagCall: "1"
                }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseCasaRateConfigure,
            actions: ["Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    });



