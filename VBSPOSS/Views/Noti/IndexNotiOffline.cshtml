    // FIX: showEdit - fallback Id/IdList
    function showEdit(e) {
        e.preventDefault();
        var grid = $("#gridMainTranspoint").data("kendoGrid");
        var tr = $(e.currentTarget).closest("tr");
        var dataItem = grid.dataItem(tr);
        var useId = dataItem.Id > 0 ? dataItem.Id : (dataItem.IdList > 0 ? dataItem.IdList : 0);
        console.log("UseId for Edit:", useId); // Debug
        if (useId > 0) {
            if (mainWindow.data("kendoWindow")) {
                mainWindow.data("kendoWindow").destroy();
            }
            mainWindow.kendoWindow({
                width: "1200px",
                height: "650px",
                title: "Sửa cấu hình lãi suất",
                content: {
                    url: '@Url.Action("ShowUpdateCasaConfig", "Noti")',
                    data: { pId: useId, pFlagCall: "2" }
                },
                resizable: false,
                visible: false,
                modal: true,
                close: onCloseCasaRateConfigure,
                actions: ["Refresh", "Close"],
                error: function (e) {
                    notification.show({
                        message: "Có lỗi xảy ra: " + e.xhr.statusText,
                        type: "error"
                    }, "error");
                    mainWindow.data("kendoWindow").close();
                }
            });
            mainWindow.data("kendoWindow").center().open();
        } else {
            alert("Vui lòng chọn một dòng dữ liệu hợp lệ để chỉnh sửa!");
        }
    }
    // FIX: deleteItem - fallback Id/IdList
    function deleteItem(e) {
        e.preventDefault();
        var grid = $("#gridMainTranspoint").data("kendoGrid");
        var row = $(e.currentTarget).closest("tr");
        var dataItem = grid.dataItem(row);
        var useId = dataItem.Id > 0 ? dataItem.Id : (dataItem.IdList > 0 ? dataItem.IdList : 0);
        console.log("UseId for Delete:", useId); // Debug
        if (useId <= 0) {
            alert("Vui lòng chọn một dòng dữ liệu hợp lệ để xóa!");
            return;
        }
        var sMessInfor = "[" + (dataItem.ProductCode || "") + " - " + (dataItem.ProductName || "") + "]";
        var deletedStatuses = [0, 3, 4];
        if (deletedStatuses.includes(dataItem.Status)) {
            alert("Cấu hình lãi suất " + sMessInfor + " đã được đánh dấu xóa rồi hoặc đã được phê duyệt. Không thực hiện đánh dấu xóa!");
            return;
        }
        var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa cấu hình lãi suất " + sMessInfor + " không?");
        if (isConfirm) {
            kendo.ui.progress(grid.element, true);
            $.ajax({
                url: '@Url.Action("CloseCasa", "Noti")',
                type: "POST",
                data: JSON.stringify({
                    id: useId,
                    documentId: dataItem.DocumentId || null
                }),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (result) {
                    kendo.ui.progress(grid.element, false);
                    console.log("Delete success result:", result);
                    if (result.success) {
                        alert("Xóa cấu hình lãi suất " + sMessInfor + " thành công!");
                        refreshGridCasaRateConfigure();
                    } else {
                        alert("Xóa cấu hình lãi suất " + sMessInfor + " thất bại! Lỗi: " + (result.message || "Không xác định"));
                    }
                },
                error: function (xhr, status, error) {
                    kendo.ui.progress(grid.element, false);
                    console.error("Delete error:", xhr, status, error);
                    alert("Xóa cấu hình lãi suất " + sMessInfor + " có lỗi! Chi tiết: " + (xhr.responseText || error));
                }
            });
        } else {
            alert("Thao tác bị hủy bỏ!");
        }
    }
