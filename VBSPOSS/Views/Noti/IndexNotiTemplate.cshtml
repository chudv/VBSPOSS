@{
    ViewBag.Title = "MẪU THÔNG BÁO MOBILE BANKING ONLINE";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="myNoti"></div>

<script>
    var mainWindow = $("#myNoti");
</script>

