<script>
    function clearControls() {
        var id = $("#Id").val();
        if (id != 0 || id != null) {
        }
        else {
            $("#Id").val(0);
            $("#Slug").val("");
            $("#ChoiseImage").val(0);
            $("#DeleteImage").val(0);
            $("#Images").val("");
            $("#Title").val("");
            $("#Detail").val("");
            $("#CateId").data('kendoComboBox').select(0);
            $("#PostType").data('kendoComboBox').select(0);
            $("#Promoted").data('kendoDropDownList').select(0);

            $("#LevelCode").val("");
            $("#Description").val("");
            $("#DetailHTML").val("");
            $("#Status").data('kendoDropDownList').select(0);

            var iconPath = $("#icon_path").val();
            iconPath = "";
            $("#icon_path").val("");
            if (iconPath === null || iconPath === '') {
                document.getElementById('stuImage').src = "../upload/FILE_NO_FOUND.jpg";
            }
            else {
                document.getElementById('stuImage').src = "../" + iconPath;
            }
            $('input[type=file]').val(null);

            $("#Title").focus();
        }
    }

    $(function () {
        $("#form0").submit(function (event) {
            event.preventDefault();
            for (var instanceName in CKEDITOR.instances) {
                CKEDITOR.instances[instanceName].updateElement();
            }
            var dataString;
            var action = this.action;
            var contentType;
            var processData;
            if (this.enctype == "multipart/form-data") {
                dataString = new FormData($(this).get(0));
                contentType = false;
                processData = false;
            } else {
                //
            }

            $.ajax({
                url: this.action,
                type: this.method,
                dataType: "json", //change to your own, else read my note above on enabling the JsonValueProviderFactory in MVC
                contentType: contentType,
                processData: processData,
                data: dataString,
                success: function (result) {

                    var arrResult = result.split("#");
                    var sResult = "";
                    var iRecordId = 0;
                    var lcImagesHistory = "";
                    if (arrResult.length != 0) {
                        sResult = arrResult[0];
                        iRecordId = parseInt(arrResult[1]);
                        lcImagesHistory = arrResult[2];
                        if (sResult == "0") {
                            var titleUpdate = $("#Title").val();
                            alert("Bạn đã cập nhật thành công Bài học [" + titleUpdate + "]!");
                            dataChange = true;
                            $("#ImagesHistory").val(lcImagesHistory);
                            //Nếu dóng chuyển ra form ngoài (với nút lệnh là btnSave01)
                            if (eventFlag.trim() === "btnSave01") {
                                clearControls();
                                $('#href2')[0].click();
                            }
                            else if (eventFlag.trim() === "btnSave02") {
                                $("#Id").val(iRecordId);
                            }
                        }
                        else {
                            dataChange = false;
                            if (sResult == "1")
                                alert("Tiêu đề của bài học không được để trống!");
                            else if (sResult == "2")
                                alert("Đề mục cho bài học không được để trống!");
                            else if (sResult == "3")
                                alert("Tiêu đề chi tiết của bài học không được để trống!");
                            else if (sResult == "4")
                                alert("Phân loại bài viết/bài học/bài báo... không được để trống!");
                            else if (sResult == "5")
                                alert("Bài học [" + $("#Title").val() + "] này đã tồn tại. Vui lòng kiểm tra lại!");
                        }
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    alert("Lỗi khi cập nhật dữ liệu. Vui lòng liên hệ quản trị hệ thống!");
                }
            });
            return false;
        });
    });

