<style>
    .cssMain {
        display: inline-flex;
        width: 100%;
        justify-content: space-between;
        align-items: center;
        margin-top: 5px;
        font-family: Tahoma;
    }

    .lgContent {
        font-size: 22px;
        font-weight: bold;
        font-family: Tahoma;
    }

    .smContent {
        font-size: 13px;
        font-weight: normal;
        font-family: Tahoma;
    }

    .smContent-color {
        color: gray;
    }

    .dropbtn {
        background-color: #00a561;
        color: white;
        padding: 7px;
        font-size: 12px;
        border: none;
        cursor: pointer;
        border-radius: 3px;
        border: 1px solid #bbb;
        font-family: Tahoma;
    }

    .ck.ck-editor {
        width: 100%;
    }

    .ck-editor__editable_inline {
        height: 50vh;
    }

    /* Gắn vào div cha */
    .my-white-combobox .k-dropdown-wrap {
        background-color: #fff !important;
        border: 1px solid #ccc !important;
        border-radius: 6px !important;
    }
    
    /* Ô input bên trong */
    .my-white-combobox .k-input-inner {
        background-color: #fff !important;
        color: blue !important;
        font-weight: bold !important;
    }

    /* Áp dụng cho placeholder */
    .k-combobox .k-input-inner::placeholder {
        color: blue !important;
        font-weight: bold !important;
    }

    .my-white-combobox.k-input-inner {
        background: url('/images/group_green_add.png') no-repeat left center;
        background-size: 16px 16px;
        padding-left: 22px; /* chừa chỗ cho icon */
        align-items: center;
    }

    /* Chỉ ẩn icon mũi tên, vẫn giữ button để mở dropdown */
    .my-white-combobox .k-input-button .k-svg-icon {
        display: none !important;
    }

    /* Làm combobox giống textbox */
    .my-white-combobox .k-combobox,
    .my-white-combobox .k-dropdown-wrap {
        border: 1px solid #ccc !important; /* viền giống textbox */
        border-radius: 4px !important; /* bo góc */
        box-shadow: none !important; /* bỏ shadow */
        background: #fff !important; /* nền trắng */
    }

    /* Căn giữa text */
    .my-white-combobox .k-input-inner {
        text-align: center !important;
    }
</style>

