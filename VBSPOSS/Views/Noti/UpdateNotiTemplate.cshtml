        function loadImage() {
            $("#imageFile").click();
        }

        function onChoiceImage(e) {
            loadImage();
            $("#ChoiseImage").val(1);
            $("#DeleteImage").val(0);
        }

        function onDeleteImage(e) {
            var iconPath = $("#icon_path").val();
            //$("#Icon").val("");
            iconPath = "";
            $("#icon_path").val("");
            if (iconPath === null || iconPath === '') {
                document.getElementById('stuImage').src = "../upload/FILE_NO_FOUND.jpg";
            }
            else {
                document.getElementById('stuImage').src = "../" + iconPath;
            }
            $('input[type=file]').val(null);
            $("#DeleteImage").val(1);
            $("#ChoiseImage").val(0);
        }

        //Khai báo tên tránh bị trùng nếu không sẽ gây lỗi
        var eventFlag = "";

        function onClick(e) {
        // Kiểm tra CKEditor instance có tồn tại không
            if (CKEDITOR.instances["editor1"]) {
                var editorData = CKEDITOR.instances["editor1"].getData();
                var plainText = $(editorData).text();
                // Làm sạch text
                plainText = plainText.replace(/\r?\n|\r/gm, " "); // bỏ xuống dòng
                plainText = plainText.replace(/\s\s+/g, " ").trim(); // bỏ space thừa
                // Gán vào hidden field
                $("#Description").val(plainText);
            }
            // Lấy ID button từ Kendo event
            var eventFlag = e.sender.element.attr("id");
            console.log("Button clicked:", eventFlag);

            // Cho phép submit form sau khi gán dữ liệu
            return true;
        }

        function onClickText(e) {
            // Lấy nội dung từ CKEditor
            var content = CKEDITOR.instances["editor1"].getData();

            // Nếu muốn loại bỏ thẻ HTML, chỉ lấy text thuần:
            // var content = CKEDITOR.instances["editor1"].document.getBody().getText();

            // Tạo file txt
            var blob = new Blob([content], { type: "text/plain;charset=utf-8" });

            // Tạo link download ẩn
            var link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = "output.txt";
            link.click();

            // Giải phóng bộ nhớ
            URL.revokeObjectURL(link.href);
        }

        function onFormBegin() {
            for (var instanceName in CKEDITOR.instances) {
                CKEDITOR.instances[instanceName].updateElement();
            }
        }

        function onNotiTypeChange(e) {
            var combo = e.sender;
            var notiType = combo.value();
            var notiSend = $("#NotiSend").val();

            if (!notiType) return;

            $.ajax({
                url: '/Noti/GetNotiTemplateDetail',
                type: 'GET',
                data: { pNotiType: notiType, pNotiSend: notiSend },
                success: function (res) {
                    if (res && res.length > 0) {
                        var item = res[0];
                        // Gán dữ liệu vào các control
                        $("#NotiType").val(item.notiType);
                        $("#MailSubject").val(item.mailSubject);
                        $("#Status").data("kendoDropDownList").value(item.status);
                        if (CKEDITOR.instances['editor1']) {
                            CKEDITOR.instances['editor1'].setData(item.detail);
                        } else {
                            $("#editor1").val(item.detail);
                        }
                    }
                },
                error: function () {
                    alert("Không lấy được dữ liệu");
                }
            });
        }

        function onNotiSendChange(e) {
            var notiSend = this.value();
            var notiType = $("#NotiTypeFindUpdate").data("kendoComboBox").value();
            if (!notiType) {
                //CKEDITOR.instances["editor1"].setData("");
                return;
            }
            $.ajax({
                url: '/Noti/GetNotiTemplateDetail',
                type: 'GET',
                data: { pNotiType: notiType, pNotiSend: notiSend },
                success: function (res) {
                    if (res && res.length > 0) {
                        var item = res[0];
                        $("#MailSubject").val(item.mailSubject);
                        $("#Status").data("kendoDropDownList").value(item.status);
                    if (item.detail && item.detail.trim() !== "") {
                        CKEDITOR.instances["editor1"].setData(item.detail);
                    } else {
                        CKEDITOR.instances["editor1"].setData(""); // clear nếu không có detail
                    }
                    }
                },
                error: function () {
                    alert("Không lấy được dữ liệu");
                }
            });
        }
    </script>

