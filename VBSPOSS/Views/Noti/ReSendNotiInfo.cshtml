@Html.Hidden("pTxnPointName", TempData["pTxnPointName"])
@Html.Hidden("pNotiType", TempData["pNotiType"]) 
@Html.Hidden("pPosCode", TempData["pPosCode"])
@Html.Hidden("pTransPoint", TempData["pTransPoint"])
@Html.Hidden("pTransDate", TempData["pTransDate"])

<div style="padding:15px; background:#fff; border-radius:6px;">

    <h6 class="m-0 text-primary fw-bold text-center">
        📋 DANH SÁCH NGƯỜI DÙNG NHẬN LẠI THÔNG BÁO ĐI GDX @TempData["pTxnPointName"]?.ToString().ToUpper()
    </h6>

    @(Html.Kendo().Grid<VBSPOSS.Integration.Model.NotificationDataResponse>()
        .Name("gridResendNoti")
        .BindTo(Model)
        .Columns(columns =>
        {
            columns.Bound(c => c.posCode).Title("Ma PGD").Width(120);
            columns.Bound(c => c.posName).Title("Tên PGD").Width(180);
            columns.Bound(c => c.d1).Title("Mã điểm iao dịch");
            columns.Bound(c => c.d2).Title("UserName");
            columns.Bound(c => c.d3).Title("Mật khẩu");
            columns.Bound(c => c.d15).Title("Nhóm quyền");
           @*  columns.Bound(c => c.status).Title("Status").Width(100)
            .HtmlAttributes(new { style = "text-align:center;" }); *@
        })

        .Selectable(s => s.Mode(GridSelectionMode.Multiple))

        // 🔥 QUAN TRỌNG
        @* .Scrollable() *@
        //.Pageable()
        //.DataSource(...)

        .Sortable()
        )

    <!-- Buttons -->
    <div class="action-group">
        <button class="btn-primary-custom" onclick="onUpdateNoti()">
            ✔ Cập nhật
        </button>

        <button class="btn-secondary-custom" onclick="onCancelNoti()">
            ✖ Hủy bỏ
        </button>
    </div>

</div>

<script>
    function onUpdateNoti() {

        var pNotiType = $("#pNotiType").val();
        var pPosCode = $("#pPosCode").val();
        var pTransPoint = $("#pTransPoint").val();
        var pTransDate = $("#pTransDate").val();

        $.ajax({
            url: '@Url.Action("UpdateNoti", "Noti")',
            type: 'POST',
            data: {
                notiType: pNotiType,
                posCode: pPosCode,
                transPoint: pTransPoint,
                transDate: pTransDate
            },
            success: function (res) {
                if (res.Code === "00") {
                    alert(res.Message);

                    var wnd = $(".k-window-content").data("kendoWindow");
                    if (wnd) wnd.close();

                    var parentGrid = $("#gridMain").data("kendoGrid");
                    if (parentGrid) parentGrid.dataSource.read();
                    else location.reload();

                } else {
                    alert(res.Message); 
                }
            },
            error: function () {
                alert("Có lỗi xảy ra!");
            }
        });
    }

    function onCancelNoti() {
        // Nếu mở bằng Kendo Window
        var wnd = $(".k-window-content").data("kendoWindow");
        if (wnd) {
            wnd.close();
            return;
        }

        // Nếu là page thường
        window.history.back();
    }
</script>