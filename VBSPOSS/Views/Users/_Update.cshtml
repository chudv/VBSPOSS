    function Bind_Ds_CanBo(e) {
        var sDonVi_KeThua_Cd = $("#DonVi_KeThua_Cd_TimKiem").val();
        var dsCanBo = $("#StaffId").data("kendoComboBox");
        if (dsCanBo != null) {
            dsCanBo.dataSource.read();
