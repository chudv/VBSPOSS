@model VBSPOSS.Models.UserModel

<style>
    #mydiv {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1000;
        background-color: grey;
        opacity: .8;
    }

    .ajax-loader {
        position: absolute;
        left: 50%;
        top: 50%;
        margin-left: -32px;
        margin-top: -32px;
        display: block;
    }

    .view_form.row {
        width: 100% !important;
        margin-left: 0;
        margin-right: 0;
    }
</style>

<script src="@Url.Content("~/js/utility.js")"></script>

<script>
    // ====================== PARAM FUNCTIONS ======================
    function paramRole() {
        return { grantType: 0, pTitleChoice: "--- Chọn Nhóm quyền ---" };
    }

    function paramDonViLoad() {
        return { pFlagCondi: "5", pStatus: "O", pShortName: "1", pTitleChoice: "", pFlagShow: "1" };
    }

    function paramStaffByPosCode() {
        return {
            pPosCode: $("#DonVi_KeThua_Cd_TimKiem").val() || "",
            pTitleChoice: "--- Chọn cán bộ ---",
            pFlagTextShow: "2"
        };
    }

    // ====================== GLOBAL FLAGS ======================
    var isSubmitting = false;
    var isLoadingStaff = false;
    var lastSelectedStaffId = "";

    // ====================== COMMON FUNCTIONS ======================
    function Bind_Ds_CanBo() {
        var dsCanBo = $("#StaffId").data("kendoComboBox");
        if (!dsCanBo) return;

        // Reset dữ liệu cán bộ khi đổi đơn vị
        dsCanBo.value("");
        dsCanBo.text("");
        lastSelectedStaffId = "";

        clearAllStaffFields();
        dsCanBo.dataSource.read();
    }

    function onExit() {
        mainWindow.data("kendoWindow").close();
    }

    function clearAllStaffFields() {
        $("#FullName").val("");
        $("#PosName").val("");
        $("#TitleDesc").val("");
        $("#DepartmentDesc").val("");
        $("#DegreeDesc").val("");
        $("#Genders").val("");
        $("#Mobile").val("");
        $("#Email").val("");
        $("#IssuedPlace").val("");

        $("#PosCode").val("");
        $("#TitleCode").val("");
        $("#DepartmentCode").val("");
        $("#DegreeCode").val("");

        var birthPicker = $("#UserBirthday").data("kendoDatePicker");
        if (birthPicker) birthPicker.value(null);

        var issuedPicker = $("#IssuedDate").data("kendoDatePicker");
        if (issuedPicker) issuedPicker.value(null);

        var masked = $("#IdCode").data("kendoMaskedTextBox");
        if (masked) {
            masked.value("");
        } else {
            $("#IdCode").val("");
        }
    }

    // ====================== LOAD CÁN BỘ ======================
    function onStaffSelect(e) {
        var combo = this;
        var dataItem = combo.dataItem(e.item.index());

        if (!dataItem) return;

        var staffId = dataItem.id || dataItem.StaffId || "";
        if (!staffId) return;

        if (staffId === lastSelectedStaffId) return;

        lastSelectedStaffId = staffId;
        $("#StaffId").val(staffId);

        LoadDsCanBo_ThanhVien(staffId);
    }

    function LoadDsCanBo_ThanhVien(staffId) {
        if (!staffId || staffId === "0" || isLoadingStaff) {
            return;
        }

        isLoadingStaff = true;
        $("#mydiv").show();

        $.ajax({
            type: "GET",
            url: "@Url.Action("GetListStaffVBSPByStaffId", "ListOfValue")",
            data: { pStaffId: staffId },
            success: function (response) {
                if (!response || response.length === 0) {
                    alert("Không tìm thấy thông tin cán bộ với StaffId này!");
                    clearAllStaffFields();
                    return;
                }

                var data = Array.isArray(response) ? response[0] : response;
                if (!data) {
                    alert("Không tìm thấy thông tin cán bộ!");
                    clearAllStaffFields();
                    return;
                }

                $("#StaffId").val(data.StaffCode || data.StaffId || "");
                $("#FullName").val(data.StaffName || data.FullName || "");
                $("#PosName").val(data.PosName || data.StaffPosName || "");
                $("#TitleDesc").val(data.StaffPositionName || data.TitleDesc || "");
                $("#DepartmentDesc").val(data.StaffDepartmentName || data.DepartmentDesc || "");
                $("#DegreeDesc").val(data.DegreeDesc || data.DegreeName || "");
                $("#Genders").val(data.GenderText || (data.GenderCode === "M" ? "Nam" : "Nữ") || "");
                $("#Mobile").val(data.StaffMobileNo || data.Mobile || "");
                $("#Email").val(data.StaffEmail || data.Email || "");

                $("#PosCode").val(data.PosCode || data.StaffPosCode || "");
                $("#TitleCode").val(data.StaffPositionCode || data.TitleCode || "");
                $("#DepartmentCode").val(data.StaffDepartmentCode || data.DepartmentCode || "");
                $("#DegreeCode").val(data.DegreeCode || "");

                var masked = $("#IdCode").data("kendoMaskedTextBox");
                if (masked) {
                    masked.value(data.IdNo || "");
                } else {
                    $("#IdCode").val(data.IdNo || "");
                }

                var birthPicker = $("#UserBirthday").data("kendoDatePicker");
                if (birthPicker) {
                    var birthDate = data.DateOfBirth || data.UserBirthday;
                    birthPicker.value(birthDate ? new Date(birthDate) : null);
                }

                var issuedPicker = $("#IssuedDate").data("kendoDatePicker");
                if (issuedPicker) {
                    issuedPicker.value(data.IssuedDate ? new Date(data.IssuedDate) : null);
                }

                $("#IssuedPlace").val(data.IssuedPlace || "");
            },
            error: function (xhr, status, error) {
                console.error("Lỗi khi gọi API GetListStaffVBSPByStaffId:", xhr.responseText || error);
                alert("Lỗi khi lấy thông tin cán bộ!");
            },
            complete: function () {
                isLoadingStaff = false;
                $("#mydiv").hide();
            }
        });
    }

    // ====================== VALIDATION ======================
    function onSaveData(e) {
        var lcTen_Nd = $("#UserName").val()?.trim();
        var lcNd_MatKhau = $("#Password").val()?.trim();
        var lcHoTen = $("#FullName").val()?.trim();
        var lcNhom = $("#DefaultRole").data("kendoComboBox")?.value() || $("#DefaultRole").val();

        if (!lcTen_Nd) {
            alert("Tên đăng nhập không được để trống!");
            $("#UserName").focus();
            if (e) e.preventDefault();
            return false;
        }

        if (parseInt($("#Id").val() || 0) === 0 && !lcNd_MatKhau) {
            alert("Mật khẩu không được để trống khi thêm mới!");
            $("#Password").focus();
            if (e) e.preventDefault();
            return false;
        }

        if (!lcHoTen) {
            alert("Họ và tên không được để trống!");
            $("#FullName").focus();
            if (e) e.preventDefault();
            return false;
        }

        if (!lcNhom) {
            alert("Nhóm quyền không được để trống!");
            $("#DefaultRole").focus();
            if (e) e.preventDefault();
            return false;
        }

        return true;
    }

    // ====================== INIT ======================
    $(document).ready(function () {
        $("#mydiv").hide();

        var isEdit = parseInt($("#IsEdit").val() || 0);

        if (isEdit === 1) {
            $("#UserName").attr("readonly", true);

            var pw = $("#user_password").data("kendoTextBox");
            if (pw) pw.wrapper.hide();

            $("#lbl_matkhau").hide();

            $("#StaffId, #DonVi_KeThua_Cd_TimKiem").each(function () {
                var cb = $(this).data("kendoComboBox");
                if (cb) cb.enable(false);
            });
        } else {
            var pw2 = $("#user_password").data("kendoTextBox");
            if (pw2) pw2.wrapper.show();

            $("#lbl_matkhau").show();

            $("#StaffId, #DonVi_KeThua_Cd_TimKiem").each(function () {
                var cb = $(this).data("kendoComboBox");
                if (cb) cb.enable(true);
            });
        }

        $("#form0").on("submit", function (event) {
            event.preventDefault();

            if (isSubmitting) return false;
            if (!onSaveData(event)) return false;

            var validator = $(this).data("kendoValidator");
            if (validator && !validator.validate()) {
                return false;
            }

            isSubmitting = true;
            $("#mydiv").show();

            var form = this;
            var formData = new FormData(form);

            // Lấy giá trị chuẩn từ Kendo controls / hidden fields
            formData.set("Id", $("#Id").val() || "0");
            formData.set("IsEdit", $("#IsEdit").val() || "0");
            formData.set("UserName", $("#UserName").val() || "");
            formData.set("Password", $("#Password").val() || "");
            formData.set("FullName", $("#FullName").val() || "");
            formData.set("Mobile", $("#Mobile").val() || "");
            formData.set("Email", $("#Email").val() || "");
            formData.set("IssuedPlace", $("#IssuedPlace").val() || "");

            formData.set("StaffId", $("#StaffId").val() || "");
            formData.set("PosCode", $("#PosCode").val() || "");
            formData.set("TitleCode", $("#TitleCode").val() || "");
            formData.set("DepartmentCode", $("#DepartmentCode").val() || "");
            formData.set("DegreeCode", $("#DegreeCode").val() || "");

            var roleCombo = $("#DefaultRole").data("kendoComboBox");
            formData.set("DefaultRole", roleCombo ? roleCombo.value() : ($("#DefaultRole").val() || ""));

            var statusDropDown = $("#Status").data("kendoDropDownList");
            formData.set("Status", statusDropDown ? statusDropDown.value() : ($("#Status").val() || ""));

            var userBirthday = $("#UserBirthday").data("kendoDatePicker");
            formData.set("UserBirthday", userBirthday && userBirthday.value()
                ? kendo.toString(userBirthday.value(), "yyyy-MM-dd")
                : "");

            var issuedDate = $("#IssuedDate").data("kendoDatePicker");
            formData.set("IssuedDate", issuedDate && issuedDate.value()
                ? kendo.toString(issuedDate.value(), "yyyy-MM-dd")
                : "");

            var masked = $("#IdCode").data("kendoMaskedTextBox");
            formData.set("IdCode", masked ? masked.value() : ($("#IdCode").val() || ""));

            $.ajax({
                url: form.action,
                type: form.method || "POST",
                data: formData,
                contentType: false,
                processData: false,
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (result) {
                    if (result == "0") {
                        alert("Cập nhật thành công người dùng " + ($("#FullName").val() || "") + " [" + ($("#UserName").val() || "") + "]!");
                        onExit();
                    } else if (result == "1") {
                        alert("Tên đăng nhập đã tồn tại!");
                    } else {
                        alert("Có lỗi xảy ra: " + result);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Lỗi AJAX:", xhr.responseText || error);
                    alert("Lỗi khi lưu dữ liệu! Vui lòng xem console (F12) để biết chi tiết.");
                },
                complete: function () {
                    isSubmitting = false;
                    $("#mydiv").hide();
                }
            });

            return false;
        });
    });
</script>

<form asp-controller="Users" asp-action="CreateUser" method="post" id="form0" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id, new { Value = Model?.Id ?? 0 })
    @Html.Hidden("IsEdit", TempData["IsEdit"])
    @Html.HiddenFor(m => m.PosCode)
    @Html.HiddenFor(m => m.TitleCode)

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-4">
            <label class="control-label" style="color:blueviolet; padding-top: 3px;">Phòng giao dịch/ Hội sở</label>
        </div>
        <div class="col-md-8">
            @(Html.Kendo().ComboBox()
                        .Name("DonVi_KeThua_Cd_TimKiem")
                        .Filter(FilterType.Contains)
                        .Placeholder("--- Chọn đơn vị cập nhật người dùng ---")
                        .DataTextField("value")
                        .DataValueField("id")
                        .Events(e => e.Change("Bind_Ds_CanBo"))
                        .DataSource(source => source.Read(read => read.Action("GetListBranchs", "ListOfValue").Data("paramDonViLoad")))
                        .Suggest(true)
                        .AutoBind(true)
                        .HtmlAttributes(new { style = "width: 660px !important;color:navy;" }))
        </div>
    </div>

    <div style="color: navy; padding-top: 6px;" class="row">
        <div class="col-md-12">
            <label style="width: 200px; color: navy; text-align:left;">
                Cán bộ phân quyền <span style="color:red;">*</span>
            </label>
            @(Html.Kendo().ComboBoxFor(m => m.StaffId)
                        .Filter(FilterType.Contains)
                        .Placeholder("--- Danh sách cán bộ ---")
                        .DataTextField("value")
                        .DataValueField("id")
                        .ClearButton(false)
                        .DataSource(source => source.Read(read => read.Action("GetListStaffVBSP", "ListOfValue").Data("paramStaffByPosCode")))
                        .HtmlAttributes(new { style = "width: 770px; color: green;" })
                        .Events(e => e.Select("onStaffSelect"))
                        .Suggest(true)
                        .AutoBind(false))
        </div>
    </div>

    <div class="row" style="padding-top: 12px;">
        <div class="col-md-12" style="display: inline-flex; align-items: center; gap: 12px;">
            <label style="width:100px; text-align:right;">Ngày sinh</label>
            @Html.Kendo().DatePickerFor(m => m.UserBirthday).Format("dd/MM/yyyy").HtmlAttributes(new { @readonly = "readonly", style = "width: 90px; color: blueviolet;" })

            <label style="width:80px; text-align:right;">Giới tính</label>
            @Html.Kendo().TextBox().Name("Genders").HtmlAttributes(new { @readonly = "readonly", style = "width: 70px; color: blueviolet;" })

            <label style="width:100px; text-align:right;">Điện thoại</label>
            @Html.Kendo().TextBoxFor(m => m.Mobile).HtmlAttributes(new { @readonly = "readonly", style = "width: 100px; color: blueviolet;" })

            <label style="width:70px; text-align:right;">Email</label>
            @Html.Kendo().TextBoxFor(m => m.Email).HtmlAttributes(new { @readonly = "readonly", style = "width: 240px; color: blueviolet;" })
        </div>
    </div>

    <div class="row" style="padding-top: 8px;">
        <div class="col-md-12" style="display: inline-flex; align-items: center; gap: 12px;">
            <label style="width:90px;">Chức vụ</label>
            @Html.Kendo().TextBoxFor(m => m.TitleDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 220px; color: blueviolet;" })

            <label style="width:90px; text-align:right;">Mã Phòng ban</label>
            @Html.Kendo().TextBoxFor(m => m.DepartmentCode).HtmlAttributes(new { @readonly = "readonly", style = "width: 180px; color: blueviolet;" })

            <label style="width:90px; text-align:right;">Phòng ban</label>
            @Html.Kendo().TextBoxFor(m => m.DepartmentDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 180px; color: blueviolet;" })

            <label style="width:80px; text-align:right;">Đơn vị</label>
            @Html.Kendo().TextBoxFor(m => m.PosName).HtmlAttributes(new { @readonly = "readonly", style = "width: 360px; color: blueviolet;" })
        </div>
    </div>

    <div class="row" style="padding-top: 8px;">
        <div class="col-md-12" style="display: inline-flex; align-items: center; gap: 12px;">
            <label style="width:90px;">Trình độ</label>
            @Html.Kendo().TextBoxFor(m => m.DegreeCode).HtmlAttributes(new { @readonly = "readonly", style = "width: 200px; color: blueviolet;" })

            <label style="width:100px; text-align:right;">Ngày cấp CCCD</label>
            @Html.Kendo().DatePickerFor(m => m.IssuedDate).Format("dd/MM/yyyy").HtmlAttributes(new { @readonly = "readonly", style = "width: 100px; color: blueviolet;" })

            <label style="width:80px; text-align:right;">Nơi cấp</label>
            @Html.Kendo().TextBoxFor(m => m.IssuedPlace).HtmlAttributes(new { @readonly = "readonly", style = "width: 250px; color: blueviolet;" })
        </div>
    </div>

    <div class="view_form row" style="padding-top:10px;">
        <div class="col-md-6">
            <label class="control-label" style="text-align: left; color: navy; padding-top: 3px;">Tên đăng nhập (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.UserName).HtmlAttributes(new { style = "width: 150px; max-width:100% !important;color:navy;" })

            <label id="lbl_matkhau" class="control-label" style="text-align: right; padding-right: 3px; padding-top: 3px;">Mật khẩu (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.Password).HtmlAttributes(new
                        {
                @class = "form-control",
                        type = "password",
                        placeholder = "Nhập mật khẩu",
                        style = "width: 130px; max-width:100% !important;color:navy;"
                        })
        </div>

        <div class="col-md-6">
            <label id="lbl_hoten" class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px;">Họ và tên (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.FullName).HtmlAttributes(new { style = "width: 230px; max-width:100% !important;color:navy;" })
        </div>
    </div>

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-7">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px;">Nhóm người dùng (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.DefaultRole)
                        .Filter(FilterType.Contains)
                        .Placeholder("Nhóm quyền")
                        .DataTextField("value")
                        .DataValueField("id")
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetRoles", "RoleManagement").Data("paramRole");
                            }).ServerFiltering(false);
                        })
                        .HtmlAttributes(new { style = "width: 400px !important;color: navy;" })
                        .Suggest(true)
                        .AutoBind(true))
        </div>
    </div>

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-6">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Số CCCD (<font color="red">*</font>)</label>
            @Html.Kendo().MaskedTextBoxFor(m => m.IdCode).Mask("0000 0000 0000 ").HtmlAttributes(new { data_validmask_msg = "Giá trị không hợp lệ", style = "width: 195px !important;max-width: 100% !important;color: navy;" })
        </div>

        <div class="col-md-6">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Trạng thái (<font color="red">*</font>)</label>
            @(Html.Kendo().DropDownList()
                        .Name("Status")
                        .DataTextField("Text")
                        .DataValueField("Value")
                        .BindTo(new List<SelectListItem>()
                        {
                        new SelectListItem() { Text = "Mở", Value = "1" },
                        new SelectListItem() { Text = "Đóng", Value = "0" }
                        })
                        .SelectedIndex(0)
                        .HtmlAttributes(new { style = "width: 100px !important;color: navy;" }))
        </div>
    </div>

    <hr style="margin-top: 1em; margin-bottom: 0.2em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc);" />

    <div class="view_form row" style="padding-top:10px;padding-right:20px;">
        <div class="col-md-12 text-right">
            <div style="float:right; width:30%;text-align:right;padding-right:10px;">
                @(Html.Kendo().Button()
                                .Name("btnSave")
                                .HtmlAttributes(new
                                {
                                    type = "submit",
                                    style = "margin-right: 1.3em; width: 87px; font-weight:bold; color: blue;",
                                    title = "Lưu thông tin vừa Thêm mới/Sửa đổi"
                                })
                                .ImageUrl(Url.Content("~/images/save.png"))
                                .Content(" Lưu lại"))

                @(Html.Kendo().Button()
                                .Name("btnExit")
                                .Events(ev => ev.Click("onExit"))
                                .HtmlAttributes(new
                                {
                                    type = "button",
                                    style = "width: 85px; font-weight:bold; color: blue;",
                                    title = "Đóng lại màn hình cập nhật Văn bản, tài liệu"
                                })
                                .ImageUrl(Url.Content("~/images/close_icon.gif"))
                                .Content(" Quay ra"))
            </div>
        </div>
    </div>

    <div id="mydiv">
        <img style="height:80px;" src="~/images/loading.gif" class="ajax-loader" />
    </div>
</form>