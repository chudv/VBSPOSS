        var lcNhomNd_Cd = $("#DefaultRole").val();


        var dNgaySinh = stringToDate(lcNgaySinh, "dd/MM/yyyy", "/");
        var dNgayCap = stringToDate(lcNgayCap, "dd/MM/yyyy", "/");


        if (lcTen_Nd == null || lcTen_Nd == "") {
            alert('Tên đăng nhập không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#UserName').focus();
