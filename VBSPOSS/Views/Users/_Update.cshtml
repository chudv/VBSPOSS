@model VBSPOSS.Models.UserModel



<style>
    #mydiv {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1000;
        background-color: grey;
        opacity: .8;
    }

    .ajax-loader {
        position: absolute;
        left: 50%;
        top: 50%;
        margin-left: -32px; /* -1 * image width / 2 */
        margin-top: -32px; /* -1 * image height / 2 */
        display: block;
    }


    .view_form.row {
        width: 100% !important;
        margin-left: 0;
        margin-right: 0;
    }
</style>

<script src="@Url.Content("~/js/utility.js")"></script>

<script>
    // ====================== PARAM FUNCTIONS ======================
    function paramPhongBan_Update() {
        return { pFlagCallRoot: "0", pParentId: "15", pTenVT: "0", pTitleChoice: "--- Chọn Phòng ban ---", pStatus: "1" };
    }
    function paramChucVu_Update() {
        return { pFlagCallRoot: "0", pParentId: "14", pTenVT: "0", pTitleChoice: "--- Chọn Chức vụ ---", pStatus: "1" };
    }
    function paramDonViCT() {
        return { pFlagCondi: "5", pStatus: "", pShortName: "1", pTitleChoice: "", pFlagShow: "1" };
    }
    function paramDegree_Update() {
        return { pFlagCallRoot: "0", pParentId: "38", pTenVT: "0", pTitleChoice: "--- Chọn Trình độ ---", pStatus: "1" };
    }
    function paramRole() {
        return { grantType: 0, pTitleChoice: "--- Chọn Nhóm quyền ---" };
    }
    function paramDonViLoad() {
        return { pFlagCondi: "5", pStatus: "O", pShortName: "1", pTitleChoice: "", pFlagShow: "1" };
    }
    function paramUserPosCode() {
        return { posCode: $("#DonVi_KeThua_Cd_TimKiem").val() };
    }

        function paramStaffByPosCode() {
        return {
            pPosCode: $("#DonVi_KeThua_Cd_TimKiem").val() || "",
            pTitleChoice: "--- Chọn cán bộ ---",
            pFlagTextShow: "2"        //
        };
    }

    // ====================== COMMON FUNCTIONS ======================
    function Change_DonVi(e) {
        $("#DepartmentCode, #TitleCode").each(function () {
            var cb = $(this).data("kendoComboBox");
            if (cb) cb.dataSource.read();
        });
    }

    function Bind_Ds_CanBo(e) {
        var dsCanBo = $("#StaffId").data("kendoComboBox");
        if (dsCanBo) dsCanBo.dataSource.read();
    }

    function onExit() {
        mainWindow.data("kendoWindow").close();
    }

    function Find_ReplaceALL(str, target, replacement) {
        return (str || "").split(target).join(replacement);
    }

    function stringToDate(_date, _format, _delimiter) {
        if (typeof _date !== 'string') return null;
        var formatItems = _format.toLowerCase().split(_delimiter);
        var dateItems = _date.split(_delimiter);
        if (formatItems.length !== dateItems.length) return null;

        var month = parseInt(dateItems[formatItems.indexOf("mm")], 10) - 1;
        var day = parseInt(dateItems[formatItems.indexOf("dd")], 10);
        var year = parseInt(dateItems[formatItems.indexOf("yyyy")], 10);
        if (isNaN(day) || isNaN(month) || isNaN(year)) return null;
        return new Date(year, month, day);
    }

    // ====================== LOAD CÁN BỘ ======================

    function LoadDsCanBo_ThanhVien(e) {
        var staffId = $("#StaffId").val();
        if (!staffId || staffId === "0") return;

        $.ajax({
            type: "GET",
            url: "@Url.Action("GetListStaffVBSPByStaffId", "ListOfValue")",
            data: { pStaffId: staffId },
            success: function (response) {
                if (!response || response.length === 0) {
                    alert("Không tìm thấy thông tin cán bộ!");
                    return;
                }

                var data = response[0];   // API trả về mảng

                $("#UserName").val("");
                $("#FullName").val(data.StaffName || "");

                $("#Sex").data("kendoDropDownList").value(data.GenderCode || "M");

                if (data.DateOfBirth) {
                    $("#UserBirthday").data("kendoDatePicker").value(new Date(data.DateOfBirth));
                }

                if (data.PosCode) {
                    $("#PosCode").data("kendoComboBox").value(data.PosCode);
                }

                Change_DonVi();   // Load lại Phòng ban theo đơn vị mới

                setTimeout(() => {
                    // Phòng ban
                    if (data.StaffDepartmentCode) {
                        $("#DepartmentCode").data("kendoComboBox").value(data.StaffDepartmentCode);
                    }

                    // Chức vụ
                    if (data.StaffPositionCode) {
                        $("#TitleCode").data("kendoComboBox").value(data.StaffPositionCode);
                    }

                    // Trình độ
                    if (data.DegreeCode) {
                        $("#DegreeCode").data("kendoComboBox").value(data.DegreeCode);
                    }

                    // CCCD (quan trọng)
                    if (data.IdNo) {
                        $("#IdCode").data("kendoMaskedTextBox").value(data.IdNo);
                    }

                    // Ngày cấp & Nơi cấp
                    if (data.IssuedDate) {
                        $("#IssuedDate").data("kendoDatePicker").value(new Date(data.IssuedDate));
                    }
                    $("#IssuedPlace").val(data.IssuedPlace || "");

                    $("#Mobile").val(data.StaffMobileNo || "");
                    $("#Email").val(data.StaffEmail || "");

                }, 500);
            },
            error: function () {
                alert("Không thể lấy thông tin cán bộ!");
            }
        });
    }

    // ====================== VALIDATION ======================
    function onClick(e) {
        var lcTen_Nd = $("#UserName").val()?.trim();
        var lcNd_MatKhau = $("#Password").val()?.trim();
        var lcHoTen = $("#FullName").val()?.trim();
        var lcNgaySinh = $("#UserBirthday").val();
        var lcDonVi = $("#PosCode").val();
        var lcPhongBan = $("#DepartmentCode").val();
        var lcChucVu = $("#TitleCode").val();
        var lcTrinhDo = $("#DegreeCode").val();
        var lcDienThoai = Find_ReplaceALL(Find_ReplaceALL($("#Mobile").val() || "", " ", ""), "_", "");
        var lcSoCMT = Find_ReplaceALL(Find_ReplaceALL($("#IdCode").val() || "", " ", ""), "_", "");
        var lcNgayCap = $("#IssuedDate").val();
        var lcId = $("#Id").val();
        var lcNhom = $("#DefaultRole").val();

        var dSinh = stringToDate(lcNgaySinh, "dd/MM/yyyy", "/");
        var dCap = stringToDate(lcNgayCap, "dd/MM/yyyy", "/");

        if (!lcTen_Nd) { alert('Tên đăng nhập không được để trống!'); $('#UserName').focus(); e.preventDefault(); return false; }
        if (parseInt(lcId || 0) === 0 && !lcNd_MatKhau) {
            alert('Mật khẩu không được để trống!'); $('#Password').focus(); e.preventDefault(); return false;
        }
        if (!lcHoTen) { alert('Họ và tên không được để trống!'); $('#FullName').focus(); e.preventDefault(); return false; }
        if (!lcNgaySinh) { alert('Ngày sinh không được để trống!'); $('#UserBirthday').focus(); e.preventDefault(); return false; }
        if (!lcDonVi) { alert('Đơn vị không được để trống!'); $('#PosCode').focus(); e.preventDefault(); return false; }
        if (!lcPhongBan) { alert('Phòng ban không được để trống!'); $('#DepartmentCode').focus(); e.preventDefault(); return false; }
        if (!lcChucVu) { alert('Chức vụ không được để trống!'); $('#TitleCode').focus(); e.preventDefault(); return false; }
        if (!lcTrinhDo) { alert('Trình độ không được để trống!'); $('#DegreeCode').focus(); e.preventDefault(); return false; }
        if (!lcSoCMT || lcSoCMT.length < 9) { alert('Số CCCD không hợp lệ!'); $('#IdCode').focus(); e.preventDefault(); return false; }
        if (dSinh && dCap && dSinh > dCap) { alert('Ngày cấp CCCD không thể nhỏ hơn ngày sinh!'); e.preventDefault(); return false; }
        if (!lcNhom) { alert('Nhóm quyền không được để trống!'); $('#DefaultRole').focus(); e.preventDefault(); return false; }
        if (!lcDienThoai || !isValidVNMobile(lcDienThoai)) {
            alert('Số điện thoại không đúng định dạng!'); $('#Mobile').focus(); e.preventDefault(); return false;
        }
    }


    function initKeThuaCombo() {
        if ($("#DonVi_KeThua_Cd_TimKiem").data("kendoComboBox")) return;

        $("#DonVi_KeThua_Cd_TimKiem").kendoComboBox({
            change: Bind_Ds_CanBo,
            dataBound: Bind_Ds_CanBo,
            autoBind: true,
            dataTextField: "value",
            dataValueField: "id",
            placeholder: "--- Chọn đơn vị cập nhật người dùng ---",
            suggest: true,
            filter: "contains",
            dataSource: { transport: { read: { url: "/ListOfValue/GetListBranchs", data: paramDonViLoad } } }
        });
    }

    $(document).ready(function () {
        initKeThuaCombo();

        var isEdit = parseInt($("#IsEdit").val() || 0);

        if (isEdit === 1) {
            $("#UserName").attr('readonly', true);
            var pw = $("#user_password").data("kendoTextBox");
            if (pw) pw.wrapper.hide();
            $('#lbl_matkhau').hide();
            $("#StaffId, #DonVi_KeThua_Cd_TimKiem").each(function () {
                var cb = $(this).data("kendoComboBox");
                if (cb) cb.enable(false);
            });
        } else {
            var pw = $("#user_password").data("kendoTextBox");
            if (pw) pw.wrapper.show();
            $('#lbl_matkhau').show();
            $("#StaffId, #DonVi_KeThua_Cd_TimKiem").each(function () {
                var cb = $(this).data("kendoComboBox");
                if (cb) cb.enable(true);
            });
        }
    });
</script>

<form asp-controller="Users" asp-action="CreateUser" data-ajax="true" data-ajax-method="POST" id="form0" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id, new { Value = Model?.Id ?? 0 })
    @Html.Hidden("IsEdit", TempData["IsEdit"])

    <!-- Kế thừa cán bộ -->
    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-4">
            <label class="control-label" style="color:blueviolet; padding-top: 3px;">Kế thừa thông tin từ danh sách cán bộ</label>
        </div>
        <div class="col-md-8">
            @(Html.Kendo().ComboBox()
                .Name("DonVi_KeThua_Cd_TimKiem")
                .Filter(FilterType.Contains)
                .Placeholder("--- Chọn đơn vị cập nhật người dùng ---")
                .DataTextField("value")
                .DataValueField("id")
                .Suggest(true)
                .AutoBind(true)
                .HtmlAttributes(new { style = "width: 660px !important;color:navy;" })
                .Deferred()
                )
        </div>
    </div>

    <!-- Chọn cán bộ -->

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-4"></div>
        <div class="col-md-8">
            @(Html.Kendo().ComboBoxFor(m => m.StaffId)
                .Filter(FilterType.Contains)
                .Placeholder("Vui lòng chọn cán bộ")
                .DataTextField("value")
                .DataValueField("id")
                .Events(v => v.Change("LoadDsCanBo_ThanhVien"))
                .DataSource(ds => ds.Read(read => read
                .Action("GetListStaffVBSP", "ListOfValue")
                .Data("paramStaffByPosCode")
                ))
                .HtmlAttributes(new { style = "width:660px !important;color:navy;" })
                .Suggest(true)
                .AutoBind(false)
                .MinLength(0)
                )
        </div>
    </div>



    <div class="view_form row" style="padding-top:10px;">
        <div class="col-md-6">
            <label class="control-label" style="text-align: left; color: navy; padding-top: 3px;">Tên đăng nhập (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.UserName).HtmlAttributes(new { style = "width: 150px; !important;max-width:100% !important;color:navy;" })
            <label id="lbl_matkhau" class="control-label" style="text-align: right; padding-right: 3px; padding-top: 3px; ">Mật khẩu (<font color="red">*</font>)</label>
            @* @Html.PasswordFor(m => m.Password, new { @class = "k-textbox", placeholder = "Mật khẩu người dùng", style = "width: 130px; !important;max-width:100% !important;color:navy;" }) *@
            @Html.Kendo().TextBoxFor(m => m.Password).HtmlAttributes(new
                {
                    @class = "form-control",
                    type = "password",
                    placeholder = "Nhập mật khẩu",
                    style = "width: 130px; !important;max-width:100% !important;color:navy;"
                })
        </div>




        <div class="col-md-6">
            <label id="lbl_hoten" class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Họ và tên (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.FullName).HtmlAttributes(new { style = "width: 230px; !important;max-width:100% !important;color:navy;" })

            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Giới tính</label>
            @(Html.Kendo().DropDownList()
                .Name("Sex")
                .DataTextField("Text")
                .DataValueField("Value")
                .BindTo(new List<SelectListItem>() { new SelectListItem() { Text = "Nam", Value = "M" }, new SelectListItem() { Text = "Nữ", Value = "F" } })
                .SelectedIndex(0)
                .HtmlAttributes(new { style = "width: 110px !important;color:navy;" })
                )
        </div>
    </div>
    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-3">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Ngày sinh (<font color="red">*</font>)</label>
            @Html.Kendo().DatePickerFor(m => m.UserBirthday).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 120px !important;color:navy;" })


        </div>
        <div class="col-md-4">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Đơn vị (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.PosCode)
                .Filter(FilterType.Contains)
                .Placeholder("Đơn vị công tác người dùng")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(
                source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramDonViCT"); }).ServerFiltering(false); })
                .Events(v => v.Change("Change_DonVi"))
                .HtmlAttributes(new { style = "width: 230px !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )
        </div>
        <div class="col-md-5">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Phòng/ban (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.DepartmentCode)
                .Filter(FilterType.Contains)
                .Placeholder("Phòng/ban công tác người dùng")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source =>
                { source.Read(read => { read.Action("GetListMain_ByConditions", "ListOfValue").Data("paramPhongBan_Update"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 260px !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )
        </div>
    </div>

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-4">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Chức vụ (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.TitleCode)
                .Filter(FilterType.Contains)
                .Placeholder("Chức vụ người dùng")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source =>
                { source.Read(read => { read.Action("GetListMain_ByConditions", "ListOfValue").Data("paramChucVu_Update"); ; }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 245px !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )


        </div>
        <div class="col-md-4">
            <label class="control-label" style="color: navy; padding-right: 3px; padding-top: 3px; ">Trình độ (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.DegreeCode)
                .Filter(FilterType.Contains)
                .Placeholder("Trình độ chuyên môn")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source =>
                { source.Read(read => { read.Action("GetListMain_ByConditions", "ListOfValue").Data("paramDegree_Update"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 180px !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )
        </div>
        <div class="col-md-4">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Điện thoại</label>
            @* @(Html.Kendo().MaskedTextBoxFor(m => m.Mobile) *@
            @*     .Mask("00 000 000 000 000")
                .HtmlAttributes(new { data_validmask_msg = "Giá trị không hợp lệ", }).HtmlAttributes(new { style = "width: 200px !important;color: navy;" })
                ) *@

            @(Html.Kendo().MaskedTextBoxFor(m => m.Mobile)
                .Mask("0000 000 000") // Định dạng
                .HtmlAttributes(new { data_validmask_msg = "Giá trị không hợp lệ", style = "width: 200px !important;color: navy;" })
                )
        </div>
    </div>

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-5">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Địa chỉ e-mail</label>
            @Html.Kendo().TextBoxFor(m => m.Email).HtmlAttributes(new { placeholder = "Địa chỉ E-mail", type = "email", data_email_msg = "Địa chỉ E-mail không hợp lệ", style = "width: 245px !important;max-width: 100% !important;color: navy;" })
        </div>
        <div class="col-md-7">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Nhóm người dùng (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.DefaultRole)
                .Filter(FilterType.Contains)
                .Placeholder("Nhóm quyền")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source =>
                { source.Read(read => { read.Action("GetRoles", "RoleManagement").Data("paramRole"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 400px !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )
        </div>
    </div>

    <div class="view_form row" style="padding-top:5px;">
        <div class="col-md-6">
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Số CCCD (<font color="red">*</font>)</label>
            @Html.Kendo().MaskedTextBoxFor(m => m.IdCode).Mask("0000 0000 0000 ").HtmlAttributes(new { data_validmask_msg = "Giá trị không hợp lệ", }).HtmlAttributes(new { style = "width: 195px !important;max-width: 100% !important;color: navy;" })
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Ngày cấp</label>
            @Html.Kendo().DatePickerFor(m => m.IssuedDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 120px !important;color:navy;" })
        </div>
        <div class="col-md-6">
            <label class="control-label" style="text-align: right; color: navy; padding-right: 3px; padding-top: 3px; ">Nơi cấp</label>
            @Html.Kendo().TextBoxFor(m => m.IssuedPlace).HtmlAttributes(new { style = "width: 120px !important;color:navy;" })
            <label class="control-label" style="text-align: left; color: navy;padding-top:3px;">Trạng thái (<font color="red">*</font>)</label>
            @(Html.Kendo().DropDownList()
                .Name("Status")
                .DataTextField("Text")
                .DataValueField("Value")
                .BindTo(new List<SelectListItem>() { new SelectListItem() { Text = "Mở", Value = "1" }, new SelectListItem() { Text = "Đóng", Value = "0" } })
                .SelectedIndex(0)
                .HtmlAttributes(new { style = "width: 100px !important;color: navy;" })
                )
        </div>
    </div>

    <hr style='margin-top: 1em; margin-bottom: 0.2em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />
    <div class="view_form row" style="padding-top:10px;padding-right:20px;">
        <div class="col-md-12 text-right">
            <div style="float:right; width:30%;text-align:right;padding-right:10px;">
                @(Html.Kendo().Button()
                    .Name("btnSave")
                    .Events(v => v.Click("onClick"))
                    .HtmlAttributes(new { type = "submit", style = "margin-right: 1.3em; width: 87px; font-weight:bold; color: blue;", title = "Lưu thông tin vừa Thêm mới/Sửa đổi" })
                    .ImageUrl(Url.Content("~/images/save.png"))
                    .Content(" Lưu lại"))
                @(Html.Kendo().Button().Name("btnExit").Events(ev => ev.Click("onExit")).HtmlAttributes(new { type = "button", style = "width: 85px; font-weight:bold; color: blue;", title = "Đóng lại màn hình cập nhật Văn bản, tài liệu" }).ImageUrl(Url.Content("~/images/close_icon.gif")).Content(" Quay ra"))
            </div>
        </div>
    </div>


    <div id="mydiv">
        <img style="height:80px;" src="~/images/loading.gif" class="ajax-loader" />
    </div>



</form>


<script>
    $('#mydiv').hide();

    $(function () {
        $("form").kendoValidator();
    });

    function OnSuccess(response) {
        alert("Lưu dữ liệu thành công!");
        clearControls();
    }

    function OnFailure(response) {
        alert("Có lỗi khi lưu dữ liệu: " + response);
    }

    function OnComplete(response) {
    }

    function clearControls() {
    }

    $("#form0").submit(function (event) {
        event.preventDefault();
        $('#mydiv').show();

        $.ajax({
            url: this.action,
            type: this.method,
            data: new FormData(this),
            contentType: false,
            processData: false,
            success: function (result) {
                $('#mydiv').hide();
                if (result == "0") {
                    alert("Cập nhật thành công người dùng " + $("#FullName").val() + " [" + $("#UserName").val() + "]!");
                    onExit();
                } else {
                    // các alert lỗi của bạn
                    alert(result == "1" ? "Tên đăng nhập đã tồn tại!" : "Có lỗi xảy ra!");
                }
            },
            error: function () {
                $('#mydiv').hide();
                alert("Lỗi khi lưu dữ liệu!");
            }
        });
    });


</script>