    function Find_ReplaceALL(string, target, replacement) {
        if (string != "") {
            var i = 0, length = string.length;
            for (i; i < length; i++) {
                string = string.replace(target, replacement);
            }
        }
        return string;
    }

    // function stringToDate(_date, _format, _delimiter) {
    //     var formatLowerCase = _format.toLowerCase();
    //     var formatItems = formatLowerCase.split(_delimiter);
    //     var dateItems = _date.split(_delimiter);
    //     var monthIndex = formatItems.indexOf("mm");
    //     var dayIndex = formatItems.indexOf("dd");
    //     var yearIndex = formatItems.indexOf("yyyy");
    //     var month = parseInt(dateItems[monthIndex]);
    //     month -= 1;
    //     var formatedDate = new Date(dateItems[yearIndex], month, dateItems[dayIndex]);
    //     return formatedDate;
    // }
        function stringToDate(_date, _format, _delimiter) {
        if (typeof _date !== 'string' || typeof _format !== 'string' || typeof _delimiter !== 'string') {
            console.error("stringToDate: Tham số không hợp lệ", { _date, _format, _delimiter });
            return null;
        }

        var formatLowerCase = _format.toLowerCase();
        var formatItems = formatLowerCase.split(_delimiter);
        var dateItems = _date.split(_delimiter);

        if (formatItems.length !== dateItems.length) {
            console.error("stringToDate: Định dạng không khớp với dữ liệu ngày", { _date, _format });
            return null;
        }

        var monthIndex = formatItems.indexOf("mm");
        var dayIndex = formatItems.indexOf("dd");
        var yearIndex = formatItems.indexOf("yyyy");

        if (monthIndex === -1 || dayIndex === -1 || yearIndex === -1) {
            console.error("stringToDate: Format không chứa dd/mm/yyyy đầy đủ");
            return null;
        }

        var month = parseInt(dateItems[monthIndex], 10) - 1; // tháng trong JS: 0-11
        var day = parseInt(dateItems[dayIndex], 10);
        var year = parseInt(dateItems[yearIndex], 10);

        if (isNaN(day) || isNaN(month) || isNaN(year)) {
            console.error("stringToDate: Dữ liệu ngày không hợp lệ");
            return null;
        }

        return new Date(year, month, day);
    }

    function onClick(e) {
