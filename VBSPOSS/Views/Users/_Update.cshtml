<script>
    $('#mydiv').hide();

    $(function () {
        $("form").kendoValidator();
    });

    function OnSuccess(response) {
        alert("Lưu dữ liệu thành công!");
        clearControls();
    }

    function OnFailure(response) {
        alert("Có lỗi khi lưu dữ liệu: " + response);
    }

    function OnComplete(response) {
    }

    function clearControls() {
    }

    $(function () {
        $("#form0").submit(function (event) {
            event.preventDefault();
            $('#mydiv').show();
            var dataString;
            var action = this.action;
            var contentType;
            var processData;
            if (this.enctype == "multipart/form-data") {
                dataString = new FormData($(this).get(0));
                contentType = false;
                processData = false;
            } else {
                //
            }

            $.ajax({
                url: this.action,   
                type: this.method,
                //data: $(this).serialize(),
                dataType: "json", //change to your own, else read my note above on enabling the JsonValueProviderFactory in MVC
                contentType: contentType,
                processData: processData,
                data: dataString,
                success: function (result) {
                    $('#mydiv').hide();
                    if (result == "0") {
                        alert("Bạn đã cập nhật thành công Người dùng " + $("#FullName").val() + " [" + $("#UserName").val() + "]!");
                        clearControls();
                        dataChange = true;
                        onExit();
                    }
                    else {
                        if (result == "1")
                            alert("Tên đăng nhập người dùng  [" + $("#UserName").val() + "] đã tồn tại. Vui lòng kiểm tra lại!");
                        else if (result == "2")
                            alert("Ngày sinh lớn hơn hoặc bằng ngày hiện tại.Vui lòng kiểm tra lại!");
                        else if (result == "3")
                            alert("Ngày sinh lớn hơn hoặc bằng ngày ngày cấp CMND/Thẻ căn cước. Vui lòng kiểm tra lại!");
                        else if (result == "4")
                            alert("Số  CMND/Thẻ căn cước  [" + $("#IdCode").val() + "] đã tồn tại. Vui lòng kiểm tra lại!");
                        else if (result == "5")
                            alert("Id của người dùng được thêm mới != 0, Bạn hãy kiểm tra lại");
                        else
                            alert("Có lỗi xảy ra, bạn hãy kiểm tra lại!");
                        dataChange = false;
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    $('#mydiv').hide();
                    alert("Lỗi khi cập nhật dữ liệu người dùng. Vui lòng liên hệ quản trị hệ thống!");
                }
            });
            return false;
        });
    });


