    function LoadDsCanBo_ThanhVien(e) {
        var kcbStaff = $("#StaffId").data("kendoComboBox");
        if (kcbStaff != null) {
            var _staffCode = $("#StaffId").val(); // Lấy ID của thành viên =>Load thông tin ra theo ID này
            if (_staffCode != null && _staffCode != "" && _staffCode != "0") {
                $.ajax({
                    type: "GET",
                    data: {
                        staffId: _staffCode
                    },
                    url: "@Url.Action("GetStaffById", "RoleManagement")",
                    success: function (data) {
                        if (data != null) {
                            $("#UserName").val("");
                            $("#FullName").val(data.StaffName);
                            $("#Sex").data('kendoDropDownList').value(data.Sex);

                            var birthdayDatePicker = $("#UserBirthday").data("kendoDatePicker");
                            // Gán giá trị mới (chuỗi hoặc Date object)
                            // alert('data.Birthday' + data.Birthday);
                             birthdayDatePicker.value(new Date(data.Birthday));
                            // Nếu muốn reformat ngay lập tức
                            birthdayDatePicker.trigger("change");

                            $("#PosCode").data('kendoComboBox').value(data.PosCode);
                            Change_DonVi();
                            $("#DepartmentCode").data('kendoComboBox').value(data.DepartmentCode);
                            $("#TitleCode").data('kendoComboBox').value(data.TitleCode);
                            $("#DegreeCode").data('kendoComboBox').value(data.DegreeCode);
                            $("#IdCode").val(data.IdCode);

                            //$("#IssuedDate").val(data.IssuedDate);
                            var issuedDatePicker = $("#IssuedDate").data("kendoDatePicker");
                            // Gán giá trị mới (chuỗi hoặc Date object)
                            issuedDatePicker.value(new Date(data.IssuedDate));
                            // Nếu muốn reformat ngay lập tức
                            issuedDatePicker.trigger("change");

                            $("#IssuedPlace").val(data.IssuedPlace);
                            $("#Mobile").val(data.Mobile);
                            $("#Email").val(data.Email);
                            //$("#StaffId").val(data.StaffId);
                        }
                    }
                });
            }
        }
    }
</script>

