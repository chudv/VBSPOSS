@model VBSPOSS.Models.UserModel

<style>
    #mydiv {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1000;
        background-color: grey;
        opacity: .8;
    }

    .ajax-loader {
        position: absolute;
        left: 50%;
        top: 50%;
        margin-left: -32px;
        margin-top: -32px;
        display: block;
    }

    .view_form.row {
        width: 100% !important;
        margin-left: 0;
        margin-right: 0;
    }

    .k-dropdown .k-dropdown-wrap {
        height: 21px;
    }
</style>

@* <script src="@Url.Content("~/js/utility.js")"></script> *@

<script>
    function findReplaceALL(string, target, replacement) {
        if (string != "") {
            var i = 0, length = string.length;
            for (i; i < length; i++) {
                string = string.replace(target, replacement);
            }
        }
        return string;
    }
    function stringToDate(_date, _format, _delimiter) {
        var formatLowerCase = _format.toLowerCase();
        var formatItems = formatLowerCase.split(_delimiter);
        var dateItems = _date.split(_delimiter);
        var monthIndex = formatItems.indexOf("mm");
        var dayIndex = formatItems.indexOf("dd");
        var yearIndex = formatItems.indexOf("yyyy");
        var month = parseInt(dateItems[monthIndex]);
        month -= 1;
        var formatedDate = new Date(dateItems[yearIndex], month, dateItems[dayIndex]);
        return formatedDate;
    }

    function paramRole() {
        return { grantType: 0, pTitleChoice: "--- Chọn nhóm người dùng ---" };
    }
        
    function paramPosCodeLoadIUpd() {
        return { pFlagCondi: "5", pStatus: "O", pShortName: "1", pTitleChoice: "--- Chọn đơn vị ---", pFlagShow: "1" };
    }

    function paramStaffByPosCode() {
        return {
            pPosCode: $("#PosCode_Choice_Search").val() || "",
            pTitleChoice: "--- Chọn danh sách cán bộ ---",
            pFlagTextShow: "2",
            pFlagCall: "1"
        };
    }

    // ====================== GLOBAL FLAGS ======================
    var isSubmitting = false;
    var isLoadingStaff = false;
    var lastSelectedStaffId = "";

    // Hàm tải danh sách cán bộ theo PosCode được chọn
    function LoadListStaffByPosCode() {
        var objStaffIdList = $("#StaffId").data("kendoComboBox");
        if (!objStaffIdList) return;

        // Reset dữ liệu cán bộ khi đổi đơn vị
        objStaffIdList.value("");
        objStaffIdList.text("");
        lastSelectedStaffId = "";

        clearControls();
        objStaffIdList.dataSource.read();
    }

    function onCloseUpdateUser() {
        mainWindow.data("kendoWindow").close();
    }

    function clearControls() {
        //$("#PosCode_Choice_Search").data('kendoComboBox').select(0);
        //LoadListStaffByPosCode();
        $("#StaffId").data('kendoComboBox').select(0);

        $("#PosCode").val("");
        $("#TitleCode").val("");
        $("#DepartmentCode").val("");
        $("#DegreeCode").val("");
        $("#Sex").val("");
        $("#BirthdayText").val("");
        $("#FullName").val("");
        var objBirthPicker = $("#UserBirthday").data("kendoDatePicker");
        if (objBirthPicker)
            objBirthPicker.value(null);
        $("#SexDesc").val("");
        $("#Mobile").val("");
        $("#Email").val("");
        $("#DegreeDesc").val("");
        $("#TitleDesc").val("");
        $("#DepartmentDesc").val("");
        $("#PosName").val("");
        $("#IdCode").val("");

        var objIssuedDate = $("#IssuedDate").data("kendoDatePicker");
        if (objIssuedDate)
            objIssuedDate.value(null);
        $("#IssuedPlace").val("");
        $("#UserName").val("");
        $("#Password").val("");
        $("#Status").data('kendoDropDownList').select(0);
        $("#DefaultRole").data('kendoComboBox').select(0);
    }

    //Hàm chọn Cán bộ để tạo lập tài khoản người dùng
    function onChoiceStaffId(e) {
        var objComboChoiceStaffId = this;
        var dataItem = objComboChoiceStaffId.dataItem(e.item.index());

        if (!dataItem) return;

        var staffId = dataItem.id || dataItem.StaffId || "";
        if (!staffId) return;

        if (staffId === lastSelectedStaffId) return;

        lastSelectedStaffId = staffId;
        $("#StaffId").val(staffId);

        LoadStaff_InforByStaffId(staffId);
    }
    
    function LoadStaff_InforByStaffId(staffId) {
        if (!staffId || staffId === "0" || isLoadingStaff) {
            return;
        }
        isLoadingStaff = true;
        $("#mydiv").show();

        $.ajax({
            type: "GET",
            url: "@Url.Action("GetListStaffVBSPByStaffId", "ListOfValue")",
            data: { pStaffId: staffId },
            success: function (response) {
                if (!response || response.length === 0) {
                    alert("Không tìm thấy thông tin cán bộ có IdCanBo " + staffId + ". Vui lòng kiểm tra lại!");
                    clearControls();
                    return;
                }
                var data = Array.isArray(response) ? response[0] : response;
                if (!data) {
                    alert("Không tìm thấy thông tin cán bộ. Vui lòng kiểm tra lại!");
                    clearControls();
                    return;
                }
                $("#StaffId").val(data.StaffId || data.StaffCode || "");
                $("#PosCode").val(data.PosCode);
                $("#TitleCode").val(data.StaffPositionCode);
                $("#DepartmentCode").val(data.StaffDepartmentCode);
                $("#DegreeCode").val(data.DegreeCode);
                $("#Sex").val(data.GenderCode);
                $("#SexDesc").val(data.GenderText);
                $("#FullName").val(data.StaffName);

                var objUserBirthday = $("#UserBirthday").data("kendoDatePicker");
                if (objUserBirthday) {
                    var dBirthDate = data.DateOfBirth || data.UserBirthday;
                    objUserBirthday.value(dBirthDate ? new Date(dBirthDate) : null);
                }
                $("#BirthdayText").val(data.DateOfBirthText);
                $("#Mobile").val(data.StaffMobileNo);
                $("#Email").val(data.StaffEmail);
                $("#TitleDesc").val(data.StaffPositionName);
                $("#DegreeDesc").val(data.DegreeDesc);
                $("#DepartmentDesc").val(data.StaffDepartmentName);
                $("#PosName").val(data.StaffPosName);
                $("#IdCode").val(data.IdNo);
                $("#IssuedPlace").val(data.IssuedPlace);
                $("#IssuedDateText").val(data.IssuedDateText);
                var objIssuedDate = $("#IssuedDate").data("kendoDatePicker");
                if (objIssuedDate) {
                    objIssuedDate.value(data.IssuedDate ? new Date(data.IssuedDate) : null);
                }
            },
            error: function (xhr, status, error) {
                console.error("Lỗi khi gọi API GetListStaffVBSPByStaffId:", xhr.responseText || error);
                alert("Lỗi khi lấy thông tin cán bộ!");
            },
            complete: function () {
                isLoadingStaff = false;
                $("#mydiv").hide();
            }
        });
    }

    //Kiểm tra dữ liệu hợp lệ trước khi cập nhật thông tin tài khoản người dùng
    function onSaveData(e) {
        var lcUserName = $("#UserName").val()?.trim();
        var lcPassword = $("#Password").val()?.trim();
        var lcFullName = $("#FullName").val()?.trim();
        var lcDefaultRole = $("#DefaultRole").data("kendoComboBox")?.value() || $("#DefaultRole").val();
        var lcMobile = findReplaceALL(findReplaceALL($("#Mobile").val(), " ", ""), "_", "");
        var lcIdCode = findReplaceALL(findReplaceALL($("#IdCode").val(), " ", ""), "_", "");
        var lcUserBirthday = $("#UserBirthday").val();
        var lcIssuedDate = $("#IssuedDate").val();
        var dUserBirthday = stringToDate(lcUserBirthday, "dd/MM/yyyy", "/");
        var dIssuedDate = stringToDate(lcIssuedDate, "dd/MM/yyyy", "/");

        if (lcUserName == null || lcUserName == "") {
            alert("Tên đăng nhập không được để trống. Vui lòng kiểm tra lại!");
            $("#UserName").focus();
            if (e) e.preventDefault();
            return false;
        }

        if ((parseInt($("#Id").val() || 0) === 0) && (lcPassword==null || lcPassword === "")) {
            alert("Mật khẩu không được để trống khi thêm mới tài khoản người dùng. Vui lòng kiểm tra lại!");
            $("#Password").focus();
            if (e) e.preventDefault();
            return false;
        }

        if (lcFullName == null || lcFullName == "") {
            alert("Họ và tên không được để trống. Vui lòng kiểm tra lại!");
            $("#FullName").focus();
            if (e) e.preventDefault();
            return false;
        }
        if (lcMobile == null || lcMobile == "" || lcMobile.length < 9) {
            alert('Số điện thoại không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#Mobile').focus();
            e.preventDefault();
            return false;
        }
        if (lcIdCode == null || lcIdCode == "" || lcIdCode.length < 9) {
            alert('Số thẻ căn cước không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#IdCode').focus();
            e.preventDefault();
            return false;
        }
        if (dUserBirthday > dIssuedDate) {
            alert('Ngày cấp thẻ căn cước ' + lcIssuedDate + ' không thể nhỏ hơn ngày sinh ' + lcUserBirthday + '. Vui lòng kiểm tra lại!');
            $("#IssuedDate").focus();
            e.preventDefault();
            return false;
        }
        if (lcDefaultRole == null || lcDefaultRole == "") {
            alert("Nhóm quyền không được để trống. Vui lòng kiểm tra lại!");
            $("#DefaultRole").focus();
            if (e) e.preventDefault();
            return false;
        }
        return true;
    }

    // ====================== INIT ==================================================================
    $(document).ready(function () {
        $("#mydiv").hide();

        var isEdit = parseInt($("#IsEdit").val() || 0);

        if (isEdit === 1) {
            $("#UserName").attr("readonly", true);
            $("#Password").attr("readonly", true);

            $('#Password').hide();
            $("#lbl_password").hide();

            $("#PosCode_Choice_Search").data("kendoComboBox").enable(false);
            $("#StaffId").data("kendoComboBox").enable(false);
        }
        else {
            clearControls();
            $("#PosCode_Choice_Search").data('kendoComboBox').select(0);
            LoadListStaffByPosCode();          
            
            $('#Password').show();
            $("#lbl_password").show();
            $("#PosCode_Choice_Search").data("kendoComboBox").enable(true);
            $("#StaffId").data("kendoComboBox").enable(true);
        }
        //Khi submit cập nhật thông tin Thêm/Sửa
        $("#form0").on("submit", function (event) {
            event.preventDefault();

            if (isSubmitting) return false;
            if (!onSaveData(event)) return false;

            var validator = $(this).data("kendoValidator");
            if (validator && !validator.validate()) {
                return false;
            }

            isSubmitting = true;
            $("#mydiv").show();

            var form = this;
            var formData = new FormData(form);
            var iFlagCall = parseInt($("#IsEdit").val() || 0);
            // Lấy giá trị chuẩn từ Kendo controls / hidden fields
            formData.set("Id", $("#Id").val() || "0");
            formData.set("IsEdit", $("#IsEdit").val() || "0");
            formData.set("UserName", $("#UserName").val() || "");
            formData.set("Password", $("#Password").val() || "");
            
            formData.set("StaffId", $("#StaffId").val() || "");
            formData.set("PosCode", $("#PosCode").val() || "");
            formData.set("PosName", $("#PosName").val() || "");
            formData.set("TitleCode", $("#TitleCode").val() || "");
            formData.set("TitleDesc", $("#TitleDesc").val() || "");
            formData.set("Sex", $("#Sex").val() || "");
            formData.set("SexDesc", $("#SexDesc").val() || "");
            formData.set("DepartmentCode", $("#DepartmentCode").val() || "");
            formData.set("DepartmentDesc", $("#DepartmentDesc").val() || "");
            formData.set("DegreeCode", $("#DegreeCode").val() || "");
            formData.set("DegreeDesc", $("#DegreeDesc").val() || "");

            formData.set("BirthdayText", $("#BirthdayText").val() || "");
            formData.set("FullName", $("#FullName").val() || "");
            
            formData.set("Mobile", $("#Mobile").val() || "");
            formData.set("Email", $("#Email").val() || "");

            formData.set("IdCode", $("#IdCode").val() || "");
            formData.set("IssuedPlace", $("#IssuedPlace").val() || "");
            
            var objDefaultRole = $("#DefaultRole").data("kendoComboBox");
            formData.set("DefaultRole", objDefaultRole ? objDefaultRole.value() : ($("#DefaultRole").val() || ""));
            var objStatus = $("#Status").data("kendoDropDownList");
            formData.set("Status", objStatus ? objStatus.value() : ($("#Status").val() || ""));
            
            formData.set("RoleName",objDefaultRole.text());
            formData.set("IssuedDateText", $("#IssuedDateText").val() || "");

            var objUserBirthday = $("#UserBirthday").data("kendoDatePicker");
            formData.set("UserBirthday", objUserBirthday && objUserBirthday.value() ? kendo.toString(objUserBirthday.value(), "yyyy-MM-dd") : "");

            var issuedDate = $("#IssuedDate").data("kendoDatePicker");
            formData.set("IssuedDate", issuedDate && issuedDate.value() ? kendo.toString(issuedDate.value(), "yyyy-MM-dd") : "");
            $.ajax({
                url: form.action,
                type: form.method || "POST",
                data: formData,
                contentType: false,
                processData: false,
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (result) {
                    if (result == "0") {
                        if(iFlagCall==1)
                            alert("Cập nhật thành công thay đổi thông tin tài khoản ["  + $("#UserName").val() + "] của [" + $("#FullName").val() + "]!");
                        else alert("Cập nhật thành công thêm mới tài khoản ["  + $("#UserName").val() + "] của [" + $("#FullName").val() + "]!");
                        dataChange = true;
                        onCloseUpdateUser();
                    } 
                    else if (result == "1") {
                        alert("Tên đăng nhập ["  + $("#UserName").val() + "] đã tồn tại. Vui lòng kiểm tra lại!");
                    } 
                    else if (result == "2") {
                        alert("Ngày sinh của người dùng ["  + $("#BirthdayText").val() + "] lớn hơn ngày hiện tại. Vui lòng kiểm tra lại!");
                    }
                     else if (result == "3") {
                        alert("Ngày sinh lớn hơn hoặc bằng ngày cấp CMND/Thẻ căn cước. Vui lòng kiểm tra lại!");
                     }
                      else if (result == "4") {
                        alert("Số căn cước [" + $("#SoCMT").val() + "] của người dùng đã tồn tại. Vui lòng kiểm tra lại!");
                     }
                     else if (result == "5") {
                        alert("Id của người dùng được thêm mới != 0, bạn hãy kiểm tra lại!");
                     }
                        else if (result == "6") {
                     alert("Có lỗi xảy ra, bạn hãy kiểm tra lại!");
                     }
                     else if (result == "7") {
                     alert("Đơn vị của người dùng không được để trống. Vui lòng kiểm tra lại!");
                      }
                        else if (result == "8") {
                    alert("Phòng ban của người dùng không được để trống. Vui lòng kiểm tra lại!");
                        }
                     else if (result == "9") {
                     alert("Chức vụ của người dùng không được để trống. Vui lòng kiểm tra lại!");
                         }
                    else if (result == "10") {
                       alert("Trình độ chuyên môn của người dùng không được để trống. Vui lòng kiểm tra lại!");
                     }
                    else if (result == "11") {
                     alert("Mật khẩu người dùng phải có ký tự chữ hoa, chữ thường, ký tự số và ký tự đặc biệt. Vui lòng kiểm tra lại!");
                        }
                    else if (result == "12") {
                        alert("Mật khẩu người dùng tối thiểu phải 6 ký tự (trong đó có ký tự chữ hoa, chữ thường, ký tự số và ký tự đặc biệt). Vui lòng kiểm tra lại!");
                        }
                     else if (result == "13") {
                        alert("Mật khẩu người dùng phải có ít nhất một ký tự đặc biệt. Vui lòng kiểm tra lại!");
                        }
                      else if (result == "14") {
                        alert("Mật khẩu người dùng phải có ít nhất một ký tự chữ thường. Vui lòng kiểm tra lại!");
                        }
                         else if (result == "15") {
                        alert("Mật khẩu người dùng phải có ít nhất một ký tự số. Vui lòng kiểm tra lại!");
                        }
                         else if (result == "16") {
                        alert("Mật khẩu người dùng phải có ít nhất 6 ký tự khác nhau. Vui lòng kiểm tra lại!");
                         }
                         else if (result == "17") {
                        alert("Mật khẩu người dùng không chính xác. Vui lòng kiểm tra lại!");
                         }
                           else if (result == "18") {
                        alert("Người dùng đã có mật khẩu. Vui lòng kiểm tra lại!");
                        }
                    else {
                        alert("Có lỗi xảy ra: " + result);
        ///         "2" - Ngày sinh lớn hơn hoặc bằng ngày hiện tại. Vui lòng kiểm tra lại!";
        ///         "3" - Ngày sinh lớn hơn hoặc bằng ngày ngày cấp CMND/Thẻ căn cước. Vui lòng kiểm tra lại!";
        ///         "4" - Số  căn cước [" + $("#SoCMT").val() + "] của người dùng đã tồn tại. Vui lòng kiểm tra lại!";
        ///         "5" - Id của người dùng được thêm mới != 0, Bạn hãy kiểm tra lại.
        ///         "6" - Có lỗi xảy ra, bạn hãy kiểm tra lại!"
        ///         "7" - Đơn vị của người dùng không được để trống. Vui lòng kiểm tra lại!
        ///         "8" - Phòng ban của người dùng không được để trống. Vui lòng kiểm tra lại!
        ///         "9" - Chức vụ của người dùng không được để trống. Vui lòng kiểm tra lại!
        ///         "10" - Trình độ chuyên môn của người dùng không được để trống. Vui lòng kiểm tra lại!
        ///         "11" - Mật khẩu người dùng phải có ký tự chữ hoa, chữ thường, ký tự số và ký tự đặc biệt. Vui lòng kiểm tra lại!
        ///         "12" - Mật khẩu người dùng tối thiểu phải 6 ký tự (trong đó có ký tự chữ hoa, chữ thường, ký tự số và ký tự đặc biệt). Vui lòng kiểm tra lại!
        ///         "13" - Mật khẩu người dùng phải có ít nhất một ký tự đặc biệt. Vui lòng kiểm tra lại!
        ///         "14" - Mật khẩu người dùng phải có ít nhất một ký tự chữ thường. Vui lòng kiểm tra lại!
        ///         "15" - Mật khẩu người dùng phải có ít nhất một ký tự số. Vui lòng kiểm tra lại!
        ///         "16" - Mật khẩu người dùng phải có ít nhất 6 ký tự khác nhau. Vui lòng kiểm tra lại!
        ///         "17" - Mật khẩu người dùng không chính xác. Vui lòng kiểm tra lại!
        ///         "18" - Người dùng đã có mật khẩu. Vui lòng kiểm tra lại!
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Lỗi AJAX:", xhr.responseText || error);
                    alert("Lỗi khi lưu dữ liệu! Vui lòng kiểm tra lại.");
                },
                complete: function () {
                    isSubmitting = false;
                    $("#mydiv").hide();
                }
            });

            return false;
        });
    });
</script>

<form asp-controller="Users" asp-action="CreateUser" method="post" id="form0" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id, new { Value = Model?.Id ?? 0 })
    @Html.Hidden("IsEdit", TempData["IsEdit"])
    @Html.HiddenFor(m => m.PosCode)
    @Html.HiddenFor(m => m.TitleCode)
    @Html.HiddenFor(m => m.Sex)
    @Html.HiddenFor(m => m.DepartmentCode)
    @Html.HiddenFor(m => m.DegreeCode)
    @Html.HiddenFor(m => m.BirthdayText)
    @Html.HiddenFor(m => m.IssuedDateText)
    <br />
    <p style="font-weight: bold; color: blueviolet; padding-top: 7px;padding-bottom: 0px;">CẬP NHẬT (THÊM MỚI/THAY ĐỔI THÔNG TIN) THÔNG TIN TÀI KHOẢN NGƯỜI DÙNG</p>
    <hr style='margin-top: 0em; margin-bottom: 0.4em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />

    <div style="color: navy; padding-top: 7px;" class="row">
        <div class="col-md-12" style="vertical-align: bottom; color: navy;">
            <label class="lbcontrol" style="width: 350px;color: navy;text-align:left;padding-top: 6px;">Kế thừa thông tin đã có từ danh sách cán bộ QLNS</label>
            @(Html.Kendo().ComboBox()
                .Name("PosCode_Choice_Search")
                .Filter(FilterType.Contains)
                .Placeholder("--- Chọn đơn vị của người dùng ---")
                .DataTextField("value")
                .DataValueField("id")
                .Events(e => e.Change("LoadListStaffByPosCode"))
                .DataSource(source => source.Read(read => read.Action("GetListBranchs", "ListOfValue").Data("paramPosCodeLoadIUpd")))
                .Suggest(true)
                .AutoBind(true)
                .HtmlAttributes(new { style = "width: 630px !important;max-width:1000px !important;color:green;" })
                .SelectedIndex(0))
        </div>
    </div>

    <div style="color: navy; padding-top: 6px;" class="row">
        <div class="col-md-12">
            <label class="lbcontrol" style="width: 190px;color: navy;text-align:left;padding-top: 6px;">Chọn cán bộ tạo tài khoản</label>
            @(Html.Kendo().ComboBoxFor(m => m.StaffId)
                .Filter(FilterType.Contains)
                .Placeholder("--- Danh sách cán bộ ---")
                .DataTextField("value")
                .DataValueField("id")
                .ClearButton(false)
                .DataSource(source => source.Read(read => read.Action("GetListStaffVBSP", "ListOfValue").Data("paramStaffByPosCode")))
                .HtmlAttributes(new { style = "width: 790px !important;max-width:1000px !important;color:green;" })
                .Events(e => e.Select("onChoiceStaffId"))
                .Suggest(true)
                .AutoBind(false))
        </div>
    </div>

    <div class="row" style="padding-top: 10px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label id="lbl_hoten" class="control-label" style="width: 110px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Họ và tên (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.FullName).HtmlAttributes(new { @readonly = "readonly", style = "width: 250px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width: 115px;color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Ngày sinh (<font color="red">*</font>)</label>
            @Html.Kendo().DatePickerFor(m => m.UserBirthday).Format("dd/MM/yyyy").HtmlAttributes(new { @readonly = "readonly", style = "width: 100px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:105px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Giới tính (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.SexDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 60px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:125px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Điện thoại (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.Mobile).HtmlAttributes(new { @readonly = "readonly", style = "width: 110px; !important;max-width:100% !important;color:blueviolet;" })
        </div>
    </div>


    <div class="row" style="padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label id="lbl_email" class="control-label" style="width: 110px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Email (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.Email).HtmlAttributes(new { @readonly = "readonly", style = "width: 560px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:105px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Trình độ</label>
            @Html.Kendo().TextBoxFor(m => m.DegreeDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 200px; !important;max-width:100% !important;color:blueviolet;" })
        </div>
    </div>

    <div class="row" style="padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label id="lbl_titlecode" class="control-label" style="width: 110px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Chức vụ (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.TitleDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 180px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width: 115px;color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Phòng ban (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.DepartmentDesc).HtmlAttributes(new { @readonly = "readonly", style = "width: 250px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:90px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Đơn vị (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.PosName).HtmlAttributes(new { @readonly = "readonly", style = "width: 230px; !important;max-width:100% !important;color:blueviolet;" })
        </div>
    </div>

    <div class="row" style="padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label id="lbl_IdCode" class="control-label" style="width: 110px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Số căn cước (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.IdCode).HtmlAttributes(new { @readonly = "readonly", style = "width: 180px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width: 115px;color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Ngày cấp</label>
            @Html.Kendo().DatePickerFor(m => m.IssuedDate).Format("dd/MM/yyyy").HtmlAttributes(new { @readonly = "readonly", style = "width: 100px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:85px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Nơi cấp</label>
            @Html.Kendo().TextBoxFor(m => m.IssuedPlace).HtmlAttributes(new { @readonly = "readonly", style = "width: 120px; !important;max-width:100% !important;color:blueviolet;" })
            <label style="width:105px; color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Ngày hết hạn</label>
            @Html.Kendo().DatePickerFor(m => m.IdExpDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 100px; !important;max-width: 100% !important;color:blue;" })
            
        </div>
    </div>

    <div class="row" style="padding-top: 20px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label id="lbl_username" class="control-label" style="width: 160px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Tên đăng nhập (<font color="red">*</font>)</label>
            @Html.Kendo().TextBoxFor(m => m.UserName).HtmlAttributes(new { style = "width: 200px; !important;max-width:100% !important;color:blue;" })
            <label id="lbl_password" class="control-label" style="width: 120px;color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Mật khẩu (<font color="red">*</font>)</label>
            @Html.PasswordFor(m => m.Password, new { @class = "k-textbox", placeholder = "Mật khẩu người dùng", style = "width: 200px; !important;max-width:100% !important;color:blue;" })

        </div>
    </div>

    <div class="row" style="padding-top: 5px; padding-left: 10px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label class="control-label" style="width: 160px; text-align: left; color: navy; padding-right: 3px; padding-top: 7px;">Nhóm người dùng (<font color="red">*</font>)</label>
            @(Html.Kendo().ComboBoxFor(m => m.DefaultRole)
                .Filter(FilterType.Contains)
                .Placeholder("Nhóm quyền")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetRoles", "RoleManagement").Data("paramRole");
                    }).ServerFiltering(false);
                })
                .HtmlAttributes(new { style = "width: 420px !important;max-width:1000px !important;color:blue;" })
                .Suggest(true)
                .AutoBind(true))

            <label class="control-label" style="width: 120px;color: navy;text-align:right;padding-top: 7px;padding-right: 10px!important;">Trạng thái (<font color="red">*</font>)</label>
            @(Html.Kendo().DropDownList()
                .Name("Status")
                .DataTextField("Text")
                .DataValueField("Value")
                .BindTo(new List<SelectListItem>() { new SelectListItem() { Text = "Mở", Value = "1" }, new SelectListItem() { Text = "Đóng", Value = "0" } })
                .SelectedIndex(0)
                .HtmlAttributes(new { style = "width: 200px;!important;max-width: 100% !important;color: blue; height: 23px;" }))
        </div>
    </div>

    <hr style="margin-top: 1em; margin-bottom: 0.2em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc);" />
    <div class="row" style="padding-top:10px;padding-right:20px;">
        <div class="col-md-12 text-right">
            <label class="control-label" style="width: 780px; text-align: left; color: red; padding-top: 3px;font-weight:inherit;" id="lbl_messageInfo">Lưu ý: Các thông tin cán bộ để thêm mới/thay đổi thông tin đều được lấy từ phần mềm QLNS</label>
            @(Html.Kendo().Button()
                .Name("btnSaveUpdateUser")
                .HtmlAttributes(new
                {
                    type = "submit",
                    style = "font-weight:bold; width:90px; color: blue;padding-left: 0px; height: 25px;",
                    title = "Lưu thông tin người dùng được thêm mới/sửa đổi"
                }).ImageUrl(Url.Content("~/images/save.png")).Content(" Lưu lại"))
            &nbsp;
            @(Html.Kendo().Button()
                .Name("btnExit")
                .Events(ev => ev.Click("onCloseUpdateUser"))
                .HtmlAttributes(new
                {
                    type = "button",
                    style = "font-weight:bold; width:90px; color: blue;padding-left: 0px; height: 25px;",
                    title = "Đóng lại cập nhật"
                }).ImageUrl(Url.Content("~/images/close_icon.gif")).Content(" Quay ra"))
        </div>
    </div>

    <div id="mydiv">
        <img style="height:80px;" src="~/images/loading.gif" class="ajax-loader" />
    </div>
</form>