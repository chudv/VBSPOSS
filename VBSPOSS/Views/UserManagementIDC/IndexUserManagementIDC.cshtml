<hr style='margin-top: 0.1em; margin-bottom: 0.1em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />

<div style="flex-grow: 1; display: flex; flex-direction: column; ">
    <div class="row" style="color: navy; padding-top: 0px;padding-bottom: 0px;">

        <div class="col-md-12">
            <label class="lbcontrol" style="color: navy;text-align:left;width:60px;padding-top:3px;padding-right:0px;padding-left:5px;font-family:Tahoma;font-size:12px;">Đơn vị</label>
            @(Html.Kendo().ComboBox().Name("MainPosCode_Find")
                .Filter(FilterType.Contains)
                .Placeholder("--- Đơn vị ---")
                .DataTextField("value")
                .DataValueField("id")
                .ClearButton(false)
                .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramLoadListBranchFind"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 200px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0))
            <label class="lbcontrol" style="color: navy;text-align:center;width:85px;padding-top: 7px;">Nghiệp vụ</label>
            @(Html.Kendo().ComboBox().Name("FunctionType_Find")
                .Filter(FilterType.Contains)
                .DataTextField("Description")
                .DataValueField("Code")
                .BindTo((List<ValueConstModel>)ViewBag.FunctionTypes)
                .Placeholder("Chọn nghiệp vụ yêu cầu")
                .HtmlAttributes(new { style = "width: 300px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                .Filter("contains")
                .SelectedIndex(0))
            <label class="lbcontrol" style="color: navy;text-align:right;width:90px;padding-top:7px;padding-right:6px;">Tài khoản</label>
            @(Html.Kendo().TextBox().Name("NickName_Find")
                .Placeholder("Tài khoản")
                .HtmlAttributes(new { style = "width: 65px;padding-left: 2px;padding-right: 0px;" }))
            @(Html.Kendo().TextBox().Name("StaffName_Find")
                .Placeholder("Họ tên người dùng")
                .HtmlAttributes(new { style = "width: 130px;padding-left: 3px;padding-right: 2px;" }))
            <label class="lbcontrol" style="width: 85px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:3px;padding-top:7px; ">Trạng thái</label>
            @(Html.Kendo().ComboBox().Name("Status_Find")
                .Filter(FilterType.Contains)
                .DataTextField("Description")
                .DataValueField("Value")
                .BindTo((List<ValueConstModel>)ViewBag.StatusFlowUserIDC)
                .Placeholder("Chọn trạng thái")
                .HtmlAttributes(new { style = "width: 210px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                .Filter("contains")
                .SelectedIndex(0))

            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                .Name("btnSearchUserManagementIDC")
                .Events(ev => ev.Click("onSearchUserManagementIDC"))
                .HtmlAttributes(new { type = "button", style = "font-weight:bold; width:100px; color: blue;padding-left: 0px; height: 25px;", title = "Tìm kiếm yêu cầu về tài khoản người dùng Intellect iDC" })
                .ImageUrl(Url.Content("~/images/tim_kiem.png"))
                .Content(" Tìm kiếm "))
        </div>
    </div>


    <div style="color: navy; padding-top: 0px; display:flex;" class="row">
        <div class="col-md-12">
            @(Html.Kendo().Grid<VBSPOSS.ViewModels.UserManagementIDCViewModel>()
                .Name("gridMainIDC")
                .Events(e => e.DataBound("onRowBoundUserManagementIDC"))
                .Columns(columns =>
                {
                    columns.Command(command =>
                    {
                        command.Custom("ViewEdit").Text("<span style='color: blue;'></span>").Click("showEditUserManagementIDC").HtmlAttributes(new
                        {
                            @class = "btn-view-edit",
                            style = "width: 20px !important; display: inline-block; vertical-align: middle;padding: 0 2px !important;",
                            title = "Chỉnh sửa thông tin bản ghi"
                        });
                        command.Custom("Delete").Text("<span style='color: blue;'></span>").Click("deleteItemUserManagementIDC").HtmlAttributes(new
                        {
                            style = "width: 20px !important; display: inline-block; vertical-align: middle;padding: 0 2px !important;",
                            title = "Đánh dấu xóa bản ghi",
                            @class = "btn-delete"
                        });
                        command.Custom("View").Text("<span style='color: blue;'></span>").Click("showDetailUserIDC").HtmlAttributes(new
                        {
                            style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                            title = "Xem chi tiết thông tin bản ghi",
                            @class = "btn-view"
                        });
                    }).Width(100).Title("Sửa/Xóa").HtmlAttributes(new { style = "text-align: center;" });

                    columns.Command(command =>
                    {
                        command.Custom("EditIDC").Text("<span style='color: blue;'></span>").Click("showEditIDC").HtmlAttributes(new
                        {
                            style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                            title = "Yêu cầu nghiệp vụ thay đổi thông tin tài khoản người dùng Intellect iDC",
                            @class = "btn-EditIDC"
                        });
                    }).Width(80).Title("Nghiệp vụ thay đổi").HtmlAttributes(new { style = "text-align: center;text-wrap: auto;" });

                    columns.Bound(c => c.OrderNo).Title("STT").Width(50).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.FunctionTypeName).Title("Nghiệp vụ").Width(120).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.PosName).Title("Đơn vị").HtmlAttributes(new { style = "text-align: left;" });
                    columns.Bound(c => c.UserId).Title("Tài khoản").Width(75).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.FullName).Title("Họ tên").Width(150).HtmlAttributes(new { style = "text-align: left;" });
                    columns.Bound(c => c.DateOfBirth).Title("Ngày sinh").Format("{0:dd/MM/yyyy}").Width(81).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.MobileNumber).Title("Số điện thoại").Width(90).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.GroupNameText).Title("Nhóm quyền").Width(100).HtmlAttributes(new { style = "text-align: left;" });
                    columns.Bound(c => c.RoleToTransferCashName).Title("Q. TM").Width(45).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.GroupName).Hidden();
                    columns.Bound(c => c.EffectiveDate).Title("Ngày hiệu lực").Format("{0:dd/MM/yyyy}").Width(83).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.ExpiryDate).Title("Ngày hết hiệu lực").Format("{0:dd/MM/yyyy}").Width(83).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.StatusText).Title("Trạng thái").Width(130).HtmlAttributes(new { style = "text-align: left;" });
                    columns.Bound(c => c.CreatedDate).Title("Ngày tạo yêu cầu").Format("{0:dd/MM/yyyy}").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                    columns.Bound(c => c.Id).Hidden();
                    columns.Bound(c => c.PosCode).Hidden();
                    columns.Bound(c => c.StaffId).Hidden(); ;
                    columns.Bound(c => c.StaffCode).Hidden();
                    columns.Bound(c => c.NickName).Hidden();
                    columns.Bound(c => c.FirstName).Hidden();
                    columns.Bound(c => c.LastName).Hidden();
                    columns.Bound(c => c.EmailAddress).Hidden();
                    columns.Bound(c => c.EntityList).Hidden();
                    columns.Bound(c => c.AuthType).Hidden();
                    columns.Bound(c => c.UserType).Hidden();
                    columns.Bound(c => c.MailIdFlag).Hidden();
                    columns.Bound(c => c.AuthsecType).Hidden();
                    columns.Bound(c => c.ExtraAttributeUserRole).Hidden();
                    columns.Bound(c => c.ExtraAttributeBranchCode).Hidden();
                    columns.Bound(c => c.Remark).Hidden();
                    columns.Bound(c => c.OrtherNotes).Hidden();
                    columns.Bound(c => c.Status).Hidden();
                    columns.Bound(c => c.CreatedBy).Hidden();
                    columns.Bound(c => c.ModifiedBy).Hidden();
                    columns.Bound(c => c.ModifiedDate).Hidden();
                    columns.Bound(c => c.ApproverBy).Hidden();
                    columns.Bound(c => c.ApprovalDate).Hidden();
                    columns.Bound(c => c.FunctionType).Hidden();
                    //columns.Bound(c => c.Genders).Hidden();
                    columns.Bound(c => c.StatusText).Hidden();
                    @* columns.Bound(c => c.StaffPositionName).Hidden();
                    columns.Bound(c => c.StaffDepartmentName).Hidden();
                    columns.Bound(c => c.RoleToTransferCashDescription).Hidden();
                    columns.Bound(c => c.RoleToTransferCashValue).Hidden(); *@
                })
                .HtmlAttributes(new { style = "height: 680px;color: navy; border: 1px solid #ddd;" })
                .ToolBar(toolbar =>
                {
                    toolbar.Custom().IconClass("k-icon k-i-plus").Text("Thêm mới").Name("btnCreateUserManagementIDC").HtmlAttributes(new { id = "btnCreateUserManagementIDC", style = "height: 25px;width: 100px; font-weight:bold; color: blue;font-size: 12px;font-family: tahoma;!important;" });
                    toolbar.Excel().HtmlAttributes(new { id = "btnExportExcel", style = "height: 25px;width: 110px; font-weight:bold; color: blue;font-family:Tahoma; font-size: 12px;font-weight:bold;!important;", title = "Xuất dữ liệu trên lưới ra file excel" }).Text("Xuất excel");
                })
                .Excel(excel => excel.FileName("Danh sach nguoi dung IDC.xlsx").AllPages(true))
                .Editable(editable => { editable.Mode(GridEditMode.InLine); })
                .Sortable()
                .Scrollable()
                .Pageable(pageable => pageable.Refresh(true).ButtonCount(5))
                .DataSource(dataSource => dataSource
                .Ajax()
                .Batch(false)
                .ServerOperation(false)
                .Model(model => model.Id(p => p.Id))
                .Events(e => e.RequestEnd("onSaveGridIDC").Error("error_handlerIDC"))
                .Read(read => read.Action("LoadGridData_UserIDCManagement", "UserManagementIDC").Data("paramLoadGridData"))
                .PageSize(100)
                )
                .Resizable(resize => resize.Columns(true))
                .AutoBind(true)
                )
        </div>
    </div>
</div>


<script>
     function onSaveGridIDC(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {
                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_handlerIDC(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
            console.error("Kendo Grid Error:", e.errors);  // Debug console để xem lỗi backend (F12)
        }
    }

    $(document).ready(function () {
        $(".k-grid-excel").after("<label id='lbl_space' style='padding-top:5px;padding-left: 10px;width:70%; font-size: 11px; font-weight: bold; color: blue;text-align:center;line-height: 25px;'>DANH SÁCH TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC (LỊCH SỬ TẠO MỚI/THAY ĐỔI THÔNG TIN TÀI KHOẢN NGƯỜIU ÙNG INTELLECT IDC)</label>");
    });
</script>