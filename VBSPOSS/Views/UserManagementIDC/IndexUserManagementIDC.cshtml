<script>
    var mainWindow = $("#myPopup");
</script>

<script>
    function paramLoadListBranchFind() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }

    function paramLoadGridData() {
        return {
            pPosCode: $("#MainPosCode_Find").val(),
            pFunctionType: $("#FunctionType_Find").val(),
            pNickName: $("#NickName_Find").val(),
            pFullName: $("#StaffName_Find").val(),
            pStatus: $("#Status_Find").val()
        };
    }

    function refreshGridIDC() {
        var grid = $("#gridMainIDC").data("kendoGrid");
        if (grid != null) {
            grid.dataSource.read();
        }
    }

    function onSearchUserManagementIDC(e) {
        refreshGridIDC();
    }

    function onRowBoundUserManagementIDC(e) {
        var rows = e.sender.tbody.children();
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var statusRowValue = dataItem.get("Status");
            if (statusRowValue == 0)
                row.css({ "background-color": "#f8f9fa", "color": "red" });
            else if (statusRowValue == 4 || statusRowValue == 7)
                row.css({ "background-color": "#f8f9fa", "color": "red" });
            else if (statusRowValue != null && statusRowValue == 3) // Đã duyệt
                row.css({ "background-color": "#e8f5e9", "color": "green" });
            else if (statusRowValue == 1 || statusRowValue == 5)
                row.css({ "background-color": "white", "color": "Navy" });
        }
    }
    
    function formatDateToDDMMYYYY(date) {
        if (!date) return "";
        var d = new Date(date);
        if (isNaN(d.getTime())) return "";

        var day = d.getDate().toString().padStart(2, '0');
        var month = (d.getMonth() + 1).toString().padStart(2, '0');
        var year = d.getFullYear();

        return day + '/' + month + '/' + year;
    }
    
    var dataChange = false;

    //Sự kiện gọi Thêm mới thông tin bản ghi Yêu cầu nghiệp vụ với Tài khoản người dùng Intellect iDC
    $(document).on('click', '#btnCreateUserManagementIDC', function (e)
    {
        e.preventDefault();
        var lcEventValue = $("#EventFlag_AddView").val();
        
        
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        var today = new Date();
        var dCurrentDate = today.getDate().toString().padStart(2, '0') + '/' +
                    (today.getMonth() + 1).toString().padStart(2, '0') + '/' +
                    today.getFullYear();
        mainWindow.kendoWindow({
            width: "1024px",
            height: "700px",
            title: "Thêm mới yêu cầu nghiệp vụ tạo mới tài khoản người dùng Intellect IDC",
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pButtonType: $("#FunctionTypeFlag_ADDNEW_USERView").val(), pId: 0, pPosCode: "",pUserId: "", pEffectiveDate: dCurrentDate, pFlagCall: lcEventValue}
            },
            resizable: true,
            visible: false,
            close: onClose,
            modal: true,
            actions: ["Refresh", "Close"],
            error: function (e) {
                notification.show( { message: "Có lỗi xảy ra: " + e.xhr.statusText, type: "error"}, "error");
            mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    });

    function onClose() {
        if (dataChange == true) {
            refreshGridIDC();
            dataChange = false;
        }
    }

    function doCompleteWindow() {
        mainWindow.data("kendoWindow").close();
    }
    
    //Sự kiện gọi Đánh dấu xóa bản ghi Yêu cầu nghiệp vụ với Tài khoản người dùng Intellect iDC
    function deleteItemUserManagementIDC(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Bản ghi người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "]";
        if (dataItem.Status.toString() == "0") {
            alert(sMessInfor + " đã được đánh dấu xóa nên không thể đánh dấu xóa tiếp. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.FunctionType == "") {
            alert(sMessInfor + " chưa có yêu cầu thay đổi nghiệp vụ nào nên không thể đánh dấu xóa bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "3" || dataItem.Status.toString() == "6") {
            alert(sMessInfor + " có nghiệp vụ [" + dataItem.FunctionTypeName + "] đã được phê duyệt nên không thể đánh dấu xóa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "4" || dataItem.Status.toString() == "7") {
            alert(sMessInfor + " có nghiệp vụ [" + dataItem.FunctionTypeName + "] đã được từ chối nên không thể đánh dấu xóa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "2") {
            alert(sMessInfor + " có nghiệp vụ [" + dataItem.FunctionTypeName + "] đã được trình duyệt nên không thể đánh dấu xóa. Vui lòng kiểm tra lại!");
        }
       
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa bản ghi Yêu cầu nghiệp vụ [" + dataItem.FunctionTypeName + "] của người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "] không?");
            if (isConfirm == true) {
                $.ajax({
                    data: { pId: dataItem.Id,pUserId: dataItem.UserId, pStaffId: dataItem.StaffId, pStatus: dataItem.Status, pFunctionType: dataItem.FunctionType},
                    type: "POST",
                    url: "../UserManagementIDC/DeleteMarkUserManagementIDC",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn đã đánh dấu xóa bản ghi Yêu cầu nghiệp vụ [" + dataItem.FunctionTypeName + "] của người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "] thành công!");
                            refreshGridIDC();
                        }
                        else alert("Đánh dấu xóa bản ghi Yêu cầu nghiệp vụ [" + dataItem.FunctionTypeName + "] của người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "] thất bại!");
                    },
                    error: function () {
                        alert("Đánh dấu xóa bản ghi Yêu cầu nghiệp vụ [" + dataItem.FunctionTypeName + "] của người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "] có lỗi!");
                    }
                });
            }
            else {
                alert("Thao tác đánh dấu xóa bản ghi Yêu cầu nghiệp vụ [" + dataItem.FunctionTypeName + "] của người dùng [" + dataItem.UserId + "] - [" + dataItem.FullName + "] bị hủy bỏ!");
            }
        }
    }

    //Sự kiện gọi Chỉnh sửa thông tin bản ghi Yêu cầu nghiệp vụ với Tài khoản người dùng Intellect iDC
    function showEditUserManagementIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tài khoản của người dùng [" + dataItem.FullName + "]";
        if (dataItem.Status.toString() == "0") {
            alert(sMessInfor + " đã được đánh dấu xóa nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "2") {
            alert(sMessInfor + " đã được trình duyệt nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "3") {
            alert(sMessInfor + " đã được phê duyệt thực thi vào Intellect iDC nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "4") {
            alert(sMessInfor + " đã được từ chối nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.FunctionType == "") {
            alert(sMessInfor + " chưa có yêu cầu thay đổi nghiệp vụ nào nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "6") {
            alert(sMessInfor + " đã được phê duyệt tại cấp Chi nhánh nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "7") {
            alert(sMessInfor + " đã được từ chối tại cấp Chi nhánh nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Id <= 0) {
            alert(sMessInfor + " chưa có yêu cầu nghiệp vụ nào nên không thể chỉnh sửa thông tin bản ghi. Vui lòng kiểm tra lại!");
        }
        else
        {
            var lcEventValue = $("#EventFlag_EditView").val();
            mainWindow.kendoWindow({
                width: "1024px",
                height: "700px",
                title: "Chỉnh sửa thông tin bản ghi yêu cầu nghiệp vụ với tài khoản người dùng IDC",
                content: {
                    url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                    data: { pButtonType: dataItem.FunctionType, pId: dataItem.Id, pPosCode: dataItem.PosCode,pUserId: dataItem.UserId, pEffectiveDate: formatDateToDDMMYYYY(dataItem.EffectiveDate), pFlagCall: lcEventValue }
                },
                resizable: false,
                visible: false,
                modal: true,
                close: onClose,
                actions: ["Refresh", "Close"]
            });
            mainWindow.data("kendoWindow").wrapper.css({ height: 700, width: 1024 });
            mainWindow.data("kendoWindow").center().open().title("Chỉnh sửa thông tin bản ghi yêu cầu nghiệp vụ với tài khoản người dùng IDC");
        }
    }

    //Xem chi tiết bản ghi: Xem chi tiết bản ghi: Thêm mới/Yêu cầu nghiệp vụ thay đổi người dùng
    function showDetailUserIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        
        var lcTitleForm = "Xem chi tiết thông tin tài khoản người dùng Intellect iDC";

        if (dataItem.FunctionType != "" && dataItem.Id != 0)
            lcTitleForm = "Xem chi tiết thông tin bản ghi yêu cầu nghiệp vụ với tài khoản người dùng Intellect iDC";
        
        var lcEventValue = $("#EventFlag_ViewView").val();

        mainWindow.kendoWindow({
            width: "1024px",
            height: "700px",
            title: lcTitleForm,
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pButtonType: dataItem.FunctionType, pId: dataItem.Id, pPosCode: dataItem.PosCode,pUserId: dataItem.UserId, pEffectiveDate: formatDateToDDMMYYYY(dataItem.EffectiveDate), pFlagCall: lcEventValue }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onClose,
            actions: ["Refresh","Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    }

    //Không thấy sử dụng?
    function submitForApprovalIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Người dùng [" + dataItem.FullName + "]";
        var grid = $("#gridMainTidePanelRate").data("kendoGrid");
        // Kiểm tra trạng thái trước khi trình duyệt
        var deletedStatuses = [0, 2, 3, 4];
        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.Status == 0) {
                alert(sMessInfor + " đã được đánh dấu xóa nên không thể thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 1) {
                alert(sMessInfor + " đang ở bước tạo lập không thể thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 2) {
                alert(sMessInfor + " đã được trình duyệt nên không thể thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 4) {
                alert(sMessInfor + " đã được từ chối nên không thể thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            return;
        }
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_ApprovalTemp").val();
        mainWindow.kendoWindow({
            width: "1050px",
            height: "750px",
            title: "Trình duyệt cấu hình lãi suất rút trước hạn tiền gửi CKH",
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pPosCode: dataItem.PosCode, pUserId: dataItem.UserId, pButtonType: "10" }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onClose,
            actions: ["Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    }
    
    //Sự kiện gọi lên Form Tạo mới yêu cầu (Luôn luôn là thê mmới bản ghi Yêu cầu thay đổi thông tin):
    //          'RESET_PASSWORD' - Cấp lại mật khẩu
    //          'ENABLE_USER' - Mở lại người dùng
    //          'DISABLE_USER' - Khóa người dùng
    //          'MODIFY_USER' - Thay đổi thông tin người dùng
    //          'CHANGE_POS' - Thay đổi POS người dùng
    //          'CHANGE_ROLE' - Thay đổi quyền/vài trò người dùng
    function showEditIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        
        var sMessInfor = "Tài khoản của người dùng [" + dataItem.FullName + "]";
        // Kiểm tra trạng thái trước khi trình duyệt
        var deletedStatuses = [0, 1, 2, 4, 7, 5];

        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.Status == 0) {
                alert(sMessInfor + " đã được đánh dấu xóa, không thể tạo yêu cầu nghiệp vụ thay đổi thông tin tài khoản người dùng Intellect iDC. Vui lòng kiểm tra lại!");
                return;
            }
            // else if (dataItem.Status == 1 || dataItem.Status == 5) {
            //     alert(sMessInfor + " bản ghi có trạng thái đang tạo lập/chỉnh sửa bản ghi, không thể tạo yêu cầu nghiệp vụ thay đổi thông tin tài khoản người dùng Intellect iDC. Vui lòng kiểm tra lại!");
            // }
            // else if (dataItem.Status == 2) {
            //     alert(sMessInfor + " bản ghi có trạng thái trình duyệt, không thể tạo yêu cầu nghiệp vụ thay đổi thông tin tài khoản người dùng Intellect iDC. Vui lòng kiểm tra lại!");
            // }
            // else if (dataItem.Status == 4 || dataItem.Status == 7) {
            //     alert(sMessInfor + " bản ghi có trạng thái bị từ chối, không thể tạo yêu cầu nghiệp vụ thay đổi thông tin tài khoản người dùng Intellect iDC. Vui lòng kiểm tra lại!");
            // }
            //return;
        }
        var lcIdRowChange = dataItem.Id;
        if ((dataItem.FunctionType == "") && (dataItem.Status== 6 || dataItem.Status == 3))
            lcIdRowChange = 0;
        else lcIdRowChange = 0;
        var lcEventValue = $("#EventFlag_EditIDCView").val();
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        
        mainWindow.kendoWindow({
            width: "1024px",
            height: "700px",
            title: "Yêu cầu chỉnh sửa thông tin người dùng IDC",
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pButtonType: dataItem.FunctionType, pId: lcIdRowChange, pPosCode: dataItem.PosCode,pUserId: dataItem.UserId, pEffectiveDate: formatDateToDDMMYYYY(dataItem.EffectiveDate), pFlagCall: lcEventValue }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onClose,
            actions: ["Refresh","Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    }
</script>


