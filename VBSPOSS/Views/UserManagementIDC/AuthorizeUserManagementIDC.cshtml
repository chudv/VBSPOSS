@model VBSPOSS.ViewModels.UserManagementIDCViewModel

<div id="mySppLocality"></div>


<style>
    .k-animation-container {
        z-index: 100000 !important;
    }

    .readonly-field input,
    .readonly-field .k-input,
    .readonly-field textarea {
        background-color: #f0f0f0 !important;
        color: #28a745 !important; /* Màu xanh lá */
        cursor: not-allowed !important;
    }

    .editable-field input,
    .editable-field .k-input {
        color: navy !important;
    }

    #EffectDate, #ExpiryDate {
        width: 50px !important;
        max-width: 100% !important;
        font-family: Tahoma;
        padding-left: 2px;
        padding-right: 2px;
    }

    .hidden-block {
        display: none !important;
    }
</style>

<script>

    var isEditMode = false;


    (function() {
        var flagCallView = '@TempData["FlagCall"]';
        if (flagCallView === "2") {
            isEditMode = true;
        }
    })();

    function paramLoadListBranchFind() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }

    function paramLoadListStaffFind() {
        return {
            pPosCode: $("#PosCode").val(),
            pTitleChoice: "",
            pFlagTextShow: "2",
            pFlagCall: "2"
        };
    }

    function paramLoadListRoleOfUserIDC() {
        return {
            pPosCode: $("#UserPosCodeView").val(),
            pTitleChoice: ""
        };
    }

    function Change_PosCode() {

        if (isEditMode) return;

        var staffIdReload = $("#StaffId").data("kendoComboBox");
        if (staffIdReload != null) {
            staffIdReload.dataSource.read();
        }
    }

    var roleLists;
    function Change_RoleOfUserIDC() {
        var objGroupId = $("#GroupName").val();
        if (objGroupId != null) {
            $.ajax({
                type: "GET",
                data: {
                    pUserRole: objGroupId
                },
                url: "../ListOfValue/GetRoleToTransferCashByUserRole",
                success: function (data) {
                    roleLists = data;
                    if (roleLists != null && roleLists.length != 0) {
                        //$("#RoleToTransferCashDescription").val(roleLists[0].RoleToTransferCashDescription);
                        $("#RoleToTransferCashValue").val(roleLists[0].RoleToTransferCashValue);
                        $("#RoleToTransferCashDescriptionDetail").val(roleLists[0].RoleToTransferCashDescription);
                        $("#UserRoleNameChange").val(roleLists[0].UserRoleName);
                    }
                }
            });
        }

    }

    //Hàm dùng khi khởi động màn hình
    function Change_RoleOfUserIDCStart() {
        var objGroupId = $("#GroupNameOld").val();
        if (objGroupId != null) {
            $.ajax({
                type: "GET",
                data: {
                    pUserRole: objGroupId
                },
                url: "../ListOfValue/GetRoleToTransferCashByUserRole",
                success: function (data) {
                    roleLists = data;
                    if (roleLists != null && roleLists.length != 0) {
                        $("#RoleToTransferCashDescription").val(roleLists[0].RoleToTransferCashDescription);
                        $("#RoleToTransferCashValue").val(roleLists[0].RoleToTransferCashValue);
                        // $("#RoleToTransferCashDescriptionDetail").val(roleLists[0].RoleToTransferCashDescription);
                        $("#UserRoleName").val(roleLists[0].UserRoleName);
                        // $("#UserRoleNameChange").val(roleLists[0].UserRoleName);
                    }
                }
            });
        }

    }

    var staffLists;
    function LoadStaffInfoDetail(e) {
        var lcStaffId = $("#StaffId").val(); // Lấy ID của thành viên =>Load thông tin ra theo ID này
        if (lcStaffId != null && lcStaffId != "" && lcStaffId != "0") {
            $.ajax({
                type: "GET",
                data: {
                    pStaffId: lcStaffId
                },
                url: "../ListOfValue/GetListStaffVBSPByStaffId",
                success: function (data) {
                    staffLists = data;
                    if (staffLists != null && staffLists.length != 0) {
                        $("#StaffCode").val(staffLists[0].StaffCode);
                        $("#Genders").val(staffLists[0].GenderText);
                        $("#DateOfBirth").val(staffLists[0].DateOfBirthText);
                        $("#StaffDepartmentName").val(staffLists[0].StaffDepartmentName);
                        $("#StaffPositionName").val(staffLists[0].StaffPositionName);
                        $("#MobileNumberEdit").val($("#MobileNumber").val());
                        $("#EmailEdit").val($("#EmailAddress").val());
                        $("#StaffPosCode").val(staffLists[0].StaffPosCode);
                        $("#StaffDepartmentCode").val(staffLists[0].StaffDepartmentCode);
                        $("#StaffPositionCode").val(staffLists[0].StaffPositionCode);
                        $("#FullName").val(staffLists[0].StaffName);
                        $("#MobileNumberIDC").val(staffLists[0].StaffMobileNo);
                        $("#EmailAddressIDC").val(staffLists[0].StaffEmail);
                        $("#PosCodeNew").val($("#PosCode").val());
                        // Gọi hàm check dữ liệu bảng UserIDCMaster
                        $.ajax({
                            type: "GET",
                            url: "../UserManagementIDC/LoadGridData_UserIDCMaster",
                            data: {
                                pUserId: staffLists[0].StaffCode
                            },
                            success: function (res) {

                                if (res && res.Data && res.Data.length > 0) {
                                    $("#PosNameIDC").val(res.Data[0].PosName);
                                } else {
                                    $("#PosNameIDC").val(staffLists[0].StaffPosName);
                                }

                            }
                        });
                    }
                }
            });
        }
    }

    function onCloseUpdate(ev) {
        mainWindowApproval.data("kendoWindow").close();
    }


    function Change_Status(e) {

        if (!isEditMode) return;

        var statusDDL = $("#Status").data("kendoDropDownList");
        var statusValue = statusDDL.value();


        if (statusValue === "0") {
            var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
            if (expirePicker) {

                expirePicker.value(new Date());


                expirePicker.enable(true);
            }
        }
    }

    function onClick(e) {
        var lcPosCode = $("#PosCode").val();
        var lcStaffId = $("#StaffCode").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcStaffId == null || lcStaffId == "") {
            alert('Cán bộ được phân giao quản lý địa bàn không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#StaffCode').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
    }

    var lcButton = "";

    function onClickApproval(e) {
        lcButton = "8";
        var lcPosCode = $("#PosCode").val();
        var lcStaffId = $("#StaffCode").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcStaffId == null || lcStaffId == "") {
            alert('Cán bộ được phân giao quản lý địa bàn không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#StaffCode').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
        sendDataToParent(8);
    }

    function onClickAuthorize(e) {
        lcButton = "9";
        var lcPosCode = $("#PosCode").val();
        var lcStaffId = $("#StaffCode").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcStaffId == null || lcStaffId == "") {
            alert('Cán bộ được phân giao quản lý địa bàn không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#StaffCode').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
        sendDataToParent(9);
    }

    function onClickDenie(e) {
        lcButton = "3";
        var lcButtonType = $("#ButtonTypeView").val();
        var lcStatusReject = 0;
        if (lcButtonType == "8")
        {
            lcStatusReject = 12;
        }
        else {
            lcStatusReject = 13;
        }
        var lcPosCode = $("#PosCode").val();
        var lcRemark = $("#Remark").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcRemark == null || lcRemark == "" || lcRemark.length < 5) {
            alert('Từ chối cần phải nhập ghi chú. Bạn vui lòng kiểm tra lại!');
            $('#Remark').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
        sendDataToParent(lcStatusReject);
    }

    function sendDataToParent(status) {
        var data = {
            Id: $("#Id").val(),
            UserId: $("#UserId").val(),
            Status: status
        };
        if (window.parent && window.parent.receiveDataFromChild) {
            window.parent.receiveDataFromChild(data);
        }
        if(status == 8) {
            alert("Trình duyệt thành công");
        }

        if(status == 9) {
            alert("Phê duyệt thành công");
        }

        if(status == 12 || status == 13) {
            alert("Từ chối thành công");
        }
        onCloseUpdate();
    }


</script>

