                @Html.Kendo().TextBoxFor(m => m.PosCode).HtmlAttributes(new { @readonly = "readonly", style = " width: 80px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
                <label class="lbcontrol" style="color: navy;text-align:center;width:100px;padding-top: 7px;">Tên đơn vị</label>
                @Html.Kendo().TextBoxFor(m => m.PosName).HtmlAttributes(new { @readonly = "readonly", style = " width: 610px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
            </div>
        </div>

        <div id="divModify" class="row" style="margin-bottom: 10px;padding-top: 0px; padding-left: 0px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 150px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:7px;padding-top:3px;">Số điện thoại</label>
                @Html.Kendo().TextBoxFor(m => m.MobileNumber).HtmlAttributes(new { @readonly = "readonly", style = " width: 100px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
                <label class="lbcontrol" style="width: 80px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:7px;padding-top:3px;">Email</label>
                @Html.Kendo().TextBoxFor(m => m.EmailAddress).HtmlAttributes(new { @readonly = "readonly", style = " width: 610px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
            </div>
        </div>

        <div id="divRole" class="row" style="margin-bottom: 10px;padding-top: 0px; padding-left: 0px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 150px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:7px;padding-top:3px; ">Nhóm quyền</label>
                @Html.Kendo().TextBoxFor(m => m.GroupName).HtmlAttributes(new { @readonly = "readonly", style = " width: 100px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
                <label class="lbcontrol" style="width: 10px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:7px;padding-top:3px; "></label>
                @Html.Kendo().TextBox().Name("UserRoleNameChange").HtmlAttributes(new { @readonly = "readonly", style = " width: 350px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
                <label class="lbcontrol" style="color: navy;text-align:center;width:120px;padding-top: 7px;padding-right: 10px!important;">Quyền tiền mặt </label>
                @Html.Kendo().TextBox().Name("RoleToTransferCashDescriptionDetail").HtmlAttributes(new { @readonly = "readonly", style = " width: 210px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
            </div>
        </div>

        <div class="row" style="margin-bottom: 10px;padding-top: 0px; padding-left: 0px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 150px; vertical-align: middle;color: navy;text-align:left;">Ghi chú</label>
                @Html.TextAreaFor(m => m.Remark, new { @class = "k-textbox", style = "min-height:50px;width:790px;max-width:100%;color: blue;font-family:Tahoma !important;", rows = "2", placeholder = "Yêu cầu nhập ghi chú khi từ chối!" })
            </div>
        </div>

        <div class="row" style="padding-top: 5px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="width:100%; display:flex; justify-content:flex-end;">
                <label class="control-label" id="lblMessageInfor" style="width: 740px; text-align: left; color: red;"></label>
                &nbsp;&nbsp;
                @(Html.Kendo().Button()
                                .Name("btnApproval")
                                .Events(ev => ev.Click("onClickApproval"))
                                .HtmlAttributes(new { type = "button", style = "width: 90px; font-weight:bold; color: blue;height: 25px;", title = "Trình duyệt cấp chi nhánh người dùng IDC" })
                                .ImageUrl(Url.Content("~/images/save.png"))
                                .Content("Trình duyệt"))
                &nbsp;
                @(Html.Kendo().Button()
                                .Name("btnAuthorize")
                                .Events(ev => ev.Click("onClickAuthorize"))
                                .HtmlAttributes(new { type = "button", style = "width: 90px; font-weight:bold; color: blue;height: 25px;", title = "Trình duyệt cấp chi nhánh người dùng IDC" })
                                .ImageUrl(Url.Content("~/images/save.png"))
                                .Content("Phê duyệt"))
                &nbsp;
                @(Html.Kendo().Button()
                                .Name("btnDenie")
                                .Events(ev => ev.Click("onClickDenie"))
                                .HtmlAttributes(new { type = "button", style = "width: 90px; font-weight:bold; color: blue;height: 25px;", title = "Trình duyệt cấp chi nhánh người dùng IDC" })
                                .ImageUrl(Url.Content("~/images/save.png"))
                                .Content("Từ chối"))
            </div>
        </div>

    </div>

</form>

<script>
    $(function () {
        $("#form0").submit(function (event) {
            event.preventDefault();

            var expirePicker = $("#ExpiryDate").data("kendoDatePicker");

            if (expirePicker && expirePicker.value()) {
                $("#ExpiryDate").val(kendo.toString(expirePicker.value(), "yyyy-MM-dd"));
            }

            $("#UserId").val($("#StaffCode").val());
            $("#NickName").val($("#StaffCode").val());
            var form = this;
            var posCode = $("#PosCode").val();
            $("#pFlagCall").val($("#FlagCallView").val());
            $("#pButtonType").val(lcButton);
            submitFormAjax(form);
            return false;
        });
    });

    function submitFormAjax(form) {
        var dataString;
        var contentType;
        var processData;
        if (form.enctype === "multipart/form-data") {
            dataString = new FormData($(form).get(0));
            contentType = false;
            processData = false;
        }
        $.ajax({
            url: form.action,
            type: form.method,
            dataType: "json",
            contentType: contentType,
            processData: processData,
            data: dataString,
            success: function (result) {
                if (result == "0") {
                    alert("Bạn đã cập nhật thành công Thông tin người đại diện!");
                    dataChange = true;
                    onCloseUpdate();
                } else {
                    dataChange = false;
                    if (result == "1")
                        alert("Phòng giao dịch/Hội sở tỉnh không được để trống!");
                    else if (result == "2")
                        alert("Cán bộ được phân giao người đại diện không được để trống!");
                    else if (result == "3")
                        alert("Ngày hiệu lực và ngày hết hiệu lực không được trùng nhau!");
                    else if (result == "4")
                        alert("Ngày hiệu lực lớn hơn ngày hết hiệu lực phân giao!");
                }
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error:", xhr.responseText);
                alert("Lỗi khi cập nhật dữ liệu. Vui lòng liên hệ quản trị hệ thống!");
            }
        });
    }

    $(document).ready(function () {
        Change_RoleOfUserIDCStart();
        Change_RoleOfUserIDC();
        LoadStaffInfoDetail();
        var lcFunctionType = $("#FunctionType").val();
        if(lcFunctionType == "ADDNEW_USER" || lcFunctionType == "RESET_PASSWORD" || lcFunctionType == "ENABLE_USER" || lcFunctionType == "DISABLE_USER" || lcFunctionType == "DELETE_USER") {
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == "MODIFY_USER"){
            $("#divPosCode").hide();
            $("#divModify").show();
            $("#divRole").hide();
        }
        else if (lcFunctionType == "CHANGE_POS"){
            $("#divPosCode").show();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == "CHANGE_ROLE"){
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").show();
        }

        var lcButtonType = $("#ButtonTypeView").val();
        if(lcButtonType == "8"){
            $("#btnApproval").show();
            $("#btnAuthorize").hide();
        }
        else if(lcButtonType == "9"){
            $("#btnAuthorize").show();
            $("#btnApproval").hide();
        }
    });

</script>