    function onClickAuthorize(e) {
        var lcPosCode = $("#PosCode").val();
        var lcStaffId = $("#StaffCode").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcStaffId == null || lcStaffId == "") {
            alert('Cán bộ được phân giao quản lý địa bàn không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#StaffCode').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
        sendDataToParent($("#EventFlag_AuthorizeView").val(), $("#Status").val());
    }

    function onClickRejectChild(e) {
        var lcFlagEventCallView = $("#FlagEventCallView").val();
        var lcStatusReject = 0;
        var lcUserGradeView = $("#UserGradeView").val();
        if (lcUserGradeView == "2") {
            lcStatusReject = 7;
        }
        else if (lcUserGradeView == "3") {
            lcStatusReject = 4;
        }
        else lcStatusReject = 0;

        var lcPosCode = $("#PosCode").val();
        var lcRemark = $("#Remark").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcRemark == null || lcRemark == "" || lcRemark.length < 5) {
            alert('Từ chối cần phải nhập ghi chú. Bạn vui lòng kiểm tra lại!');
            $('#Remark').focus();
            e.preventDefault();
            return false;
        }
        var effectPicker = new Date();
        var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        if (effectPicker && expirePicker) {
            var dEffectDate = effectPicker.value();
            var dExpiryDate = expirePicker.value();
            if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
                alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
                $('#ExpiryDate').focus();
                e.preventDefault();
                return false;
            }
        }
        sendDataToParent($("#EventFlag_AuthorizeView").val(), lcStatusReject);
    }

    function sendDataToParent(eventFlag, statusValue) {
        var data = {
            Id: $("#Id").val(),
            UserId: $("#UserId").val(),
            Status: statusValue
        };
        if (window.parent && window.parent.receiveDataFromChild) {
            window.parent.receiveDataFromChild(data);
        }
        var lcFunctionTypeName = $("#FunctionTypeName").val();
        var lcUserId = $("#UserId").val();

        if(eventFlag == $("#EventFlag_ApprovalView").val()) {
            alert("Lưu tạm (Đánh dấu chọn) trình duyệt yêu cầu [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC [" + lcUserId + "] thành công!");
        }
        if (eventFlag == $("#EventFlag_AuthorizeView").val()) {
            alert("Lưu tạm (Đánh dấu chọn) phê duyệt yêu cầu [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC [" + lcUserId + "] thành công!");
        }
        if (eventFlag == $("#EventFlag_RejectView").val()) {
            alert("Lưu tạm (Đánh dấu chọn) từ chối yêu cầu [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC [" + lcUserId + "] thành công!");
        }
        onCloseUpdateApproval();
    }
</script>

