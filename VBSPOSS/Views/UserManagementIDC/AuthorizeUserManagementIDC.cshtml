<script>
    //Không sử dụng do các nút lệnh đều là không phải submit
    $(function () {
        $("#formAuthorizeDetail").submit(function (event) {
            event.preventDefault();
            var formAuthorizeDetailTmp = this;
            $("#pFlagCall").val($("#FlagEventCallView").val());
            $("#pButtonType").val($("#FunctionType").val());

            submitFormAjax(formAuthorizeDetailTmp);
            return false;
        });
    });

    function submitFormAjax(form) {
        var dataString;
        var contentType;
        var processData;
        if (form.enctype === "multipart/form-data") {
            dataString = new FormData($(form).get(0));
            contentType = false;
            processData = false;
        }
        $.ajax({
            url: form.action,
            type: form.method,
            dataType: "json",
            contentType: contentType,
            processData: processData,
            data: dataString,
            success: function (result) {
                if (result == "0") {
                    alert("Bạn đã cập nhật thành công Thông tin người đại diện!");
                    dataChange = true;
                    onCloseUpdateApproval();
                } else {
                    dataChange = false;
                    if (result == "1")
                        alert("Phòng giao dịch/Hội sở tỉnh không được để trống!");
                    else if (result == "2")
                        alert("Cán bộ được phân giao người đại diện không được để trống!");
                    else if (result == "3")
                        alert("Ngày hiệu lực và ngày hết hiệu lực không được trùng nhau!");
                    else if (result == "4")
                        alert("Ngày hiệu lực lớn hơn ngày hết hiệu lực phân giao!");
                }
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error:", xhr.responseText);
                alert("Lỗi khi cập nhật dữ liệu. Vui lòng liên hệ quản trị hệ thống!");
            }
        });
    }

    $(document).ready(function () {
        var lcFunctionType = $("#FunctionType").val();
        if(lcFunctionType == $("#FunctionTypeFlag_ADDNEW_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_ResetPasswordView").val()
            || lcFunctionType == $("#FunctionTypeFlag_ENABLE_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_DISABLE_USERView").val() || lcFunctionType == "DELETE_USER") {
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_MODIFY_USERView").val()) {
            $("#divPosCode").hide();
            $("#divModify").show();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_POSView").val()) {
            $("#divPosCode").show();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_ROLEView").val()) {
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").show();
        }

        var lcFlagEventCall = $("#FlagEventCallView").val();
        if(lcFlagEventCall == $("#EventFlag_ApprovalView").val()){
            $("#btnApproval").show();
            $("#btnAuthorize").hide();
        }
        else if(lcFlagEventCall == $("#EventFlag_AuthorizeView").val()){
            $("#btnAuthorize").show();
            $("#btnApproval").hide();
        }
        else if(lcFlagEventCall == $("#EventFlag_ViewView").val()){
            $("#btnAuthorize").hide();
            $("#btnApproval").hide();
        }
        
    });

</script>