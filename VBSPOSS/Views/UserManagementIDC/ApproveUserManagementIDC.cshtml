            var dataTempRow = {
                    Id: dataItem.Id,
                    UserId: dataItem.UserId,
                    Status: dataItem.Status
                };
            listUserIdChoiceApprovalTmp.push(dataTempRow);
        });
            

        
        if (listUserIdChoiceApprovalTmp.length === 0) {
