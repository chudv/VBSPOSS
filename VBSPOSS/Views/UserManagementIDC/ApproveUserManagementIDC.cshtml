    //Hàm thực hiện gọi In tờ trình
    $("#btnPrintToTrinh").click(function () {     
        if (listApprovalData.length === 0) {
            alert("Bạn chưa chọn danh sách yêu cầu về tài khoản người dùng Intellect iDC. Vui lòng chọn trình duyệt/Phê duyệt!");
            return;
        }
        var listPrintData = listApprovalData.filter(function(item) {
            return Number(item.Status) === 1 || Number(item.Status) === 5 || Number(item.Status) === 2;
        });

        if (listPrintData.length === 0) {
            alert("Chưa có dữ liệu thông tin trình duyệt/phê duyệt người dùng IDC. Vui lòng trình duyệt/Phê duyệt!");
            return;
        }

        var lcListId = listPrintData.map(x => x.Id).join(',');
        var lcMainPosName = $("#MainPosCodeApproval_Find").data("kendoComboBox").text();
        lcMainPosName = lcMainPosName.replace("Hội sở CN ", "Chi nhánh NHCSXH ");
        var lcFunctionType = $("#FunctionTypeApproval_Find").data("kendoComboBox").value();
        $.ajax({
            url: '@Url.Action("GenerateFileReport_UserIDC", "Report")',
            type: 'POST',
            data: { pId: lcListId, pMainPosName: lcMainPosName, pFunctionType: lcFunctionType },
            xhrFields: {
                responseType: 'blob'   // BẮT BUỘC
            },
            success: function (data, status, xhr) {

                var fileName = "To_Trinh_" + $("#PosCode").val() + "_" + $("#UserNameView").val() + ".pdf";
                var disposition = xhr.getResponseHeader("Content-Disposition");

                if (disposition) {
                    // Ưu tiên filename*=UTF-8''
                    var utf8Match = disposition.match(/filename\*\=UTF-8''(.+)/);
                    if (utf8Match && utf8Match.length > 1) {
                        fileName = decodeURIComponent(utf8Match[1]);
                    }
                    else {
                        // fallback filename=
                        var asciiMatch = disposition.match(/filename="?([^";]+)"?/);
                        if (asciiMatch && asciiMatch.length > 1) {
                            fileName = asciiMatch[1];
                        }
                    }
                }

                var blob = new Blob([data], {
                    type: xhr.getResponseHeader("Content-Type") || "application/octet-stream"
                });

                var url = window.URL.createObjectURL(blob);
                var link = document.createElement("a");
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();

                window.URL.revokeObjectURL(url);
                link.remove();
            },
            error: function () {
                alert("Không tải được file tờ trình cấu hình lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!");
            }
        });
    });
    
