<input type="hidden" id="hiddenApprovalData" name="ApprovalData" />
<div style="flex-grow: 1; display: flex; flex-direction: column; padding-left: 0px;padding-right: 0px;">
    <div class="row" style="color: navy; padding-top: 0px;padding-bottom: 0px;padding-left: 0px;padding-right: 0px;">

        <div class="col-md-12" style="padding-left: 0px;padding-right: 0px;">
            <label class="lbcontrol" style="color: navy;text-align:left;width:60px;padding-top:7px;padding-right:0px;padding-left:5px;font-family:Tahoma;font-size:12px;">Đơn vị</label>
            @(Html.Kendo().ComboBox().Name("MainPosCodeApproval_Find")
                .Filter(FilterType.Contains)
                .Placeholder("--- Đơn vị ---")
                .DataTextField("value")
                .DataValueField("id")
                .ClearButton(false)
                .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramLoadListBranchApprovalFind"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 230px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0))
            <label class="lbcontrol" style="color: navy;text-align:center;width:85px;padding-top: 7px;">Nghiệp vụ</label>
            @(Html.Kendo().ComboBox().Name("FunctionTypeApproval_Find")
                .Filter(FilterType.Contains)
                .DataTextField("Description")
                .DataValueField("Code")
                .BindTo((List<ValueConstModel>)ViewBag.FunctionTypes)
                .Placeholder("Chọn nghiệp vụ yêu cầu")
                .HtmlAttributes(new { style = "width: 270px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                .Filter("contains")
                .Events(e => e.Change("Change_FunctionTypeApproval"))
                .SelectedIndex(0))
            <label class="lbcontrol" style="width: 90px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:3px;padding-top:7px; ">Trạng thái</label>
            @(Html.Kendo().ComboBox().Name("StatusApproval_Find")
                .Filter(FilterType.Contains)
                .DataTextField("Text")
                .DataValueField("Value")
                .BindTo(new List<SelectListItem>() {
                    new SelectListItem() { Text = "Tất cả", Value = "-1" },
                    new SelectListItem() { Text = "Mở", Value = "1" },
                    new SelectListItem() { Text = "Đóng", Value = "0" }
                    })
                .Suggest(true)
                .AutoBind(true)
                .HtmlAttributes(new { style = "padding-left: 3px;width: 130px; color: blue;", })
                .SelectedIndex(0)
                )
            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                .Name("btnSearchApproval")
