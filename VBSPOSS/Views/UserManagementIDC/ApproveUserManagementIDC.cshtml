    $("#fileUpload").on("change", function () {

        if (!this.files || this.files.length === 0) {

            return;
        }

        for (let i = 0; i < this.files.length; i++) {

            let file = this.files[i];

            let fileName = file.name.toLowerCase();

            // check pdf
            if (!fileName.endsWith(".pdf")) {

                alert("File " + file.name + " không phải PDF");

                continue;
            }

            // tránh add trùng
            let exists = uploadedFiles.some(x => x.name === file.name);

            if (exists) {
                continue;
            }

            let fileUrl = URL.createObjectURL(file);

            uploadedFiles.push({
                name: file.name,
                url: fileUrl,
                file: file
            });

            renderFileItem(file.name, fileUrl);
        }

        // reset input để chọn lại được file cũ
        $("#fileUpload").val("");
    });

    function renderFileItem(fileName, fileUrl) {

        let html =
            `
            <div class="file-item"
                 data-file="${fileName}"
                 style="margin-top:0px;
                        border:1px solid #ddd;
                        padding:1px 1px;
                        border-radius:1px;
                        display:flex;
                        align-items:center;
                        justify-content:space-between;">

                <span style="color:maroon;">
                    ${fileName}
                </span>

                <div>

                    <button type="button"
                            class="btn btn-info btn-sm btn-view-file"
                            data-url="${fileUrl}">
                        👁
                    </button>

                    <button type="button"
                            class="btn btn-danger btn-sm btn-remove-file"
                            data-file="${fileName}">
                        ✖
                    </button>

                </div>

            </div>
            `;

        $("#fileList").append(html);
    }

    // xem file
    $(document).on("click", ".btn-view-file", function () {
        let url = $(this).data("url");
        window.open (url, "_blank", "width=1200,height=800");
    });

    // xóa file
    $(document).on("click", ".btn-remove-file", function () {

        let fileName = $(this).data("file");

        uploadedFiles = uploadedFiles.filter(x => x.name !== fileName);

        $('.file-item[data-file="' + fileName + '"]').remove();
    });
