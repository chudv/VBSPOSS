                } 
                else {
                    alert("Có lỗi xảy ra!");
                }
            },
            error: function (xhr) {
                console.error(xhr.responseText);
                alert("Lỗi hệ thống!");
            }
        });
    });



    $("#btnChooseFile").click(function () {

