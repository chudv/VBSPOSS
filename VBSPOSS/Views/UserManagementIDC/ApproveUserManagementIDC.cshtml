    function onRowBoundIDCApproval(e) {
        var rows = e.sender.tbody.children();
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var trangthaiRow = dataItem.get("Status");
            if (trangthaiRow == "C" || trangthaiRow == null || trangthaiRow == 0) {
                row.css("background-color", "white");
                row.find("td").css("color", "red");
            }
            
            var lcFlagCallView = $("#FlagCallView").val();
            if (lcFlagCallView == $("#EventFlag_ApprovalView").val()) {
                row.find(".btn-auth").hide();
                row.find(".btn-approval").show();
            }
            else if (lcButtonType == $("#EventFlag_AuthorizeView").val()) {
                row.find(".btn-approval").hide(); 
                row.find(".btn-auth").show();
            }
            var dSystemDateRow = dataItem.get("SystemDate");
            var dStartDateRow = dataItem.get("StartDate");
            if (dStartDateRow < dSystemDateRow) {
                row.css("background-color", "white");
                row.find("td").css("color", "red");
            }
        }

        var grid = e.sender;
        // Sự kiện chọn từng checkbox
        grid.tbody.find(".depProductCheckSelect")
            .off("change.depProduct")
            .on("change.depProduct", function (ev) {
                ev.stopPropagation();

                var $checkbox = $(this);
                var $row = $checkbox.closest("tr");

                $row.toggleClass("row-selected-custom", $checkbox.is(":checked"));

                updateSelectedRowIdUsers();
            });

        // Click vào row thì toggle checkbox
        grid.tbody.find("tr")
            .off("click.depProduct")
            .on("click.depProduct", function (ev) {
                if ($(ev.target).is("input:checkbox")) return;

                var $row = $(this);
                var $checkbox = $row.find(".depProductCheckSelect");

                if ($checkbox.length === 0 || $checkbox.is(":disabled")) return;

                $checkbox.prop("checked", !$checkbox.is(":checked"));
                $row.toggleClass("row-selected-custom", $checkbox.is(":checked"));

                updateSelectedRowIdUsers();
            });

        // Checkbox header chọn tất cả
        $("#chkSelectAllProducts")
            .off("change.depProduct")
            .on("change.depProduct", function (ev) {
                ev.stopPropagation();

                var isChecked = $(this).is(":checked");

                grid.tbody.find(".depProductCheckSelect").prop("checked", isChecked);
                grid.tbody.find("tr").toggleClass("row-selected-custom", isChecked);

                updateSelectedRowIdUsers();
            });

        // Đồng bộ lại giao diện sau databound
        grid.tbody.find("tr").each(function () {
            var $row = $(this);
            var isChecked = $row.find(".depProductCheckSelect").is(":checked");
            $row.toggleClass("row-selected-custom", isChecked);
        });

    }

    function updateSelectedRowIdUsers() {
        var grid = $("#gridMainIDCApproval").data("kendoGrid");
        var listItemChoice = [];

        grid.tbody.find(".depProductCheckSelect:checked").each(function () {
            var row = $(this).closest("tr");
            var dataItem = grid.dataItem(row);

            if (!dataItem) return;

            listItemChoice.push(dataItem.UserId);
        });

        if (listItemChoice.length === 0) {
            $("#idRowChoiceTmp").text("Tổng số yêu cầu: " + grid.dataSource.total());
        } else {
            $("#idRowChoiceTmp").text("Yêu cầu đã chọn: " + listItemChoice.join(", "));
        }

        var total = grid.tbody.find(".depProductCheckSelect").length;
        var checked = grid.tbody.find(".depProductCheckSelect:checked").length;

        $("#chkSelectAllProducts").prop("checked", total > 0 && total === checked);
    }

