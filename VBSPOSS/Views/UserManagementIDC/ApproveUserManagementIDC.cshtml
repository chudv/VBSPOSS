        font-weight: bold;
        color: blue;
    }

</style>
<script>
    var mainWindowApproval = $("#myPopupApproval");
</script>

<script>

    function paramLoadListBranchApprovalFind() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }
    function paramLoadListStaffApprovalFind() {
        return {
            pPosCode: $("#MainPosCodeUpd_Find").val(),
            pTitleChoice: "",
            pFlagTextShow: "2"
        };
    }

    function paramLoadGridDataApproval() {
        var lcStatus = $("#StatusApproval_Find").val();
        var lcButtonType = $("#ButtonTypeView").val();
        if (lcButtonType == "9") {
            lcStatus = 2;
        }
        if (lcButtonType == "8") {
            lcStatus = 1;
        }
        return {
            pPosCode: $("#MainPosCodeUpd_Find").val(),
            pFromEffectiveDate: "",
            pToEffectiveDate: "",
            pFunctionType: $("#FunctionTypeApproval_Find").val(),
            // pFullName: $("#StaffName_Find").val(),
            pStatus: lcStatus
        };
    }

    function refreshGridIDCApproval() {
        var grid = $("#gridMainIDCApproval").data("kendoGrid");
        if (grid != null) {
            grid.dataSource.read();
        }
    }

    function onSearchApprovalTest(e) {
        refreshGridIDCApproval();
    }

        function onRowBoundIDCApproval(e) {
            var rows = e.sender.tbody.children();
            for (var j = 0; j < rows.length; j++) {
                var row = $(rows[j]);
                var dataItem = e.sender.dataItem(row);
                var trangthaiRow = dataItem.get("Status");
                if (trangthaiRow == "C" || trangthaiRow == null || trangthaiRow == 0) {
                    row.css("background-color", "white");
                    row.find("td").css("color", "red");
                }

                var lcButtonType = $("#ButtonTypeView").val();
                if (lcButtonType == "8") {
                    row.find(".btn-auth").hide();
                    row.find(".btn-approval").show();
                }
                else if (lcButtonType == "9") {
                    row.find(".btn-approval").hide(); 
                    row.find(".btn-auth").show();
                }
            }
        }

    var dataChange = false;
    function onCloseApprove() {
        if (dataChange == true) {
            refreshGridIDCApproval();
            dataChange = false;
        }
    }

    function doCompleteWindow() {
        mainWindowApproval.data("kendoWindow").close();
    }

    function deleteItem(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "[" + dataItem.StaffName + " - " + dataItem.StaffPositionName + "]";
        if (dataItem.Status === 0) {
            alert("Thành viên " + sMessInfor + " đã được đánh dấu xóa rồi. Không thực hiện đánh dấu xóa lại!");
        }
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa dữ liệu thông tin thành viên " + sMessInfor + " không?");
            if (isConfirm == true) {
                $.ajax({
                    data: { pStaffId: dataItem.StaffId,pEffectDate: formatDDMMYYYY(dataItem.EffectDate),pExpireDate: formatDDMMYYYY(dataItem.ExpireDate),pStatus: 1},
                    type: "POST",
                    url: "../PosRepresentative/DeleteMarkPosRepresentative",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn đã xóa thành công thông tin thành viên " + sMessInfor + "!");
                            refreshGridIDCApproval();
                        }
                        else alert("Đánh dấu xóa thông tin thành viên " + sMessInfor + " thất bại!");
                    },
                    error: function () {
                        alert(" dấu xóa thông tin thành viên " + sMessInfor + " có lỗi!");
                    }
                });

            } else {
                alert("Thao tác bị hủy bỏ!");
            }
        }
    }

    function Change_PosCode(e) {
    }

    function Change_FunctionTypeApproval(e) {
        addListAttachfilesLink();
    }


    function formatDDMMYYYY(date) {
        if (!date) return null;

        const d = new Date(date);
        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();

        return `${day}/${month}/${year}`;
    }

    function showEdit(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Người dùng [" + dataItem.UserId + "]";
        if (dataItem.Status.toString() == "0") {
            alert(sMessInfor + " đã được đánh dấu xóa nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "3") {
            alert(sMessInfor + " đã được phê duyệt nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "4") {
            alert(sMessInfor + " đã được từ chối nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else
        {
            var sFlagCall = $("#EventFlag_EditTemp").val();
            mainWindowApproval.kendoWindow({
                width: "1024px",
                height: "500px",
                title: "Chỉnh sửa thông tin người dùng IDC",
                content: {
                    url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                    data: { pPosCode: dataItem.PosCode, pUserId: dataItem.UserId, pFlagCall: "2" }
                },
                resizable: false,
                visible: false,
                modal: true,
                close: onCloseApprove,
                actions: ["Refresh", "Close"]
            });
            mainWindowApproval.data("kendoWindow").wrapper.css({ height: 500, width: 1024 });
            mainWindowApproval.data("kendoWindow").center().open().title("Chỉnh sửa thông tin người dùng IDC");
        }
    }

    function submitForApprovalIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "[" + dataItem.FullName + "]";
        var grid = $("#gridMainTidePanelRate").data("kendoGrid");
        // Kiểm tra trạng thái trước khi trình duyệt
        var deletedStatuses = [0, 2, 3, 4];
        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.Status == 0) {
                alert("Tạo lập yêu cầu thay đổi người dùng" + sMessInfor + " đã được đánh dấu xóa rồi. Không thực hiện thay đổi!");
            }
            else if (dataItem.Status == 2) {
                alert("Người dùng " + sMessInfor + " đã trình duyệt, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 3) {
                alert("Người dùng " + sMessInfor + " đã phê duyệt, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 4) {
                alert("Người dùng " + sMessInfor + " đã được từ chối, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            return;
        }
        if (mainWindowApproval.data("kendoWindow")) {
            mainWindowApproval.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_ApprovalTemp").val();
        mainWindowApproval.kendoWindow({
            width: "1000px",
            height: "600px",
            title: "Trình duyệt thông tin người dùng IDC",
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pId: dataItem.Id,pPosCode: dataItem.PosCode, pUserId: dataItem.UserId, pFlagCall: "", pButtonType: "8" }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseApprove,
            actions: ["Refresh","Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindowApproval.data("kendoWindow").close();
            }
        });
        mainWindowApproval.data("kendoWindow").center().open();
    }

    function submitForAuthorizeIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "[" + dataItem.FullName + "]";
        var grid = $("#gridMainTidePanelRate").data("kendoGrid");
        //Kiểm tra trạng thái trước khi trình duyệt
        var deletedStatuses = [0, 1, 3, 4];
        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.Status == 0) {
                alert("Tạo lập yêu cầu thay đổi người dùng" + sMessInfor + " đã được đánh dấu xóa rồi. Không thực hiện thay đổi!");
            }
            else if (dataItem.Status == 1) {
                alert("Người dùng " + sMessInfor + " đang tạo lập, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 3) {
                alert("Người dùng " + sMessInfor + " đã phê duyệt, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 4) {
                alert("Người dùng " + sMessInfor + " đã được từ chối, không thể thực hiện yêu cầu phê duyệt. Vui lòng kiểm tra lại!");
            }
            return;
        }
        if (mainWindowApproval.data("kendoWindow")) {
            mainWindowApproval.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_ApprovalTemp").val();
        mainWindowApproval.kendoWindow({
            width: "1000px",
            height: "600px",
            title: "Phê duyệt thông tin người dùng IDC",
            content: {
                url: '@Url.Action("ShowUpdateUserManagementIDC", "UserManagementIDC")',
                data: { pId: dataItem.Id,pPosCode: dataItem.PosCode, pUserId: dataItem.UserId, pFlagCall: "", pButtonType: "9" }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseApprove,
            actions: ["Refresh","Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindowApproval.data("kendoWindow").close();
            }
        });
        mainWindowApproval.data("kendoWindow").center().open();
    }

    function showDetailTidePenalRate(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        if (mainWindowApproval.data("kendoWindow")) {
            mainWindowApproval.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_ViewTemp").val();
        mainWindowApproval.kendoWindow({
            width: "1050px",
            height: "750px",
            title: "Xem chi tiết thông tin Quyết định cấu hình lãi suất rút trước hạn tiền gửi CKH",
            content: {
                url: '@Url.Action("ShowUpdateTidePenalRate", "IntRateConfig")',
                data: { pPosCode: dataItem.PosCode, pDocumentId: dataItem.DocumentId, pListId: dataItem.IdList, pProductGroupCode: $("#ProductGroupCodeView").val(), pFlagCall: sFlagCall}
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseApprove,
            actions: ["Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindowApproval.data("kendoWindow").close();
            }
        });
        mainWindowApproval.data("kendoWindow").center().open();

    }

    function showAttachedFile(pDocumentId, pFileId, pFileNameNew) {
        var now = new Date();
        var win = window.open('../IntRateConfig/LoadPdfAttachedFile?pDocumentId=' + pDocumentId + '&' + 'pFileId=' + pFileId + '&' + 'pFileName=' + pFileNameNew + '&t=' + now.getTime(), '_blank');
        if (win) {
            win.focus();
        } else {
            alert('Please allow popups for this website');
        }
    }

    function add_download_link() {
        var lcDocumentId = $("#DocumentId").val();
        var lcFileType = "1";
        if (lcDocumentId != 0) {
            $.ajax({
                type: "GET",
                url: "../ListOfValue/GetListAttachedFileInfo_ForDocumentId?pDocumentId=" + lcDocumentId + '&' + 'pFileType=' + lcFileType,
                success: function (data) {
                    files = data;
                    if (files != null) {
                        $("#_no_file_attach_id").text("");
                        for (i = 0; i < files.length; i++) {
                            var thutu = i + 1;
                            html = '<a title="' + files[i].Description + '" href="#" onclick=showAttachedFile(' + lcDocumentId + ',' + files[i].FileId + ',"' + files[i].FileNameNew + '")' + '>' + ' [' + thutu + '] ' + "</a>&nbsp;";
                            $("#_no_file_attach_id").append(html);
                        }
                    }
                }
            });
        }
    }

    var listApprovalData = []; // danh sách tổng
    function receiveDataFromChild(data) {
        //Tránh trùng theo Id
        var index = listApprovalData.findIndex(x => x.Id === data.Id);
        if (index !== -1) {
            // nếu đã tồn tại thì update
            listApprovalData[index] = data;
        } else {
            // nếu chưa có thì thêm mới
            listApprovalData.push(data);
        }
        console.log("Danh sách hiện tại:", listApprovalData);
        // lưu vào hidden để submit sau
        $("#hiddenApprovalData").val(JSON.stringify(listApprovalData));
    }

    function addListAttachfilesLink() {
        var pMainPosCode = parseInt($("#MainPosCodeUpd_Find").val(), 10) || 0;
        var pFunctionType = $("#FunctionTypeApproval_Find").data("kendoComboBox").value();
        $("#_no_file_attachId").text("");
        if (pMainPosCode != 0) {
            $.ajax({
                type: "GET",
                url: "../UserManagementIDC/GetListAttachFile_ForGroupFile?pDocumentId=" + pMainPosCode + '&' + 'pDocumentNumber=' + pFunctionType,
                success: function (data) {
                    files = data;
                    if (files != null) {
                        $("#_no_file_attachId").text("");
                        for (i = 0; i < files.length; i++) {
                            var thutu = i + 1;
                            html = '<a title="' + files[i].Description + '" href="#" ' +
                                    'onclick="showAttachtFileQDKT(' + pMainPosCode + ',' + files[i].Id + ',\'' + files[i].FileNameNew + '\')">' +
                                    ' [' + thutu + '] </a>&nbsp;';
                            $("#_no_file_attachId").append(html);
                        }
                    }
                }
            });
        }
    }

    function showAttachtFileQDKT(vanbanId, fileId, tenFileMoi) {
        var win = window.open('../UserManagementIDC/LoadPdfFile?pDocumentId=' + vanbanId + '&' + 'pFileId=' + fileId + '&' + 'pFileName=' + tenFileMoi, '_blank');
        if (win) {
            win.focus();
        } else {
            alert('Please allow popups for this website');
        }
    }
</script>


@Html.Hidden("UserPosCodeView", TempData["UserPosCode"])
@Html.Hidden("UserNameView", TempData["UserName"])
@Html.Hidden("ButtonTypeView", TempData["ButtonType"])
@Html.Hidden("MainPosCodeView", TempData["MainPosCode"])
<input type="hidden" id="hiddenApprovalData" name="ApprovalData" />
<hr style='margin-top: 0.2em; margin-bottom: 0.3em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />

<div style="flex-grow: 1; display: flex; flex-direction: column; ">
    <div class="row" style="color: navy; padding-top: 0px;padding-bottom: 0px;">

        <div class="col-md-12">
            <label class="lbcontrol" style="color: navy;text-align:left;width:60px;padding-top:3px;padding-right:0px;padding-left:5px;font-family:Tahoma;font-size:12px;">Đơn vị</label>
            @(Html.Kendo().ComboBox().Name("MainPosCodeUpd_Find")
                        .Filter(FilterType.Contains)
                        .Placeholder("--- Đơn vị ---")
                        .DataTextField("value")
                        .DataValueField("id")
                        .Events(e => e.Change("Change_PosCode"))
                        .ClearButton(false)
                        .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramLoadListBranchApprovalFind"); }).ServerFiltering(false); })
                        .HtmlAttributes(new { style = "width: 250px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                        .Suggest(true)
                        .AutoBind(true)
                        .SelectedIndex(0))
            <label class="lbcontrol" style="color: navy;text-align:center;width:80px;padding-top: 7px;">Nghiệp vụ</label>
            @(Html.Kendo().ComboBox().Name("FunctionTypeApproval_Find")
                        .Filter(FilterType.Contains)
                        .DataTextField("Description")
                        .DataValueField("Code")
                        .BindTo((List<ValueConstModel>)ViewBag.FunctionTypes)
                        .Placeholder("Chọn nghiệp vụ yêu cầu")
                        .HtmlAttributes(new { style = "width: 250px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                        .Filter("contains")
                        .Events(e => e.Change("Change_FunctionTypeApproval"))
                        .SelectedIndex(0))
@*             <label class="lbcontrol" style="color: navy;text-align:right;width:170px;padding-top:3px;padding-right:6px;">Tên/Mã người đại diện</label>
            @(Html.Kendo().TextBox().Name("StaffName_Find")
                        .Placeholder("Nhập tên hoặc mã cán bộ")
                        .HtmlAttributes(new { style = "width: 250px;padding-left: 3px;padding-right: 2px;" }))
 *@
            <label class="lbcontrol" style="width: 90px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:3px;padding-top:3px; ">Trạng thái</label>
            @(Html.Kendo().DropDownList().Name("StatusApproval_Find")
                        .DataTextField("Text")
                        .DataValueField("Value")
                        .BindTo(new List<SelectListItem>() { new SelectListItem() { Text = "Tất cả", Value = "-1" }, new SelectListItem() { Text = "Mở", Value = "1" }, new SelectListItem() { Text = "Đóng", Value = "0" } })
                        .HtmlAttributes(new { style = "width: 120px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;" })
                        .SelectedIndex(0)
                        )

            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                        .Name("btnSearchApproval")
                        .Events(ev => ev.Click("onSearchApprovalTest"))
                        .HtmlAttributes(new { type = "button", style = "font-weight:bold; width:100px; color: blue;padding-left: 0px; height: 25px;", title = "Tìm kiếm danh sách quyết định cấu hình lãi suất rút trước hạn TG CKH" })
                        .ImageUrl(Url.Content("~/images/tim_kiem.png"))
                        .Content(" Tìm kiếm "))
        </div>
    </div>


    <div style="color: navy; padding-top: 0px; display:flex;" class="row">
        <div class="col-md-12">
            @(Html.Kendo().Grid<VBSPOSS.ViewModels.UserManagementIDCViewModel>()
                        .Name("gridMainIDCApproval")
                        .Events(e => e.DataBound("onRowBoundIDCApproval"))
                        .Columns(columns =>
                        {
                            columns.Command(command =>
                            {
                                command.Custom("Approval").Text("<span style='color: blue;'></span>").Click("submitForApprovalIDC").HtmlAttributes(new
                                {
                                    style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                                    title = "Trình duyệt người dùng IDC",
                                    @class = "btn-approval"
                                });
                                command.Custom("Authorize").Text("<span style='color: blue;'></span>").Click("submitForAuthorizeIDC").HtmlAttributes(new
                                {
                                    style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                                    title = "Phê duyệt người dùng IDC",
                                    @class = "btn-auth"
                                });
                            }).Width(90).Title("Chức năng").HtmlAttributes(new { style = "text-align: center;" });

                            columns.Command(command =>
                            {
                                command.Custom("View").Text("<span style='color: blue;'></span>").Click("showDetailTidePenalRate").HtmlAttributes(new
                                {
                                    style = "width: 20px !important; display: inline-block; vertical-align: middle;",
