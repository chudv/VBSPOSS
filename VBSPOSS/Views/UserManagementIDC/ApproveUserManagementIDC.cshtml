        var lcBusinessDateTextView = $("#BusinessDateTextApprovalView").val();
        var functionType = $("#FunctionTypeApproval_Find").data("kendoComboBox").value();        
        var requireFileTypes = [$("#FunctionTypeFlag_ADDNEW_USERView").val(), $("#FunctionTypeFlag_DELETE_USERView").val(), $("#FunctionTypeFlag_CHANGE_POSView").val(), $("#FunctionTypeFlag_DISABLE_USERView").val(), $("#FunctionTypeFlag_ENABLE_USERView").val(), $("#FunctionTypeFlag_MODIFY_USERView").val(), $("#FunctionTypeFlag_CHANGE_ROLEView").val()];
    
        var lcFunctionTypeNameChoice = $("#FunctionTypeApproval_Find").data("kendoComboBox").text();

        var fileInput = $("#fileUpload")[0];
        alert(uploadedFiles.length );
        //var fileUploadUserIDC = fileInput.files.length > 0 ? fileInput.files[0] : null;
        var fileUploadUserIDC = uploadedFiles.length > 0 ? uploadedFiles : [];
