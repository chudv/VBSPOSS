     function onSaveGridIDC(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {
                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_handlerIDC(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
            console.error("Kendo Grid Error:", e.errors);  // Debug console để xem lỗi backend (F12)
        }
    }

    $(document).ready(function () {
        $("#gridMainIDCApproval .k-grid-excel").after("<label id='lbl_spaceApprove' style='padding-top:5px;padding-left: 10px;width:70%; font-size: 11px; font-weight: bold; color: blue;text-align:center;line-height: 25px;'>DANH SÁCH THÔNG TIN NGƯỜI DÙNG IDC ĐỀ NGHỊ THAY ĐỔI</label>");
        var lcButtonType = $("#ButtonTypeView").val();
        if (lcButtonType == "9") {
            $("#btnPrintToTrinh").hide();
            $("#divUploadFile").hide();
            $("#divFileAttached").show();
            addListAttachfilesLink();
        }
        else if(lcButtonType == "8"){
            $("#divFileAttached").hide();
            $("#divUploadFile").show();
        }
        $("#btnChooseFile").click(function () {
            $("#fileUpload").click();
        });
        $("#fileUpload").on("change", function () {
            if (this.files && this.files.length > 0) {
                $("#fileName").text(this.files[0].name);
                $("#btnRemoveFile").show();
            } else {
                resetFile();
            }
        });
        // Click nút xóa
        $("#btnRemoveFile").click(function () {
            resetFile();
        });
        function resetFile() {
            $("#fileUpload").val("");   // xóa file
            $("#fileName").text("Chưa chọn file");
            $("#btnRemoveFile").hide();
        }

        $("#fileUpload").on("change", function () {
            if (!this.files || this.files.length === 0) return;

            var file = this.files[0];
            var fileName = file.name.toLowerCase();

            if (!fileName.endsWith(".pdf")) {
                alert("Chỉ cho phép upload file PDF");
                resetFile();
                return;
            }
            $("#fileName").text(file.name);
            $("#btnRemoveFile").show();
        });

        var combo = $("#MainPosCodeUpd_Find").data("kendoComboBox");
        var value = $("#MainPosCodeView").val();
        if (value) {
            combo.value(value);
            // Trigger change để đồng bộ PosName nếu cần
            combo.trigger("change");
        }
    });

