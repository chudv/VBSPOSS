    $("#btnApprovalAll, #btnAuthorizeAll").click(function () {
        if (listApprovalData.length === 0) {
            alert("Chưa có dữ liệu thông tin trình duyệt/phê duyệt người dùng IDC. Vui lòng trình duyệt/Phê duyệt!");
            return;
        }
        var lcButtonType = $("#ButtonTypeView").val();
        var functionType = $("#FunctionTypeApproval_Find").data("kendoComboBox").value();
        var requireFileTypes = ["ADDNEW_USER", "DELETE_USER", "CHANGE_POS"];

        var fileInput = $("#fileUpload")[0];
        var file = fileInput.files.length > 0 ? fileInput.files[0] : null;

        if (requireFileTypes.includes(functionType) && lcButtonType == "8") {
            if (!file) {
                alert("Nghiệp vụ này yêu cầu phải đính kèm file PDF!");
                return;
            }

            if (!file.name.toLowerCase().endsWith(".pdf")) {
                alert("File phải là PDF!");
                return;
            }
        }

        var objFunctionType = $("#FunctionTypeApproval_Find").data("kendoComboBox");
        var objMainPos = $("#MainPosCodeUpd_Find").data("kendoComboBox");

        //Tạo FormData
        var formData = new FormData();
        // append list data
        formData.append("listApprovalData", JSON.stringify(listApprovalData));
        formData.append("pFunctionType", objFunctionType.value());
        formData.append("pMainPosCode", objMainPos.value());
        // append file
        if (file) {
            formData.append("fileUpload", file);
        }

        $.ajax({
            url: "/UserManagementIDC/SaveUpdateApproval",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                if (res === "0") {
                    alert("Lưu thành công!");
                    dataChange = false;
                    refreshGridIDCApproval();
                } else if (res === "-1") {
                    alert("Lỗi khi lưu dữ liệu người dùng IDC");
                } else if (res === "-2") {
                    alert("Thực hiện gọi API không thành công: Thay đổi tài khoản người dùng thất bại");
                } else {
                    alert("Có lỗi xảy ra!");
                }
            },
            error: function (xhr) {
                console.error(xhr.responseText);
                alert("Lỗi hệ thống!");
            }
        });
    });
