                }
                else if (resultSaveUpdate === "-1") {
                    alert("Lỗi khi lưu dữ liệu người dùng IDC");
                } 
                else if (resultSaveUpdate === "-2") {
                    alert("Thực hiện gọi API không thành công: Thay đổi tài khoản người dùng thất bại");
                } 
                else if (resultSaveUpdate == "5") {
                    alert("Thực hiện cập nhật thay đổi quyền tiền mặt không thành công. Vui lòng thực hiện lại!");
                } 
                else if (resultSaveUpdate == "6") {
                    alert("Người dùng này có mở sổ tiền mặt đầu ngày, không được phép sửa đổi. Vui lòng liên hệ quản trị viên!");
