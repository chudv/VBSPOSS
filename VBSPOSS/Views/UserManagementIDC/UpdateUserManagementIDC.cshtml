                @Html.Kendo().TextBoxFor(m=>m.UserId).HtmlAttributes(new { @readonly = "readonly", style = " width: 40px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
                <label class="lbcontrol" style="color: navy;text-align:center;width:100px;padding-top: 7px;padding-right: 10px;">Họ đệm </label>
                @Html.Kendo().TextBoxFor(m => m.FirstName).HtmlAttributes(new { @readonly = "readonly", style = " width: 90px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
                <label class="lbcontrol" style="color: navy;text-align:center;width:100px;padding-top: 7px;padding-right: 10px;">Tên đệm </label>
                @Html.Kendo().TextBoxFor(m => m.LastName).HtmlAttributes(new { @readonly = "readonly", style = " width: 50px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
