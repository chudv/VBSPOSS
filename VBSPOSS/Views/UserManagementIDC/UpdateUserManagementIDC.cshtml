    function submitFormAjax(form) {
        var dataString;
        var contentType;
        var processData;
        if (form.enctype === "multipart/form-data") {
            dataString = new FormData($(form).get(0));
            contentType = false;
            processData = false;
        }
        $.ajax({
            url: form.action,
            type: form.method,
            dataType: "json",
            contentType: contentType,
            processData: processData,
            data: dataString,
            success: function (result) {
                if (result == "0") {
                    
                    var lcFlagCallText = $("#FlagCall").val();
                    if ($("#FlagCall").val() == "1")
                        lcFlagCallText = "Thêm mới";
                    else if ($("#FlagCall").val() == "2")
                        lcFlagCallText = "Chỉnh sửa";
                    alert("Bạn đã cập nhật " + lcFlagCallText + " bản ghi yêu cầu nghiệp vụ tạo mới tài khoản người dùng [" + $("#UserId").val() + " - " + $("#FullName").val() + "] đăng nhập Intellect iDC thành công!");
                    dataChange = true;
                    onCloseUpdate();
                } 
                else {
                    dataChange = false;
                    if (result == "15")
                        alert("Yêu cầu tạo mới tài khoản người dùng nhưng trạng thái bản ghi là đóng. Vui lòng kiểm tra lại!");
                    else if (result == "1")
                        alert("Mã đơn vị của tài khoản người dùng Intellect iDC không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "2")
                        alert("Mã cán bộ của tài khoản người dùng Intellect iDC không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "14")
                        alert("Số điện thoại của người dùng không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "3")
                        alert("Tài khoản người dùng có ngày hiệu lực [" + $("#EffectiveDate").val() + "] bằng ngày hết hiệu lực [" + $("#ExpiryDate").val() + "]!. Vui lòng kiểm tra lại!");
                    else if (result == "4")
                        alert("Tài khoản người dùng có ngày hiệu lực [" + $("#EffectiveDate").val() + "] lớn hơn ngày hết hiệu lực [" + $("#ExpiryDate").val() + "]. Vui lòng kiểm tra lại!");
                    else if (result == "5")
                        alert("Tài khoản người dùng có phương thức xác thực khi đăng nhập là OTP nên không thể thực hiện tạo yêu cầu nghiệp vụ " + $("#FunctionTypeName").val() + ". Vui lòng kiểm tra lại!");
                        //alert("Tài khoản người dùng có phương thức xác thực khi đăng nhập là OTP nên không thể thực hiện tạo yêu cầu cấp lại mật khẩu. Vui lòng kiểm tra lại!");
                    else if (result == "6")
                        alert("Tài khoản người dùng đã mở sổ tiền mặt đầu ngày, nên không thể thực hiện tạo yêu cầu nghiệp vụ " + $("#FunctionTypeName").val() + ". Vui lòng kiểm tra lại!");
                    else if (result == "7")
                        alert("Tài khoản người dùng có yêu cầu nghiệp vụ " + $("#FunctionTypeName").val() + ", nhưng thông tin (Quyền/Số điện thoại/Email) vẫn giữ nguyên. Vui lòng kiểm tra lại!");
                    else if (result == "8")
                        alert("Ngày bắt đầu nhỏ hơn ngày hiện tại. Vui lòng kiểm tra lại!");
                    else if (result == "9")
                        alert("Tài khoản người dùng có trạng thái đóng, không thể thực hiện nghiệp vụ " + $("#FunctionTypeName").val() + ". Vui lòng kiểm tra lại!");
                    else if (result == "10")
                        alert("Yêu cầu nghiệp vụ [" + $("#FunctionTypeName").val() + "], nhưng tài khoản người dùng " + $("#UserId").val() + " đã tồn tại trên hệ thống Intellect iDC. Vui lòng kiểm tra lại!");
                    else if (result == "11")
                        alert("Địa chỉ email [" + $("#EmailAddress").val() + "] của người dùng bị trống hoặc không phải email nội bộ của NHCSXH. Vui lòng kiểm tra lại!");
                    else if (result == "12")
                        alert("Tài khoản người dùng Intellect iDC cập nhật có ngày hiệu lực [" + $("#EffectiveDate").val() + "] nhỏ hơn ngày hiện tại của hệ thống Intelect iDC [" + $("#BusinessDate").val() + "]. Vui lòng kiểm tra lại!");
                    else if (result == "13")
                        alert("Tài khoản người dùng Intellect iDC cập nhật có ngày bắt đầu [" + $("#StartDate").val() + "] nhỏ hơn ngày hiện tại của hệ thống Intelect iDC [" + $("#BusinessDate").val() + "]. Vui lòng kiểm tra lại");
                    else if (result == "23" || result == "24")
                        alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC có thông tin địa chỉ email [" + $("#EmailAddress").val() + "] không hợp lệ. Vui lòng kiểm tra lại!");
                    else if (result == "25")
                        alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC có thông tin số điện thoại [" + $("#MobileNumber").val() + "] không hợp lệ. Vui lòng kiểm tra lại!");
                    else if (result == "26")
                        alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC [" + $("#UserId").val() + "] đã tồn tại. Vui lòng kiểm tra lại!");
                }
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error:", xhr.responseText);
                alert("Lỗi khi cập nhật dữ liệu. Vui lòng liên hệ quản trị hệ thống!");
            }
        });
    }

    $(document).ready(function () {
        setTimeout(function () 
        {
            Change_PosCode();
            Change_RoleOfUserIDC();
            LoadStaffInfoDetail();

            

        }, 300); // delay nhẹ để đảm bảo Kendo init xong
        var lcFlagCall = $("#FlagCall").val();

        //Nếul à xem thì readonly các control và Hide nút lệnh Lưu
        var cboStatus = $("#Status").data("kendoComboBox");
        cboStatus.readonly(true);
        if (lcFlagCall == $("#EventFlag_AddView").val() || lcFlagCall == $("#EventFlag_ViewView").val())
        {
            var cboStatus = $("#Status").data("kendoComboBox");
            cboStatus.readonly(true);
        }
        else if (lcFlagCall == $("#EventFlag_ViewView").val())
        {
            var cboPosCode = $("#PosCode").data("kendoComboBox");
            cboPosCode.readonly(true);

            var cboStaffId = $("#StaffId").data("kendoComboBox");
            cboStaffId.readonly(true);

            // var cboGroupName = $("#GroupName").data("kendoComboBox");
            // cboGroupName.readonly(true);

            var cboAuthsecType = $("#AuthsecType").data("kendoComboBox");
            cboAuthsecType.readonly(true);

            var cboMailIdFlag = $("#MailIdFlag").data("kendoComboBox");
            cboMailIdFlag.readonly(true);

            var txtIpSetDetail = $("#IpSetDetail").data("kendoTextBox");
            txtIpSetDetail.readonly(true);

            var cboStatus = $("#Status").data("kendoComboBox");
            cboStatus.readonly(true);

            var dtpkEffectiveDate = $("#EffectiveDate").data("kendoDatePicker");
            dtpkEffectiveDate.readonly(true);

            var dtpkExpiryDate = $("#ExpiryDate").data("kendoDatePicker");
            dtpkExpiryDate.readonly(true);

            var dtpkStartDate = $("#StartDate").data("kendoDatePicker");
            dtpkStartDate.readonly(true);

            $("#Remark").prop("readonly", true)

            $("#btnSaveCreateNewUserIDC").hide();                    // Cách đơn giản nhất
        }
    });

</script>