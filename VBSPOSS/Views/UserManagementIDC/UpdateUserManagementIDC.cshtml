                @(Html.Kendo().ComboBoxFor(m => m.MailIdFlag)
                                .DataTextField("Description")
                                .DataValueField("Code")
                                .BindTo((List<ValueConstModel>)ViewBag.MailIdFlags)
                                .Placeholder("Chọn phương thức gửi mật khẩu")
                                .HtmlAttributes(new { style = "width: 770px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                                .Filter("contains")
                                .SelectedIndex(3))
            </div>
        </div>

        <div class="row" style="margin-bottom: 15px;padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="color: navy;text-align:left;width:170px;padding-top: 7px;padding-right: 10px;"> Dải IP được truy cập </label>
                @Html.Kendo().TextBoxFor(m => m.IpSetDetail).HtmlAttributes(new { @readonly = "readonly", style = " width: 770px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
            </div>
        </div>

        <div class="row" style="margin-bottom: 15px;padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: bottom;color: navy;text-align:left;padding-top:3px;">Ngày bắt đầu</label>
                @Html.Kendo().DatePickerFor(m => m.StartDate).Format("dd/MM/yyyy").Min(DateTime.Today).HtmlAttributes(new { style = "width: 150px;max-width:100%;font-family:Tahoma;color: blue;padding-left: 3px;padding-right: 3px;" })
                <label class="lbcontrol" style="width: 150px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:7px;padding-top:3px;">Ngày hết hiệu lực</label>
                @Html.Kendo().DatePickerFor(m => m.ExpiryDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 150px;max-width:100%;font-family:Tahoma;color: blue;padding-left: 3px;padding-right: 3px;" })
                <label class="lbcontrol" style="width: 100px; vertical-align: bottom;color: navy;text-align:center; padding-left:0px;padding-right:7px;padding-top:3px; ">Trạng thái</label>
                @(Html.Kendo().ComboBoxFor(m => m.Status)
                                .Filter(FilterType.Contains)
                                .Placeholder("--- Trạng thái ---")
                                .DataTextField("Text")
                                .DataValueField("Value")
                                .BindTo(new List<SelectListItem>() {
                                    new SelectListItem() { Text = "Mở (Hoạt động)", Value = "1" },
                                    new SelectListItem() { Text = "Đóng (Hết hiệu lực)", Value = "0" }
                                })
                                .Suggest(true)
                                .AutoBind(true)
                                .HtmlAttributes(new { style = "width: 220px; color: blue;", })
                                .Events(e => e.Change("Change_Status"))
                                .SelectedIndex(0))
            </div>
        </div>

        <div class="row" style="padding-top: 7px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: middle;color: navy;text-align:left;">Ghi chú (nếu có)</label>
                @Html.TextAreaFor(m => m.Remark, new { @class = "k-textbox", style = "min-height:50px;width:770px;max-width:100%;color: blue;font-family:Tahoma !important;", rows = "2" })
            </div>
        </div>

        <div class="row" style="padding-top: 13px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="width:100%; display:flex; justify-content:flex-end;">
                <label class="control-label" id="lblMessageInfor" style="width: 750px; text-align: left; color: red;"></label>
                &nbsp;&nbsp;
                @(Html.Kendo().Button()
                                .Name("btnSave")
                                .Events(ev => ev.Click("onClick"))
                                .HtmlAttributes(new { type = "submit", style = "width: 90px; font-weight:bold; color: blue;height: 25px;", title = "Cập nhật thông tin phân giao cán bộ phụ trách địa bàn" })
                                .ImageUrl(Url.Content("~/images/save.png"))
                                .Content("Lưu lại"))
                &nbsp;
                @(Html.Kendo().Button().Name("btnThoat").Events(ev => ev.Click("onCloseUpdate")).HtmlAttributes(new { type = "button", style = "height: 25px;width: 100px; font-weight:bold; color: blue;", title = "Đóng lại màn hình cập nhật thông tin" }).ImageUrl(Url.Content("~/images/close_icon.gif")).Content("Quay ra"))
            </div>
        </div>

    </div>

</form>

