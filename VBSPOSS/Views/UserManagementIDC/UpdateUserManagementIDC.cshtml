            //         dataType: 'json',
            //         data: { pPosCode: posCode },
            //         success: function (res) {
            //             if (res && res.resultVal === "1") {
            //                 if (!confirm("Đã tồn tại người đại diện đang hiệu lực. Bạn có chắc chắn muốn đóng và thêm mới người đại diện không?")) {
