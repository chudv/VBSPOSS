                @(Html.Kendo().ComboBoxFor(m => m.EntityList)
                                .Filter(FilterType.Contains)
                                .Placeholder("--- Nhóm mã quản lý ---")
                                .DataTextField("value")
                                .DataValueField("id")
                                .ClearButton(false)
                                .DataSource(source => { source.Read(read => { read.Action("GetListEntityOfUserIDC", "ListOfValue").Data("paramLoadListEntityOfUserIDC"); }).ServerFiltering(false); })
                                .HtmlAttributes(new { style = "width: 300px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                                .Suggest(true)
                                .AutoBind(true)
                                .SelectedIndex(0))
@*                 <label class="lbcontrol" style="color: navy;text-align:right;width:180px;padding-top: 7px;padding-right: 10px;">Thiết lập trạng thái thời gian</label>
                @(Html.Kendo().CheckBoxFor(m => m.RestrictionFlagCheck).Label(" ").HtmlAttributes(new { style = "margin-top:7px;" }))
 *@            </div>
        </div>
        
        <div class="row" style="margin-bottom: 15px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:7px;padding-top:3px; ">Nhóm quyền tài khoản</label>
                @(Html.Kendo().ComboBoxFor(m => m.GroupName)
                                .Filter(FilterType.Contains)
                                .Placeholder("--- Nhóm quyền ---")
                                .DataTextField("value")
                                .DataValueField("id")
                                .ClearButton(false)
                                .DataSource(source => { source.Read(read => { read.Action("GetListRoleOfUserIDC", "ListOfValue").Data("paramLoadListRoleOfUserIDC"); }).ServerFiltering(false); })
                                .HtmlAttributes(new { style = "width: 370px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                                .Events(e => e.Change("Change_RoleOfUserIDC"))
                                .Suggest(true)
                                .AutoBind(true)
                                .SelectedIndex(0))            
                <label class="lbcontrol" style="color: navy;text-align:right;width:120px;padding-top: 7px;padding-right: 10px!important;">Quyền tiền mặt</label>
                @Html.Kendo().TextBox().Name("RoleToTransferCashDescription").HtmlAttributes(new { @readonly = "readonly", style = " width: 280px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })            
            </div>
        </div>

        <div class="row" style="margin-bottom: 15px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:7px;padding-top:3px; ">Phương thức xác thực</label>
                @(Html.Kendo().ComboBoxFor(m => m.AuthsecType)
                                .DataTextField("Description")
                                .DataValueField("Code")
                                .BindTo((List<ValueConstModel>)ViewBag.AuthsecTypes)
                                .Placeholder("Chọn Phương thức xác thực")
                                .HtmlAttributes(new { style = "width: 770px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                                .Filter("contains")
                                .SelectedIndex(0))
            </div>
        </div>

        <div class="row" style="margin-bottom: 15px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
