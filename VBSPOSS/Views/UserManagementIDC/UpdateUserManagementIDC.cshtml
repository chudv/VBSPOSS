        <div class="row" style="padding-top: 5px; padding-left: 0px; padding-bottom: 0px;">
            <div class="col-md-12" style="display: inline-flex;">
                <label class="lbcontrol" style="color: maroon;text-align:left;width:500px;padding-top: 7px;">Thông tin tạo mới tài khoản người dùng Intellect iDC</label>
            </div>
        </div>
        <div class="row" style="margin-bottom: 5px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:0px;padding-top:7px; ">Tài khoản đăng nhập</label>
                @Html.Kendo().TextBoxFor(m=>m.UserId).HtmlAttributes(new { @readonly = "readonly", style = " width: 90px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
                <label class="lbcontrol" style="color: navy;text-align:right;width:75px;padding-top: 7px;padding-right: 7px;">Họ đệm </label>
                @Html.Kendo().TextBoxFor(m => m.FirstName).HtmlAttributes(new { @readonly = "readonly", style = " width: 150px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
                <label class="lbcontrol" style="color: navy;text-align:right;width:50px;padding-top: 7px;padding-right: 7px;">Tên </label>
                @Html.Kendo().TextBoxFor(m => m.LastName).HtmlAttributes(new { @readonly = "readonly", style = " width: 110px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
                <label class="lbcontrol" style="color: navy;text-align:right;width:90px;padding-top: 7px;padding-right: 7px;">Họ và tên</label>
                @Html.Kendo().TextBoxFor(m => m.FullName).HtmlAttributes(new { @readonly = "readonly", style = " width: 240px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
         </div>
        </div>
        
        <div class="row" style="margin-bottom: 5px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 170px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:0px;padding-top:7px; ">Nhóm quyền tài khoản</label>
                @(Html.Kendo().ComboBoxFor(m => m.GroupName)
                    .Filter(FilterType.Contains)
                    .Placeholder("--- Nhóm quyền ---")
                    .DataTextField("value")
                    .DataValueField("id")
                    .ClearButton(false)
                    .DataSource(source => { source.Read(read => { read.Action("GetListRoleOfUserIDC", "ListOfValue").Data("paramLoadListRoleOfUserIDC"); }).ServerFiltering(false); })
                    .HtmlAttributes(new { style = "width: 480px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                    .Events(e => e.Change("Change_RoleOfUserIDC"))
                    .Suggest(true)
                    .AutoBind(true)
                    .SelectedIndex(0))
                <label class="lbcontrol" style="color: navy;text-align:right;width:125px;padding-top: 7px;padding-right: 7px!important;">Quyền tiền mặt</label>
                @Html.Kendo().TextBox().Name("RoleToTransferCashDescription").HtmlAttributes(new { @readonly = "readonly", style = " width: 200px; !important;max-width:100% !important;color: blueviolet;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })            
            </div>
        </div>

        <div class="row" style="margin-bottom: 5px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 200px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:0px;padding-top:7px; ">Phương thức xác thực thứ 2</label>
                @(Html.Kendo().ComboBoxFor(m => m.AuthsecType)
                    .DataTextField("Description")
                    .DataValueField("Code")
                    .BindTo((List<ValueConstModel>)ViewBag.AuthsecTypes)
                    .Placeholder("Chọn Phương thức xác thực")
                    .HtmlAttributes(new { style = "width: 770px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                    .Filter("contains")
                    .SelectedIndex(0))
            </div>
        </div>

        <div class="row" style="margin-bottom: 5px; padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 200px; vertical-align: bottom;color: navy;text-align:left; padding-left:0px;padding-right:0px;padding-top:7px; ">Phương thức gửi mật khẩu</label>
                @(Html.Kendo().ComboBoxFor(m => m.MailIdFlag)
                    .DataTextField("Description")
                    .DataValueField("Code")
                    .BindTo((List<ValueConstModel>)ViewBag.MailIdFlags)
                    .Placeholder("Chọn phương thức gửi mật khẩu")
                    .HtmlAttributes(new { style = "width: 770px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;" })
                    .Filter("contains")
                    .SelectedIndex(0))
            </div>
        </div>

        <div class="row" style="margin-bottom: 5px;padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="color: navy;text-align:left;width:170px;padding-top: 7px;padding-right: 0px;"> Dải IP được truy cập </label>
                @Html.Kendo().TextBoxFor(m => m.IpSetDetail).HtmlAttributes(new { @readonly = "readonly", style = " width: 800px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 2px;padding-right: 2px;" })
            </div>
        </div>

        <div class="row" style="margin-bottom: 5px;padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 140px; vertical-align: bottom;color: navy;text-align:left;padding-top:7px;">Trạng thái bản ghi</label>
                @(Html.Kendo().ComboBoxFor(m => m.Status)
                    .Filter(FilterType.Contains)
                    .Placeholder("--- Trạng thái bản ghi ---")
                    .DataTextField("Text")
                    .DataValueField("Value")
                    .BindTo(new List<SelectListItem>() {
                        new SelectListItem() { Text = "Mở (Hoạt động)", Value = "1" },
                        new SelectListItem() { Text = "Chỉnh sửa", Value = "5" },
                        new SelectListItem() { Text = "Trình duyệt", Value = "2" },
                        new SelectListItem() { Text = "Phê duyệt cấp Chi nhánh", Value = "6" },
                        new SelectListItem() { Text = "Từ chối cấp Chi nhánh", Value = "7" },
                        new SelectListItem() { Text = "Phê duyệt cấp TTCNTT", Value = "3" },
                        new SelectListItem() { Text = "Từ chối cấp TTCNTT", Value = "4" },
                        new SelectListItem() { Text = "Đóng (Đánh dấu xóa)", Value = "0" }
                        })
                    .Suggest(true)
                    .AutoBind(true)
                    .HtmlAttributes(new { style = "padding-left: 3px;width: 250px; color: blue;", })
                    .Events(e => e.Change("Change_Status"))
                    .SelectedIndex(0)
                    )
                <label class="lbcontrol" style="color: navy;text-align:right;width:310px;padding-top: 7px;padding-right: 10px;"> Ngày hiện tại của hệ thống Intellect iDC</label>
                @Html.Kendo().TextBoxFor(m => m.BusinessDateText).HtmlAttributes(new { @readonly = "readonly", style = " width: 125px;max-width:100%;color: blueviolet;font-family:Tahoma;padding-left: 3px;padding-right: 2px;" })
            </div>
        </div>

        <div class="row" style="margin-bottom: 5px;padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 140px; vertical-align: bottom;color: navy;text-align:left;padding-top:7px;">Ngày hiệu lực</label>
                @Html.Kendo().DatePickerFor(m => m.EffectiveDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 130px;max-width:100%;font-family:Tahoma;color: blue;padding-left: 3px;padding-right: 3px;" })

                <label class="lbcontrol" style="width: 150px; vertical-align: bottom;color: navy;text-align:right; padding-left:0px;padding-right:7px;padding-top:7px;">Ngày hết hiệu lực</label>
                @Html.Kendo().DatePickerFor(m => m.ExpiryDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 130px;max-width:100%;font-family:Tahoma;color: blue;padding-left: 3px;padding-right: 3px;" })

                <label class="lbcontrol" style="width: 140px; vertical-align: bottom;color: navy;text-align:right; padding-left:0px;padding-right:7px;padding-top:7px;">Ngày bắt đầu</label>
                @Html.Kendo().DatePickerFor(m => m.StartDate).Format("dd/MM/yyyy").Min(DateTime.Today).HtmlAttributes(new { style = "width: 130px;max-width:100%;font-family:Tahoma;color: blue;padding-left: 3px;padding-right: 3px;" })

            </div>
        </div>

        <div class="row" style="padding-top: 0px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="vertical-align: bottom; color: navy;">
                <label class="lbcontrol" style="width: 140px; vertical-align: middle;color: navy;text-align:left;">Ghi chú (nếu có)</label>
                @Html.TextAreaFor(m => m.Remark, new { @class = "k-textbox", style = "padding-left: 5px;min-height:50px;width:830px;max-width:100%;color: blue;font-family:Tahoma !important;", rows = "2" })
            </div>
        </div>

        <div class="row" style="padding-top: 13px; padding-left: 10px; padding-bottom: 0px;">
            <div class="col-md-12" style="width:100%; display:flex; justify-content:flex-end;">
                <label class="control-label" id="lblMessageInfor" style="width: 750px; text-align: left; color: red;"></label>
                &nbsp;&nbsp;
                @(Html.Kendo().Button()
                    .Name("btnSaveCreateNewUserIDC")
                    .Events(ev => ev.Click("onClick"))
                    .HtmlAttributes(new { type = "submit", style = "width: 90px; font-weight:bold; color: blue;height: 25px;", title = "Cập nhật thông tin tài khoản người dùng Intellect iDC" })
                    .ImageUrl(Url.Content("~/images/save.png"))
                    .Content("Lưu lại"))
                &nbsp;
                @(Html.Kendo().Button().Name("btnThoat").Events(ev => ev.Click("onCloseUpdate")).HtmlAttributes(new { type = "button", style = "height: 25px;width: 100px; font-weight:bold; color: blue;", title = "Đóng lại màn hình cập nhật thông tin" }).ImageUrl(Url.Content("~/images/close_icon.gif")).Content("Quay ra"))
            </div>
        </div>

    </div>

</form>

<script>
