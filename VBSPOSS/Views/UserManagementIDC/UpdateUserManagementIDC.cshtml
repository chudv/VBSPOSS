    <div class="lbtitle" style="color: blue;text-align:center;padding-top: 10px;padding-bottom: 10px;font-weight: bold;">
        @{
            string title = "THÊM MỚI THÔNG TIN YÊU CẦU NGHIỆP VỤ TẠO TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC";
            if (TempData["FlagEventCall"]?.ToString() == "1")
