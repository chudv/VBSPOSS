@model VBSPOSS.ViewModels.UserManagementIDCViewModel
@using VBSPOSS.Models
@using VBSPOSS.Constants

<div id="mySppLocality"></div>

<style>
    .k-animation-container {
        z-index: 100000 !important;
    }

    .readonly-field input,
    .readonly-field .k-input,
    .readonly-field textarea {
        background-color: #f0f0f0 !important;
        color: #28a745 !important; /* Màu xanh lá */
        cursor: not-allowed !important;
    }

    .editable-field input,
    .editable-field .k-input {
        color: navy !important;
    }

    #StartDate, #ExpiryDate {
        width: 50px !important;
        max-width: 100% !important;
        font-family: Tahoma;
        padding-left: 2px;
        padding-right: 2px;
    }

</style>

<script>

    var isEditMode = false;


    (function() {
        var flagCallView = '@TempData["FlagCall"]';
        if (flagCallView === "2") {
            isEditMode = true;
        }
    })();

    function paramLoadListBranchFind() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }

    function paramLoadListStaffFind() {
        return {
            pPosCode: $("#PosCode").val(),
            pTitleChoice: "",
            pFlagTextShow: "2",
            pFlagCall: "2"
        };
    }

    function paramLoadListRoleOfUserIDC() {
        return {
            pPosCode: $("#PosCode").val(),
            pTitleChoice: "",
            pFlagShow: "3"
        };
    }

    function paramLoadListEntityOfUserIDC() {
        return {
            pPosCode: $("#PosCode").val(),
            pTitleChoice: "",
            pFlagShow: "2"
        };
    }

    function Change_PosCode() {
        var staffIdReload = $("#StaffId").data("kendoComboBox");
        if (staffIdReload != null) {
            staffIdReload.dataSource.read();
        }

        var comboGroup = $("#GroupName").data("kendoComboBox");
        if (comboGroup) {
            comboGroup.value("");
            comboGroup.dataSource.read();
            comboGroup.one("dataBound", function () {
                if (this.dataSource.data().length > 0) {
                    this.select(0);
                    Change_RoleOfUserIDC();
                }
            });
        }
    }

    var roleLists;
    function Change_RoleOfUserIDC() {
        var objGroupId = $("#GroupName").data("kendoComboBox");
        if (objGroupId != null) {
            $.ajax({
                type: "GET",
                data: {
                    pUserRole: objGroupId.value()
                },
                url: "../ListOfValue/GetRoleToTransferCashByUserRole",
                success: function (data) {
                    roleLists = data;
                    if (roleLists != null && roleLists.length != 0) {
                        $("#RoleToTransferCashDescription").val(roleLists[0].RoleToTransferCashDescription);
                        $("#RoleToTransferCashValue").val(roleLists[0].RoleToTransferCashValue);
                        //Set AuthsecType
                        var comboAuth = $("#AuthsecType").data("kendoComboBox");
                        if (comboAuth) {
                            if (roleLists[0].RoleToTransferCashValue === "Y") {
                                comboAuth.value("17");
                            } else {
                                comboAuth.value("0");
                            }
                            comboAuth.enable(false);
                        }
                    }
                }
            });
        }
    }

    var staffLists;
    function LoadStaffInfoDetail(e) {
        var objStaffId = $("#StaffId").data("kendoComboBox");
        var lcUserId = $("#UserId").val();
        var lcFirstName = $("#FirstName").val();
        var lcLastName = $("#LastName").val();
        if (objStaffId != null) {
            var lcStaffId = $("#StaffId").val(); // Lấy ID của thành viên =>Load thông tin ra theo ID này
            if (lcStaffId != null && lcStaffId != "" && lcStaffId != "0") {
                $.ajax({
                    type: "GET",
                    data: {
                        pStaffId: lcStaffId
                    },
                    url: "../ListOfValue/GetListStaffVBSPByStaffId",
                    success: function (data) {
                        staffLists = data;
                        if (staffLists != null && staffLists.length != 0) {
                            if (!lcUserId || lcUserId.trim() === "") {
                                $("#UserId").val(staffLists[0].StaffCode);
                            }
                            if (staffLists[0].StaffName && staffLists[0].StaffName.trim() !== "") {
                                var fullName = staffLists[0].StaffName.trim();
                                var nameParts = fullName.split(/\s+/);
                                var lastName = nameParts.pop();
                                var firstName = nameParts.join(" ");
                                if (!lcFirstName || lcFirstName.trim() === "") {
                                    $("#FirstName").val(firstName);
                                }
                                if (!lcLastName || lcLastName.trim() === "") {
                                    $("#LastName").val(lastName);
                                }
                            }
                            $("#StaffCode").val(staffLists[0].StaffCode);
                            $("#Genders").val(staffLists[0].GenderText);
                            $("#DateOfBirth").val(staffLists[0].DateOfBirthText);
                            $("#PosName").val(staffLists[0].StaffPosName);
                            $("#StaffDepartmentName").val(staffLists[0].StaffDepartmentName);
                            $("#StaffPositionName").val(staffLists[0].StaffPositionName);
                            $("#MobileNumber").val(staffLists[0].StaffMobileNo);
                            $("#EmailAddress").val(staffLists[0].StaffEmail);
                            $("#StaffPosCode").val(staffLists[0].StaffPosCode);
                            $("#StaffDepartmentCode").val(staffLists[0].StaffDepartmentCode);
                            $("#StaffPositionCode").val(staffLists[0].StaffPositionCode);
                            $("#FullName").val(staffLists[0].StaffName);
                        }
                    }
                });
            }
        }
    }

    function onCloseUpdate(ev) {
        mainWindow.data("kendoWindow").close();
    }


    function Change_Status(e) {

        if (!isEditMode) return;

        var statusDDL = $("#Status").data("kendoDropDownList");
        var statusValue = statusDDL.value();


        if (statusValue === "0") {
            var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
            if (expirePicker) {

                expirePicker.value(new Date());


                expirePicker.enable(true);
            }
        }
    }

    function onClick(e) {
        var lcPosCode = $("#PosCode").val();
        var lcStaffId = $("#StaffCode").val();
        if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
            alert('Phòng giao dịch/Hội sở tỉnh không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#PosCode').focus();
            e.preventDefault();
            return false;
        }
        if (lcStaffId == null || lcStaffId == "") {
            alert('Cán bộ được phân giao quản lý địa bàn không được để trống. Bạn vui lòng kiểm tra lại!');
            $('#StaffCode').focus();
            e.preventDefault();
            return false;
        }
        // var effectPicker = new Date();
        // var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
        // if (effectPicker && expirePicker) {
        //     var dEffectDate = effectPicker.value();
        //     var dExpiryDate = expirePicker.value();
        //     if (dEffectDate && dExpiryDate && dEffectDate > dExpiryDate) {
        //         alert('Ngày hết hiệu lực nhỏ hơn ngày hiện tại. Bạn vui lòng kiểm tra lại!');
        //         $('#ExpiryDate').focus();
        //         e.preventDefault();
        //         return false;
        //     }
        // }
    }

    function setEditMode() {
        isEditMode = true;

        $("#PosCode").closest(".k-combobox").css("pointer-events", "none").addClass("readonly-field");
        $("#StaffId").closest(".k-combobox").css("pointer-events", "none").addClass("readonly-field");
        var checkInterval = setInterval(function() {
            var posCodeCombo = $("#PosCode").data("kendoComboBox");
            var staffIdCombo = $("#StaffId").data("kendoComboBox");

            if (posCodeCombo && staffCodeCombo &&
                posCodeCombo.dataSource.data().length > 0 &&
                staffIdCombo.dataSource.data().length > 0) {

                clearInterval(checkInterval);

                posCodeCombo.enable(false);
                posCodeCombo.wrapper.css("pointer-events", "none").addClass("readonly-field");

                staffIdCombo.enable(false);
                staffIdCombo.wrapper.css("pointer-events", "none").addClass("readonly-field");

                var birthdayPicker = $("#DateOfBirth").data("kendoDatePicker");
                if (birthdayPicker) {
                    birthdayPicker.enable(false);
                    birthdayPicker.wrapper.addClass("readonly-field");
                }

                var genderDDL = $("#Genders").data("kendoDropDownList");
                if (genderDDL) {
                    genderDDL.enable(false);
                    genderDDL.wrapper.addClass("readonly-field");
                }

                var masked = $("#MobileNumber").data("kendoMaskedTextBox");
                if (masked) {
                    masked.enable(false);
                    masked.wrapper.addClass("readonly-field");
                }

                var emailTextBox = $("#EmailAddress").data("kendoTextBox");
                if (emailTextBox) {
                    emailTextBox.enable(false);
                    emailTextBox.wrapper.addClass("readonly-field");
                } else {
                    $("#EmailAddress").prop('readonly', true).parent().addClass("readonly-field");
                }

                var expirePicker = $("#ExpiryDate").data("kendoDatePicker");
                if (expirePicker) {
                    expirePicker.enable(true);
                    expirePicker.wrapper.removeClass("readonly-field").addClass("editable-field");
                }
                $("#Remark").prop('readonly', false).removeClass("readonly-field").addClass("editable-field");
            }
        }, 100);

        setTimeout(function() {
            clearInterval(checkInterval);
        }, 5000);
    }

    var lcButton = "";
</script>

<form asp-controller="UserManagementIDC" asp-action="SaveUpdate" data-ajax="true" data-ajax-method="POST" id="form0" enctype="multipart/form-data">
 <input type="hidden" id="pFlagCall" name="pFlagCall" /> <input type="hidden" id="pButtonType" name="pButtonType" />
    @Html.Hidden("FlagCallView", TempData["FlagCall"]) 
    @Html.Hidden("ButtonTypeView", TempData["ButtonType"])
    @Html.HiddenFor(m => m.RoleToTransferCashValue, new { @Value = Model == null ? "" : Model.RoleToTransferCashValue })
    @Html.HiddenFor(m => m.NickName, new { @Value = Model == null ? "" : Model.NickName })
    @Html.HiddenFor(m => m.FullName, new { @Value = Model == null ? "" : Model.FullName })
    @Html.HiddenFor(m => m.Id, new { @Value = Model == null ? 0 : Model.Id })
    @Html.HiddenFor(m => m.AuthType, new { @Value = Model == null ? "" : Model.AuthType })
    @Html.HiddenFor(m => m.UserType, new { @Value = Model == null ? "" : Model.UserType })
    @Html.HiddenFor(m => m.ExtraAttributeUserRole, new { @Value = Model == null ? "" : Model.ExtraAttributeUserRole })
    @Html.HiddenFor(m => m.ExtraAttributeBranchCode, new { @Value = Model == null ? "" : Model.ExtraAttributeBranchCode })
