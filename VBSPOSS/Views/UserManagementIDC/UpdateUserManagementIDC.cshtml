                title = "THÊM MỚI THÔNG TIN YÊU CẦU NGHIỆP VỤ TẠO TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC";
            }
            else if (TempData["FlagEventCall"]?.ToString() == "2")
            {
                title = "CHỈNH SỬA THÔNG TIN BẢN GHI YÊU CẦU NGHIỆP VỤ TẠO TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC";
            }
            else if (TempData["FlagEventCall"]?.ToString() == "6")
            {
                title = "XEM CHI TIẾT THÔNG TIN BẢN GHI YÊU CẦU NGHIỆP VỤ TẠO TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC";
            }
            @title
        }
    </div>
    <hr style='margin-top: 0em; margin-bottom: 0.3em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />
