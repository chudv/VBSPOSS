<style>
    .k-animation-container {
        z-index: 100000 !important;
    }

    .readonly-field input,
    .readonly-field .k-input,
    .readonly-field textarea {
        background-color: #f0f0f0 !important;
        color: #28a745 !important; /* Màu xanh lá */
        cursor: not-allowed !important;
    }

    .editable-field input,
    .editable-field .k-input {
        color: navy !important;
    }

    #StartDate, #ExpiryDate, #EndDateChangeRole, #EffectiveDate, #BusinessDate, #DateOfBirth {
        width: 50px !important;
        max-width: 100% !important;
        font-family: Tahoma;
        font-size:13px;
        padding-left: 2px;
        padding-right: 2px;
    }

    .hidden-block {
        display: none !important;
    }
</style>

<script>
    function stringToDate(_date, _format, _delimiter) {
        var formatLowerCase = _format.toLowerCase();
        var formatItems = formatLowerCase.split(_delimiter);
        var dateItems = _date.split(_delimiter);
        var monthIndex = formatItems.indexOf("mm");
        var dayIndex = formatItems.indexOf("dd");
        var yearIndex = formatItems.indexOf("yyyy");
        var month = parseInt(dateItems[monthIndex]);
        month -= 1;
        var formatedDate = new Date(dateItems[yearIndex], month, dateItems[dayIndex]);
        return formatedDate;
    }

    function paramLoadListBranchFind() {
        return {
            pFlagCondi: "5",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "2",
            pUserPosCode: "ALL",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }

    function paramLoadListStaffFind() {
        return {
            pPosCode: $("#PosCode").val(),
            pTitleChoice: "",
            pFlagTextShow: "2",
            pFlagCall: "2"
        };
    }

    function paramLoadListRoleOfUserIDC() {
        return {
            pPosCode: $("#UserPosCodeView").val(),
            pTitleChoice: "",
            pFlagShow: "3"
        };
    }
    //Xét giá trị cho PosName khi thay đổi đơn vị
    function Change_PosCode() {
        var objPosCode = $("#PosCode").data("kendoComboBox");
        var dataItemPosCode = objPosCode.dataItem();
        if (dataItemPosCode) {
            var lcPosNameText = dataItemPosCode.value.trim();
            let indexSpace = lcPosNameText.lastIndexOf(" - ");
            var lcPosName = lcPosNameText;
            if(indexSpace >= 0)
                lcPosName = lcPosNameText.substring(indexSpace + 3).trim();
            $("#PosName").val(lcPosName);
        }
    }

    //Sự kiện thay đổi Nghiệp vụ yêu cầu với Tài khoản người dùng: Cấp lại mật khẩu | Mở lại người dùng | Khóa người dùng | Thay đổi thông tin người dùng | 
    //                                                             Thay đổi POS người dùng | Thay đổi quyền/vài trò người dùng
    function Change_FunctionType() {
        var objFunctionTypeSelect = $("#FunctionType").data("kendoComboBox");
        var lcFunctionTypeName = objFunctionTypeSelect.text();
        $("#FunctionTypeName").val(lcFunctionTypeName);

        $("#ckb_EndDateChangeRole").hide();
        $("#lblEndDateChangeRole").hide();
        $("#EndDateChangeRole").closest(".k-datepicker").hide();
        var lcFunctionType = $("#FunctionType").val();
        if(lcFunctionType == $("#FunctionTypeFlag_ADDNEW_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_ResetPasswordView").val()
            || lcFunctionType == $("#FunctionTypeFlag_ENABLE_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_DISABLE_USERView").val()) 
        {
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_MODIFY_USERView").val()) {
            $("#divPosCode").hide();
            $("#divModify").show();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_POSView").val()) {
            $("#divPosCode").show();
            $("#divModify").hide();
            $("#divRole").hide();
        }
        else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_ROLEView").val()) {
            $("#divPosCode").hide();
            $("#divModify").hide();
            $("#divRole").show();
            $("#ckb_EndDateChangeRole").show();
            $("#lblEndDateChangeRole").show();
            $("#EndDateChangeRole").closest(".k-datepicker").show();
        }
    }

    var roleLists;
    function Change_RoleOfUserIDC() {
        
        var objGroupNameSelect = $("#GroupName").data("kendoComboBox");
        var lcGroupNameText = objGroupNameSelect.text();
        $("#GroupNameText").val(lcGroupNameText);

        var objGroupId = $("#GroupName").val();
        if (objGroupId != null) {
            $.ajax({
                type: "GET",
                data: {
                    pUserRole: objGroupId
                },
                url: "../ListOfValue/GetRoleToTransferCashByUserRole",
                success: function (data) {
                    roleLists = data;
                    if (roleLists != null && roleLists.length != 0) {
                        $("#RoleToTransferCashDescription").val(roleLists[0].RoleToTransferCashDescription);
                        $("#RoleToTransferCashValue").val(roleLists[0].RoleToTransferCashValue);
                        $("#RoleToTransferCashDescriptionDetail").val(roleLists[0].RoleToTransferCashDescription);
                        $("#UserRoleNameChange").val(roleLists[0].UserRoleName);
                        if (roleLists[0].RoleToTransferCashValue == "Y")
                            $("#RoleToTransferCashName").val("X");
                        else $("#RoleToTransferCashName").val("");
                    }
                }
            });
        }
    }

    function onCloseCreateChange(ev) {
        mainWindow.data("kendoWindow").close();
    }

    function getCurrentDate() {
        var today = new Date();

        // Format: dd/MM/yyyy
        var day = String(today.getDate()).padStart(2, '0');
        var month = String(today.getMonth() + 1).padStart(2, '0');
        var year = today.getFullYear();

        return `${day}/${month}/${year}`;
    }

    function onClickCreateChange(e) {
        var lcFunctionType = $("#FunctionType").val();
        var lcFunctionTypeName = $("#FunctionTypeName").val();
        var lcFullName = $("#FullName").val();
        var lcUserId = $("#UserId").val();
        var lcStartDate = $("#StartDate").val();
        var dStartDate = stringToDate(lcStartDate, "dd/MM/yyyy", "/");
        var lcBusinessDate = $("#BusinessDate").val();
        var dBusinessDate = stringToDate(lcBusinessDate, "dd/MM/yyyy", "/");
        var lcAuthsecType = $("#AuthsecType").val();
        var lcUserStatus = $("#UserStatus").val();              //Trạng thái người dùng. Giá trị: 1- Đóng/Khóa; 2 - Mở/Active
        var lcUserStatusText = $("#UserStatusText").val();      //Trạng thái người dùng. Giá trị: 1- Đóng/Khóa; 2 - Mở/Active
        var lcExpiryDate = $("#ExpiryDate").val();
        var dExpiryDate = stringToDate(lcExpiryDate, "dd/MM/yyyy", "/");
        var lcCurrentDateTmp = getCurrentDate();
        var dCurrentDateTmp = stringToDate(lcCurrentDateTmp, "dd/MM/yyyy", "/");
        
        var lcEndDateChangeRole = $("#EndDateChangeRole").val();
        var dEndDateChangeRole = stringToDate(lcEndDateChangeRole, "dd/MM/yyyy", "/");
        var lcExistsInCore = $("#ExistsInCore").val();
        if (lcExistsInCore == 0) {
            alert("Tài khoản người dùng [" + lcUserId + "] không tồn tại trong hệ thống Intellect iDC, không thể thực hiện yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
            $('#EffectiveDate').focus();
            e.preventDefault();
            return false;
        }
        if (dStartDate < dBusinessDate) {
            alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC có ngày bắt đầu [" + lcStartDate + "] nhỏ hơn ngày hiện tại của hệ thống Intelect iDC [" +  lcBusinessDate + "]. Vui lòng kiểm tra lại!");
            $('#EffectiveDate').focus();
            e.preventDefault();
            return false;
        }
        if (lcFunctionType == $("#FunctionTypeFlag_ResetPasswordView").val())
        {
            if (lcAuthsecType == "17")
            {
                alert("Tài khoản người dùng [" + lcUserId + " - " + lcFullName + "] có phương thức xác thực thứ 2 là OTP nên không thể thực hiện tạo yêu cầu cấp lại mật khẩu. Vui lòng kiểm tra lại!");
                $('#FunctionType').focus();
                e.preventDefault();
                return false;
            }
        }
        if (lcFunctionType == $("#FunctionTypeFlag_DISABLE_USERView").val())
        {
            //Nếu chọn nghiệp vụ KHÓA user => List danh sách user đang ở trạng thái active (USER_STATUS=2) ;
            if (lcUserStatus != "2")
            {
                alert("Tài khoản người dùng [" + lcUserId + " - " + lcFullName + "] có trạng thái [" + lcUserStatusText + "], không thể thực hiện yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
                $('#FunctionType').focus();
                e.preventDefault();
                return false;
            }
        }
        if (lcFunctionType == $("#FunctionTypeFlag_ENABLE_USERView").val())
        {
            //Nếu chọn nghiệp vụ MỞ KHÓA user => List danh sách user đang ở trạng thái Disable (USER_STATUS = 1 và ExpiryDate> SysDate).
            if (lcUserStatus != "1")
            {
                alert("Tài khoản người dùng [" + lcUserId + " - " + lcFullName + "] có trạng thái [" + lcUserStatusText + "], không thể thực hiện yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
                $('#FunctionType').focus();
                e.preventDefault();
                return false;
            }
            if (dExpiryDate < dBusinessDate)
            {
                alert("Tài khoản người dùng [" + lcUserId + " - " + lcFullName + "] có ngày hết hiệu lực [" + lcExpiryDate + "] nhỏ hơn ngày hiện thời của hệ thống Intellect [" + lcBusinessDate + "], không thể thực hiện yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
                $('#FunctionType').focus();
                e.preventDefault();
                return false;
            }
            if (dExpiryDate < dCurrentDateTmp)
            {
                alert("Tài khoản người dùng [" + lcUserId + " - " + lcFullName + "] có ngày hết hiệu lực [" + lcExpiryDate + "] nhỏ hơn ngày hiện tại [" + lcCurrentDateTmp + "], không thể thực hiện yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
                $('#FunctionType').focus();
                e.preventDefault();
                return false;
            }
        }
        if (lcFunctionType == $("#FunctionTypeFlag_MODIFY_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_CHANGE_POSView").val() ||
            lcFunctionType == $("#FunctionTypeFlag_CHANGE_ROLEView").val())
        {
            //Ngày bắt đầu hiệu lực: Dữ liệu nhập tay (DD/MM/YYYY) >= giá trị ngày hiện tại, giá trị bắt buộc
            //Đến hết ngày: Dữ liệu nhập tay (DD/MM/YYYY) >= Ngày bắt đầu hiệu lực, giá trị không bắt buộc. Ngày liền sau “Đến hết ngày” hệ thống tự động xử lý cho user về quyền cũ.
            //Khi submit: hệ thống check đảm bảo user đề nghị đổi quyền KHÔNG mở tiền mặt (script_check_OpenCash), nếu user mở tiền mặt báo lỗi.
            if (dStartDate < dCurrentDateTmp) {
                alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC có ngày bắt đầu [" + lcStartDate + "] nhỏ hơn ngày hiện tại [" + lcCurrentDateTmp + "]. Vui lòng kiểm tra lại!");
                $('#EffectiveDate').focus();
                e.preventDefault();
                return false;
            }
            var checkedEndDateChangeRole = $("#ckb_EndDateChangeRole").is(":checked");
            if(checkedEndDateChangeRole)
            {
                if (dEndDateChangeRole < dStartDate)
                {
                    alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC có ngày bắt đầu [" + lcStartDate + "] lớn hơn ngày kết thúc [" + lcEndDateChangeRole + "]. Vui lòng kiểm tra lại!");
                    $('#EndDateChangeRole').focus();
                    e.preventDefault();
                    return false;
                }
            }
        }
        if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_POSView").val())
        {
            var lcPosCode = $("#PosCode").val();
            var lcPosCodeOld = $("#PosCodeOld").val();
            if (lcPosCode == null || lcPosCode == "" || lcPosCode == "0" || lcPosCode == "000000") {
                alert('Đơn vị mới của người dùng cần thay đổi POS không được để trống. Vui lòng kiểm tra lại!');
                $('#PosCode').focus();
                e.preventDefault();
                return false;
            }
            if (lcPosCode == lcPosCodeOld)
            { 
                alert("Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản người dùng Intellect iDC, nhưng đơn vị mới [" + lcPosCode + "] và đơn vị hiện tại [" + lcPosCodeOld + "] của người dùng giống nhau. Vui lòng kiểm tra lại!");
                $('#PosCode').focus();
                e.preventDefault();
                return false;
            }
        }
    }

    function Checked_EndDateChangeRole() {
        var checkedEndDateChangeRole = $("#ckb_EndDateChangeRole").is(":checked");
        var objEndDateChangeRole = $("#EndDateChangeRole").data("kendoDatePicker");
        if (checkedEndDateChangeRole) {
            objEndDateChangeRole.enable(true);
            $("#ChoiceEndDateChangeRole").val(1);
        }
        else {
            objEndDateChangeRole.enable(false);
            $("#ChoiceEndDateChangeRole").val(0);
        }
    }
</script>

