<script>
    $(function () {
        $("#formCreateChangeInforUserManagementIDC").submit(function (event) {
            event.preventDefault();
            var frmCreateChangeInforUserManagementIDC = this;
            
            submitFormAjax(frmCreateChangeInforUserManagementIDC);
            return false;
        });
    });

    function submitFormAjax(form) {
        var dataString;
        var contentType;
        var processData;
        if (form.enctype === "multipart/form-data") {
            dataString = new FormData($(form).get(0));
            contentType = false;
            processData = false;
        }
        $.ajax({
            url: form.action,
            type: form.method,
            dataType: "json",
            contentType: contentType,
            processData: processData,
            data: dataString,
            success: function (result) {
                var lcFunctionTypeName = $("#FunctionTypeName").val();
                var lcFullName = $("#FullName").val();
                var lcUserId = $("#UserId").val();
                var lcUserStatusText = $("#UserStatusText").val();
                var lcExpiryDate = $("#ExpiryDate").val();
                var lcCurrentDateTmp = getCurrentDate();
                var lcBusinessDate = $("#BusinessDate").val();
                var lcStartDate = $("#StartDate").val();
                var lcEndDateChangeRole = $("#EndDateChangeRole").val();
                var lcPosCode = $("#PosCode").val();
                var lcPosCodeOld = $("#PosCodeOld").val();
                var lcEmailAddress = $("#EmailAddress").val();
                var lcMobileNumber = $("#MobileNumber").val();
                var lcRowId = $("#Id").val();

                if (result == "0") {
                    if (lcRowId <= 0)
                        alert("Bạn đã cập nhật thành công Thêm mới Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] của tài khoản [" + lcUserId + "] người dùng Intellect iDC!");
                    else alert("Bạn đã cập nhật thành công chỉnh sửa Yêu cầu nghiệp vụ [" + lcFunctionTypeName + "] tài khoản [" + lcUserId + "] người dùng Intellect iDC!");
                    dataChange = true;
                    onCloseCreateChange();
                }
                else {
                    dataChange = false;
                    if (result == "15")
                        alert("Yêu cầu tạo mới tài khoản người dùng nhưng trạng thái bản ghi là đóng. Vui lòng kiểm tra lại!");
                    else if (result == "1")
                        alert("Mã đơn vị của tài khoản người dùng Intellect iDC không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "2")
                        alert("Mã cán bộ của tài khoản người dùng Intellect iDC không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "14")
                        alert("Số điện thoại của người dùng không được để trống. Vui lòng kiểm tra lại!");
                    else if (result == "3")
                        alert("Tài khoản người dùng có ngày hiệu lực [" + $("#EffectiveDate").val() + "] bằng ngày hết hiệu lực [" + $("#ExpiryDate").val() + "]!. Vui lòng kiểm tra lại!");
                    else if (result == "4")
                        alert("Tài khoản người dùng có ngày hiệu lực [" + $("#EffectiveDate").val() + "] lớn hơn ngày hết hiệu lực [" + $("#ExpiryDate").val() + "]. Vui lòng kiểm tra lại!");
                    else if (result == "5")
                        alert("Tài khoản người dùng có phương thức xác thực khi đăng nhập là OTP nên không thể thực hiện tạo yêu cầu nghiệp vụ [" + lcFunctionTypeName + "]. Vui lòng kiểm tra lại!");
                        //alert("Tài khoản người dùng có phương thức xác thực khi đăng nhập là OTP nên không thể thực hiện tạo yêu cầu cấp lại mật khẩu. Vui lòng kiểm tra lại!");
                    else if (result == "6")
