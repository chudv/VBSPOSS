    <div class="lbtitle" style="color: blue;text-align:center;padding-top: 3px;padding-bottom: 3px;font-weight: bold;">
        @* @(TempData["FlagEventCall"]?.ToString() == "7" ? "YÊU CẦU NGHIỆP VỤ THAY ĐỔI THÔNG TIN NGƯỜI DÙNG INTELLECT IDC" : "CHI TIẾT THÔNG TIN NGƯỜI DÙNG INTELLECT IDC") *@
        <div class="lbtitle" style="color: blue;text-align:center;padding-top: 5px;padding-bottom: 5px;font-weight: bold;">
            @{
                string title = "YÊU CẦU NGHIỆP VỤ THAY ĐỔI THÔNG TIN NGƯỜI DÙNG INTELLECT IDC";
                if (TempData["FlagEventCall"]?.ToString() == "1" || TempData["FlagEventCall"]?.ToString() == "7")
                {
                    title = "THÊM MỚI YÊU CẦU NGHIỆP VỤ THAY ĐỔI THÔNG TIN NGƯỜI DÙNG INTELLECT IDC";
                }
                else if (TempData["FlagEventCall"]?.ToString() == "2")
                {
                    title = "CHỈNH SỬA THÔNG TIN BẢN GHI YÊU CẦU NGHIỆP VỤ THAY ĐỔI THÔNG TIN NGƯỜI DÙNG INTELLECT IDC";
                }
                else if (TempData["FlagEventCall"]?.ToString() == "6")
