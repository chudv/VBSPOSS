    $(document).ready(function () {
        //Xoa_Change_RoleOfUserIDCStart();
        //Xoa_LoadStaffInfoDetail();
        var lcButtonType = $("#ButtonTypeView").val();
        var lcFunctionType = $("#FunctionType").val();

        var iChoiceEndDateChangeRole = $("#ChoiceEndDateChangeRole").val();
        var objEndDateChangeRole = $("#EndDateChangeRole").data("kendoDatePicker");

        if (iChoiceEndDateChangeRole == 0) {
            $("#ckb_EndDateChangeRole").prop('checked', false);
            objEndDateChangeRole.enable(false);
        }
        else {
            $("#ckb_EndDateChangeRole").prop('checked', true);
            objEndDateChangeRole.enable(true);
        }
        $("#ckb_EndDateChangeRole").hide();
        $("#lblEndDateChangeRole").hide();
        $("#EndDateChangeRole").closest(".k-datepicker").hide();
        // if (lcButtonType == "14"){
        //     $("#divChange").hide();
        // }

        var lcFlagCall = $("#FlagCall").val();
        if (lcFlagCall == $("#EventFlag_EditView").val() && lcButtonType == $("#EventFlag_EditIDCView").val())
        {
            //$("#FunctionType").data("kendoComboBox").enable(false);
            var cboFunctionType = $("#FunctionType").data("kendoComboBox");
            cboFunctionType.readonly(true);
        }
        if (lcButtonType != $("#EventFlag_EditIDCView").val())
        {
            if (lcFlagCall != $("#EventFlag_EditView").val())
                $("#divChange").hide();
        }
        else {
            if (lcFunctionType == $("#FunctionTypeFlag_ADDNEW_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_ResetPasswordView").val()
                    || lcFunctionType == $("#FunctionTypeFlag_ENABLE_USERView").val() || lcFunctionType == $("#FunctionTypeFlag_DISABLE_USERView").val()) {
                $("#divPosCode").hide();
                $("#divModify").hide();
                $("#divRole").hide();
            }
            else if (lcFunctionType == $("#FunctionTypeFlag_MODIFY_USERView").val()) {
                $("#divPosCode").hide();
                $("#divModify").show();
                $("#divRole").hide();
            }
            else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_POSView").val()) {
                $("#divPosCode").show();
                $("#divModify").hide();
                $("#divRole").hide();
            }
            else if (lcFunctionType == $("#FunctionTypeFlag_CHANGE_ROLEView").val()) {
                $("#divPosCode").hide();
                $("#divModify").hide();
                $("#divRole").show();

                $("#ckb_EndDateChangeRole").show();
                $("#lblEndDateChangeRole").show();
                $("#EndDateChangeRole").closest(".k-datepicker").show();
            }
        }
       
        //Nếul à xem thì readonly các control và Hide nút lệnh Lưu
        if (lcFlagCall == $("#EventFlag_ViewView").val())
        {
            var cboFunctionType = $("#FunctionType").data("kendoComboBox");
            cboFunctionType.readonly(true);

            var dtpkStartDate = $("#StartDate").data("kendoDatePicker");
            dtpkStartDate.readonly(true);        // ← Cách tốt nhất
            
            var edtMobileNumber = $("#MobileNumber").data("kendoMaskedTextBox");
            edtMobileNumber.readonly(true);

            var txtEmailAddress = $("#EmailAddress").data("kendoTextBox");
            txtEmailAddress.readonly(true);

            var cboGroupName = $("#GroupName").data("kendoComboBox");
            cboGroupName.readonly(true);
            
            $("#Remark").prop("readonly", true)
            
            $("#btnSaveCreateChange").hide();                    // Cách đơn giản nhất
        }

    });

</script>