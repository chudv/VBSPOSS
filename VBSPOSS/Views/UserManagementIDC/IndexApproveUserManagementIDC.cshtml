@Html.Hidden("UserPosCodeView", TempData["UserPosCode"])
@Html.Hidden("UserNameView", TempData["UserName"])
@Html.Hidden("ProductGroupCodeView", TempData["ProductGroupCode"])
<hr style='margin-top: 0.2em; margin-bottom: 0.3em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />

<div style="flex-grow: 1; display: flex; flex-direction: column; ">
    <div class="row" style="color: navy; padding-top: 0px;padding-bottom: 0px;">

        <div class="col-md-12">
            <label class="lbcontrol" style="color: navy;text-align:left;width:60px;padding-top:3px;padding-right:0px;padding-left:5px;font-family:Tahoma;font-size:12px;">Đơn vị</label>
            @(Html.Kendo().ComboBox().Name("MainPosCode_Find")
                        .Filter(FilterType.Contains)
                        .Placeholder("--- Đơn vị ---")
                        .DataTextField("value")
                        .DataValueField("id")
                        .Events(e => e.Change("Change_PosCode"))
                        .ClearButton(false)
                        .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramLoadListBranchFind"); }).ServerFiltering(false); })
                        .HtmlAttributes(new { style = "width: 250px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                        .Suggest(true)
                        .AutoBind(true)
                        .SelectedIndex(0))

            <label class="lbcontrol" style="color: navy;text-align:right;width:100px;padding-top:3px;padding-right:6px;font-family:Tahoma;font-size:12px;">Ngày hiệu lực</label>
            @(Html.Kendo().DatePicker()
                        .Name("EffectDate_Find")
                        .Format("dd/MM/yyyy")
                        .HtmlAttributes(new { style = "background-color: While !important; width: 105px !important; color: green; !important;", title = "Từ ngày cần tìm kiếm" })
                        .Value(DateTime.Today.AddDays(-1))
                        )
            <span style="color: #ca8f5c;" for="DonVi_Cd_TimKiem">&nbsp;-&nbsp;</span>
            @(Html.Kendo().DatePicker()
                        .Name("ExpiryDate_Find")
                        .Format("dd/MM/yyyy")
                        .HtmlAttributes(new { style = "background-color: While !important; width: 105px !important; color: green; !important;", title = "Đến ngày cần tìm kiếm" })
                        .Value(DateTime.Today.AddDays(+1))
                        )

            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                        .Name("btnSearchTidePenalRate")
                        .Events(ev => ev.Click("onSearchTidePenalRate"))
                        .HtmlAttributes(new { type = "button", style = "font-weight:bold; width:100px; color: blue;padding-left: 0px; height: 25px;", title = "Tìm kiếm danh sách quyết định cấu hình lãi suất rút trước hạn TG CKH" })
                        .ImageUrl(Url.Content("~/images/tim_kiem.png"))
                        .Content(" Tìm kiếm "))
        </div>
    </div>


    <div style="color: navy; padding-top: 0px; display:flex;" class="row">
        <div class="col-md-12">
            @(Html.Kendo().Grid<VBSPOSS.ViewModels.UserIDCApprovalViewModel>()
                        .Name("gridMainIDC")
                        .Events(e => e.DataBound("onRowBoundIDC"))
                        .Columns(columns =>
                        {
                            columns.Command(command =>
                            {
                                command.Custom("Approval").Text("<span style='color: blue;'></span>").Click("submitForApproval").HtmlAttributes(new
                                {
                                    style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                                    title = "Trình duyệt người dùng IDC",
                                    @class = "btn-approval-main"
                                });
                                command.Custom("Authorize").Text("<span style='color: blue;'></span>").Click("submitForAuthorize").HtmlAttributes(new
                                {
                                    style = "width: 20px !important; display: inline-block; vertical-align: middle;",
                                    title = "Phê duyệt người dùng IDC",
                                    @class = "btn-auth-main"
                                });
                            }).Width(100).Title("Chức năng").HtmlAttributes(new { style = "text-align: center;" });

                            columns.Bound(c => c.STT).Title("STT").Width(50).HtmlAttributes(new { style = "text-align: center;" });
                            columns.Bound(c => c.TenChiNhanh).Title("Đơn vị").Width(200).HtmlAttributes(new { style = "text-align: center;" });
                            columns.Bound(c => c.KhoangThoiGian).Title("Khoảng thời gian").Width(200).HtmlAttributes(new { style = "text-align: center;" });
                            columns.Bound(c => c.SoLgTrinh_ThemMoi).Title("Thêm mới").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_Matkhau).Title("Đổi mật khẩu").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_MoKhoa).Title("Mở khóa người dùng").Width(150).HtmlAttributes(new { style = "text-align: center;" });
                            columns.Bound(c => c.SoLgTrinh_Khoa).Title("Khóa người dùng").Width(120).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_Edit).Title("Chỉnh sửa").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_ChangePos).Title("Đổi POS").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_ChangeRole).Title("Đổi quyền").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.SoLgTrinh_Delete).Title("Hủy User").Width(90).HtmlAttributes(new { style = "text-align: left;" });
                            columns.Bound(c => c.KieuIn).Hidden();
                            columns.Bound(c => c.TT_Dong).Hidden();
                            columns.Bound(c => c.MaDonVi).Hidden();
                        })
                        .HtmlAttributes(new { style = "height: 550px;color: navy; border: 1px solid #ddd;" })
                        .ToolBar(toolbar =>
                        {
                            toolbar.Excel().HtmlAttributes(new { id = "btnExportExcel", style = "height: 25px;width: 110px; font-weight:bold; color: blue;font-family:Tahoma; font-size: 12px;font-weight:bold;!important;", title = "Xuất dữ liệu trên lưới ra file excel" }).Text("Xuất excel");
                        })
                        .Excel(excel => excel.FileName("Danh sach nguoi dung IDC.xlsx").AllPages(true))
                        .Editable(editable => { editable.Mode(GridEditMode.InLine); })
                        .Sortable()
                        .Scrollable()
                        .Pageable(pageable => pageable.Refresh(true).ButtonCount(5))
                        .DataSource(dataSource => dataSource
                        .Ajax()
                        .Batch(false)
                        .ServerOperation(false)
                        .Model(model => model.Id(p => p.STT))
                        .Events(e => e.RequestEnd("onSaveGridIDC").Error("error_handlerIDC"))
                        .Read(read => read.Action("LoadGridData_UserIDCApproval", "UserManagementIDC").Data("paramLoadGridData"))
                        .PageSize(100)
                        )
                        .Resizable(resize => resize.Columns(true))
                        .AutoBind(false)
                        )
        </div>
    </div>


</div>


<script>
     function onSaveGridIDC(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {
                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_handlerIDC(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
            console.error("Kendo Grid Error:", e.errors);  // Debug console để xem lỗi backend (F12)
        }
    }

    $(document).ready(function () {
        $("#lbl_space").remove();
        $("#gridMainIDC .k-grid-excel").after("<label id='lbl_space' style='padding-top:5px;padding-left: 10px;width:70%; font-size: 11px; font-weight: bold; color: blue;text-align:center;line-height: 25px;'>DANH SÁCH THÔNG TIN NGƯỜI DÙNG IDC</label>");

    });
</script>