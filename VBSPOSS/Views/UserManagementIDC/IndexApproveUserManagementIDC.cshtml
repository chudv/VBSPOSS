    function openApprovalWindow(dataItem, buttonType, title) {
        var wnd = mainWindow.data("kendoWindow");
        if (!wnd) {
            mainWindow.kendoWindow({
                width: "1050px",
                height: "550px",
                resizable: false,
                visible: false,
                modal: true,
                close: onClose,
                actions: ["Refresh", "Close"]
            });

            wnd = mainWindow.data("kendoWindow");
        }
        wnd.title(title);
        wnd.refresh({
            url: '@Url.Action("ShowApprovalUserIDC", "UserManagementIDC")',
            data: {
                pPosCode: dataItem.MaDonVi,
                pUserId: "",
                pFlagCall: "2",
                pButtonType: buttonType
            }
        });
        wnd.center().open();
    }

