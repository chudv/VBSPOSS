@using Kendo.Mvc
@using VBSPOSS.Extensions
@using VBSPOSS.Models

@{
    var userPermission = TempData.Get<RolePermissionModel>("UserPermission");
    TempData.Keep("UserPermission");
}
@{
    ViewData["Title"] = "HÀNG CHỜ PHÊ DUYỆT/TỪ CHỐI YÊU CẦU NGHIỆP VỤ TẠO/THAY ĐỔI THÔNG TIN TÀI KHOẢN NGƯỜI DÙNG INTELLECT IDC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="myPopupSumRequirementUserIDC"></div>

