@model List<VBSPOSS.Data.OSS.Models.Menu>

<div class="vbsp-breadcrumb">

    @for (int i = 0; i < Model.Count; i++)
    {
        <span class="vbsp-breadcrumb-item">

            @Model[i].Text

        </span>

        @if (i < Model.Count - 1)
        {
            <span class="vbsp-breadcrumb-separator">
                ->
            </span>
        }
    }

</div>