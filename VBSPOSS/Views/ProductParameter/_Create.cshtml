        function loadProductGrid() {
        var groupCode = $("#ProductGroupCode").val();
        var effectedDate = $("#EffectedDate").data("kendoDatePicker").value();

        if (!groupCode || groupCode === "") {
            alert("Vui lòng chọn phân loại!");
            return;
        }
        if (!effectedDate) {
            alert("Vui lòng chọn ngày hiệu lực!");
            return;
        }

        var effectedDateStr = kendo.toString(effectedDate, "dd/MM/yyyy");

        $.ajax({
            url: '@Url.Action("LoadProductsForCreate", "ProductParameter")',
            type: "POST",
            data: JSON.stringify({ productGroupCode: groupCode, effectedDate: effectedDateStr }),
            contentType: "application/json; charset=utf-8",
            headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
            success: function (response) {
                if (response && response.length) {
                    var grid = $("#gridCreateDetail").data("kendoGrid");
                    if (grid) {
                        var commonRemark = $("#Remark").val().trim();
                        response.forEach(item => item.Remark = commonRemark);
                        grid.dataSource.data(response);
                    }
                } else {
                    alert("Không có dữ liệu!");
                }
            },
            error: function (xhr) {
                alert("Lỗi tải dữ liệu: " + (xhr.responseText || "Unknown error"));
            }
        });
    }
