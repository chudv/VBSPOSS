    var isEditMode = false;
    (function () {
        var flagCallView = '@TempData["FlagCall"]';
        if (flagCallView === "2") {
            isEditMode = true;
        }
    })();

    function onCloseUpdate(ev) {
        mainWindow.data("kendoWindow").close();
    }

    function onClick(e) {
        var lcPosCode = $("#PosCode").val();
        var lcProvinceCode = $("#ProvinceCode").val();
        var lcDistrictCode = $("#DistrictCode").val();
        var lcCommuneCode = $("#CommuneCode").val();

        if (!lcPosCode) {
            alert("Vui lòng chọn Đơn vị!");
