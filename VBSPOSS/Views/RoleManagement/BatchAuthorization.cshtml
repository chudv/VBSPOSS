<form asp-controller="RoleManagement" asp-action="SaveBatchAuthorization" data-ajax="true" data-ajax-method="POST" id="form0" enctype="multipart/form-data">
    @Html.Hidden("FlagCallView", TempData["FlagCall"])
    @Html.Hidden("UserPosCodeView", TempData["UserPosCode"])
