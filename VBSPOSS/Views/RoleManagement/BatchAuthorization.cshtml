                .HtmlAttributes(new { style = "width: 300px; !important;max-width: 100% !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0)
                )
            <label class="lbcontrol" style="color: navy;text-align:right;width:180px;padding-right:10px;">Chức năng phân quyền</label>
            @(Html.Kendo().ComboBoxFor(m => m.MenuId)
                .Filter(FilterType.Contains)
                .Placeholder("--- Chọn chức năng ---")
                .DataTextField("value")
                .DataValueField("id")
                .DataSource(source => { source.Read(read => { read.Action("GetMenus", "RoleManagement").Data("param_BatchAuthorizationMenuUpdate"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 300px; !important;max-width: 100% !important;color: navy;" })
                .Suggest(true)
                .AutoBind(true)
                )

