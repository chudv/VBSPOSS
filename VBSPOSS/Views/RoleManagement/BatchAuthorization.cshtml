<script>
    function onSaveGridCompleted_BatchAuthorizationGrid(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {

                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_handler_BatchAuthorizationGrid(e) {
        if (e.errors) {
            var message = "Thông báo lỗi: ";
            dataChange = true;//Làm sao để gắn giá trị này khi thoát ra mà màn hình cha bên ngoài nó Reload đc
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
        }
    }

    function param_BatchAuthorizationRoleUpdate() {
        return {
            grantType: 0,
            pTitleChoice: "--- Chọn nhóm người dùng (Bắt buộc) ---"
        };
    }

    function param_BatchAuthorizationMenuUpdate() {
        return {
            pTitleChoice: "--- Chọn chức năng (Không bắt buộc) ---"
        };
    }

    function paramLoadGridData_BatchAuthorizationGrid() {
        return {
            roleCode: $("#RoleCode").val(),
            roleName: "",
            menuId: $("#MenuId").val(),//
            menuText: "",
            permitId: -1
        };
    }

    function onRowBound_BatchAuthorizationGrid(e) {
        var rows = e.sender.tbody.children();
        var isRed = true;
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var trangthaiBG = dataItem.get("Status");
            if (trangthaiBG == "0" || trangthaiBG == "C" || trangthaiBG == null)
                row.css({ "background-color": "white", "color": "red" });

            var iKieuIn = dataItem.get("KieuIn");
            if (iKieuIn == 0 || iKieuIn == 1)
                row.addClass('style1');
            else if (iKieuIn == 2)
                row.addClass('style2');
            else if (iKieuIn == 3)
                row.addClass('style3');
            else if (iKieuIn == 4)
                row.addClass('style4');
            else if (iKieuIn == 5)
                row.addClass('style5');
        }
    }

    function refreshGrid_BatchAuthorizationGrid() {
        var objGridUpdateMenuRole = $("#_BatchAuthorizationGrid").data("kendoGrid");
        if (objGridUpdateMenuRole != null) {
            objGridUpdateMenuRole.dataSource.read();
        }
    }

    function onLoadListMenuRoles(e) {
        $('#mydivUpdMenuRoles').show();
        var lcGroupCode = $("#RoleCode").val();
        if (lcGroupCode == null || lcGroupCode == "") {
            alert('Bạn chưa chọn nhóm người dùng cần phân quyền danh sách các chức năng. Vui lòng kiểm tra lại!');
            $('#RoleCode').focus();
            $('#mydivUpdMenuRoles').hide();
            e.preventDefault();
            return false;
        }
        refreshGrid_BatchAuthorizationGrid();
    }

    function index_BatchAuthorizationGrid(dataItem) {
        var data = $("#_BatchAuthorizationGrid").data("kendoGrid").dataSource.data();
        return data.indexOf(dataItem);
    }

    var isClosedUpdMenuRoles = false;

    function onCloseUpdate() {
        isClosedUpdMenuRoles = true;
        mainWindow.data("kendoWindow").close();
    }

    function onClick(e) {
        var lcGroupCode = $("#RoleCode").val();
        if (lcGroupCode == null || lcGroupCode == "") {
            alert('Bạn chưa chọn nhóm người dùng cần phân quyền danh sách các chức năng. Vui lòng kiểm tra lại!');
            $('#RoleCode').focus();
            $('#mydivUpdMenuRoles').hide();
            e.preventDefault();
            return false;
        }
        var nameGroup = $("#RoleCode").data("kendoComboBox").text();

        //Kiểm tra xem Dữ liệu nhập trên lưới đúng chưa?
        var objGridMenuRoles = $("#_BatchAuthorizationGrid").data("kendoGrid");
        var objDataSourceGridMenuRoles = objGridMenuRoles.dataSource;
        var totalRecordGrids = objDataSourceGridMenuRoles.total();
        if (totalRecordGrids <= 0) {
            alert("Bạn chưa tải dữ liệu danh sách chức năng để phân quyền cho nhóm người dùng [" + nameGroup + "]. Vui lòng kiểm tra lại!" + "\n Chú ý: Để phân quyền người dùng bắt buộc phải chọn nhóm người dùng, sau đó nhấn tải dữ liệu danh sách chức năng");
            e.preventDefault();
            return false;
        }
    }

    function onCheckWarning(index) {
