            infoRoleCurrent.Bound(x => x.ReportPermissionDesc).ClientTemplate("#= ReportPermissionDesc #" + "<input type='hidden' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].ReportPermissionDesc' value='#= ReportPermissionDesc #' />").Title("Tạo tờ trình").Width(80).HtmlAttributes(new { style = "text-align: center;" });
            infoRoleCurrent.Bound(x => x.NoAccessPermissionDesc).ClientTemplate("#= NoAccessPermissionDesc #" + "<input type='hidden' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].NoAccessPermissionDesc' value='#= NoAccessPermissionDesc #' />").Title("Không truy cập").Width(120).HtmlAttributes(new { style = "text-align: center;" });
            })); *@
                    columns.Group(groupUpdateRole => groupUpdateRole.Title("Phân quyền theo chức năng (Thêm/Sửa)")
                    .Columns(infoUpdateRole =>
                    {
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].ViewPermissionFlag' id='MenuRolesList_ViewPermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= ViewPermissionFlag#' class= 'k-checkbox01' #= ViewPermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Xem").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].CreatePermissionFlag' id='MenuRolesList_CreatePermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= CreatePermissionFlag#' class= 'k-checkbox01' #= CreatePermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Tạo").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].EditPermissionFlag' id='MenuRolesList_EditPermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= EditPermissionFlag#' class= 'k-checkbox01' #= EditPermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Sửa").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].DeletePermissionFlag' id='MenuRolesList_DeletePermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= DeletePermissionFlag#' class= 'k-checkbox01' #= DeletePermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Xóa").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].AuthorizationPermissionFlag' id='MenuRolesList_AuthorizationPermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= AuthorizationPermissionFlag#' class= 'k-checkbox01' #= AuthorizationPermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Duyệt").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                        infoUpdateRole.Template("<input type='checkbox' name='MenuRolesList[#= index_BatchAuthorizationGrid(data)#].ReportPermissionFlag' id='MenuRolesList_ReportPermissionFlag#= index_BatchAuthorizationGrid(data)#' value='#= ReportPermissionFlag#' class= 'k-checkbox01' #= ReportPermissionFlag != 0 ? 'checked':'' # onclick='onCheckWarning(#= index_BatchAuthorizationGrid(data)#)'> ")
                    .Title("Tạo tờ trình").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                    }));
                })
