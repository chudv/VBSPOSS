                .Editable(editable => { editable.Mode(GridEditMode.InCell); })
                .Sortable(false)
                .Scrollable(s => s.Enabled(true).Height("auto"))
                .Pageable(pageable => pageable.Refresh(true).ButtonCount(5))
                .DataSource(dataSource => dataSource
                .Ajax()
                .Batch(true)
                .ServerOperation(false)
                .Model(model =>
                {
                    model.Id(p => p.Id);
                    model.Field(p => p.Order).Editable(false);
                    model.Field(p => p.RoleName).Editable(false);
                    model.Field(p => p.Text).Editable(false);
                    model.Field(p => p.GroupOrder).Editable(false);
                    model.Field(p => p.StatusDesc).Editable(false);
                    model.Field(p => p.ViewPermissionDesc).Editable(false);
                    model.Field(p => p.NoAccessPermissionDesc).Editable(false);
                })
                .Events(e => e.RequestEnd("onSaveGridCompleted_BatchAuthorizationGrid").Error("error_handler_BatchAuthorizationGrid"))
                .Read(read => read.Action("LoadBatchAuthorizationGridData", "RoleManagement").Data("paramLoadGridData_BatchAuthorizationGrid"))
