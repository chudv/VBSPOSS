        // if (lcKetQuaPermitUpdate == "1" && lcKetQuaPermitView == "1") {
        //     alert("Bạn không thể phân cả 2 quyền cho một nhóm người dùng cùng lúc. Vui lòng kiểm tra lại!" + "\n Chú ý: Có thể chọn gán một quyền cao nhất ví dụ là quyền chỉnh sửa.");
        //     $("#MenuRolesList_KetQuaPermitView" + index).attr('checked', false);
        // }
        // else if (lcKetQuaPermitNoAccess == "1" && (lcKetQuaPermitUpdate == "1" || lcKetQuaPermitView == "1")) {
        //     alert("Bạn đã phân quyền [Không truy cập] rồi, nên không thể phân quyền tiếp là quyền [Chỉnh sửa] hoặc quyền [Xem]. Vui lòng kiểm tra lại!");
        //     $("#MenuRolesList_KetQuaPermitUpdate" + index).attr('checked', false);
