<style>
    .k-animation-container {
        z-index: 100000 !important;
    }

    .readonly-field input,
    .readonly-field .k-input,
    .readonly-field textarea {
        background-color: #f0f0f0 !important;
        color: #28a745 !important; /* Màu xanh lá */
        cursor: not-allowed !important;
    }

    .editable-field input,
    .editable-field .k-input {
        color: navy !important;
    }

    #StartDate, #ExpiryDate {
        width: 50px !important;
        max-width: 100% !important;
        font-family: Tahoma;
        padding-left: 2px;
        padding-right: 2px;
    }

    .hidden-block {
        display: none !important;
    }
</style>
<script>
    function onCloseTransferWindow() {
        mainWindow.data("kendoWindow").close();
        refreshGridIDC();
    }


    $(document).ready(function () {

        var details =
    @Html.Raw(
            Newtonsoft.Json.JsonConvert
            .SerializeObject(
            Model.Details));
    
        var grid =
            $("#gridTransferVillage")
                .data("kendoGrid");

        if (grid) {

            grid.dataSource.data(
                details);

            grid.refresh();
        }
    });

</script>

<form asp-controller="TransferDataPos"
