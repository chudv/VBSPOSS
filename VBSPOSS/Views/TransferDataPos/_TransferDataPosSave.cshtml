            @(Html.Kendo().ComboBoxFor(m => m.Master.FromPosCode)
                .DataTextField("Description")
                .DataValueField("Code")
                .BindTo((List<ValueConstModel>)ViewBag.FromPosList)
                .Filter("contains")
                    .Events(e => e.Change(@<text>
                        function(ev) {

