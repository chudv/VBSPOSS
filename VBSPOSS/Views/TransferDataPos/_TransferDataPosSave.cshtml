                &nbsp;&nbsp;&nbsp;&nbsp;
                <label class="lbcontrol" style="color: navy;text-align:left;width:100px;padding-top: 7px;">Pos đích</label>

            @(Html.Kendo().ComboBoxFor(m => m.Master.ToPosCode)
                .DataTextField("Description")
                .DataValueField("Code")
                .BindTo((List<ValueConstModel>)ViewBag.ToPosList)
                .Filter("contains")
                    .Events(e => e.Change(@<text>
                        function(ev) {

                        var grid =
                        $("#gridTransferVillage")
                        .data("kendoGrid");

                        if (grid) {

                        grid.dataSource.data([]);
                        }
                        }
                    </text>))
                .HtmlAttributes(new
                {
                        style = "width: 420px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px;max-width: 100% !important;color: green;"
                })
                )

                &nbsp;&nbsp;&nbsp;&nbsp;
                <label class="lbcontrol" style="width: 120px; vertical-align: bottom;color: navy;text-align:center;padding-top:3px;">Ngày hiệu lực</label>

            @(Html.Kendo().DatePickerFor(m => m.Master.EffectiveDate)
                .Format("dd/MM/yyyy")
                .Min(DateTime.Today)
                .HtmlAttributes(new
                {
                    style = "width:110px;color:blue;"
                })
                )
            </div>
        </div>

    </div>
   

