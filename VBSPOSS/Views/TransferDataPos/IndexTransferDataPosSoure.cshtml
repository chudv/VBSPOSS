        // mainWindow.data("kendoWindow").wrapper.css({ height: 600, width: 1170 });
        mainWindow.data("kendoWindow").center().open().title("Số liệu chi tiết yêu cầu điều chuyển dữ liệu khác pos");

    }

    //Tao số liệu loan, casa, tide, ...
    function createTransferData(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tờ trình [" + dataItem.Id + "]";

        if (dataItem.Status == 6) {
            alert("Tờ trình [" + dataItem.Id + "] đã bị từ chối nên không thể tạo số liệu. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status > 6) {
            alert("Tờ trình [" + dataItem.Id + "] đã được tạo số liệu, không thể tạo lại. Vui lòng kiểm tra lại!");
        }
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa dữ liệu thông tin tờ trình " + sMessInfor + " không?");
            if (isConfirm == true) {
                $.ajax({
                    data: { pId: dataItem.Id },
                    type: "POST",
                    url: "../TransferDataPos/CreateTransferData",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn đã tạo dữ liệu thành công với tờ trình " + sMessInfor + "!");
                            refreshGridIDC();
                        }
                        else alert("Tạo dữ liệu tờ trình " + sMessInfor + " thất bại!");
                    },
                    error: function () {
                        alert("Tạo dữ liệu tờ trình " + sMessInfor + " có lỗi!");
                    }
                });

            } else {
                alert("Thao tác bị hủy bỏ!");
            }
        }
    }

