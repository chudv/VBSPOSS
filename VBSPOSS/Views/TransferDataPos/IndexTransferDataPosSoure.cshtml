            mainWindow.data("kendoWindow").center().open().title("Chỉnh sửa yêu cầu điều chuyển dữ liệu khác pos");
        }
    }

    function deleteItem(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tờ trình [" + dataItem.Id + "]";

        if (dataItem.Status.toString() != "0" && dataItem.Status.toString() != "1") {
            alert("Tờ trình [" + dataItem.Id + "] đã được phê duyệt nên không thể xóa. Vui lòng kiểm tra lại!");
        }
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa dữ liệu thông tin tờ trình " + sMessInfor + " không?");
            if (isConfirm == true) {
                $.ajax({
                    data: { pId: dataItem.Id },
                    type: "POST",
                    url: "../TransferDataPos/DeleteTransferDataPos",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn đã xóa thành công thông tin tờ trình " + sMessInfor + "!");
                            refreshGridIDC();
                        }
                        else alert("Đánh dấu xóa thông tin tờ trình " + sMessInfor + " thất bại!");
                    },
                    error: function () {
                        alert(" dấu xóa thông tin tờ trình " + sMessInfor + " có lỗi!");
                    }
                });

            } else {
                alert("Thao tác bị hủy bỏ!");
            }
        }
    }

    function approveItem(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tờ trình [" + dataItem.Id + "]";

        if (dataItem.Status.toString() != "0" && dataItem.Status.toString() != "1") {
            alert("Tờ trình [" + dataItem.Id + "] đã được trình duyệt nên không thể trình duyệt lại. Vui lòng kiểm tra lại!");
        }
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn gửi tờ trình này lên trung ương để phê duyệt?");
            if (isConfirm == true) {
                $.ajax({
                    data: {
                        pId: dataItem.Id,
                        pAction: "3"
                    },
                    type: "POST",
                    url: "../TransferDataPos/ApproveTransferDataPos",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn gửi đi phê duyệt thành công" + sMessInfor + "!");
                            refreshGridIDC();
                        }
                        else if (resultVal == "-1") {
                            alert("Lỗi ! Bạn chưa upload file tờ trình!");
                        }
                        else alert("Gửi tờ trình " + sMessInfor + "đi phê duyệt thất bại!");
                    },
                    error: function () {
                        alert(" dấu xóa thông tin tờ trình " + sMessInfor + " có lỗi!");
                    }
                });

            } else {
                alert("Thao tác bị hủy bỏ!");
            }
        }
    }

    //PGD nguồn: Chốt số liệu
    function blockDataItem(e) {
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tờ trình [" + dataItem.Id + "]";

        if (dataItem.Status > 7) {
            alert("Tờ trình [" + dataItem.Id + "] đã chốt số liệu. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status < 7) {
            alert("Tờ trình [" + dataItem.Id + "] chưa tạo số liệu. Vui lòng kiểm tra lại!");
        }
        else {
            var isConfirm = confirm("Bạn có chắc chắn muốn chốt dữ liệu điều chuyển?");
            if (isConfirm == true) {
                $.ajax({
                    data: {
                        pId: dataItem.Id,
                        pAction: "9"
                    },
                    type: "POST",
                    url: "../TransferDataPos/ApproveTransferDataPos",
                    success: function (resultVal) {
                        if (resultVal == "1") {
                            alert("Bạn gửi đi phê duyệt thành công" + sMessInfor + "!");
                            refreshGridIDC();
                        }
                        else if (resultVal == "-1") {
                            alert("Lỗi ! Bạn chưa upload file tờ trình!");
                        }
                        else alert("Gửi tờ trình " + sMessInfor + "đi phê duyệt thất bại!");
                    },
                    error: function () {
                        alert(" dấu xóa thông tin tờ trình " + sMessInfor + " có lỗi!");
                    }
                });

            } else {
                alert("Thao tác bị hủy bỏ!");
            }
        }
    }

