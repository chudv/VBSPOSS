<script>
    function downloadTransferFileGrid(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Yêu cầu [" + dataItem.Id + "]";
        if (dataItem.Status.toString() == "1") {
            alert(sMessInfor + " chưa được cấp phê duyệt cập nhật tờ trình!");
            return;
        }

        var dataItem =
            this.dataItem(
                $(e.currentTarget)
                    .closest("tr"));

        downloadTransferFile(
            dataItem.Id);
    }

    function printToTrinh(e) {

        e.preventDefault();

        var dataItem =
            this.dataItem(
                $(e.currentTarget)
                    .closest("tr"));

        if (!dataItem) {

            alert(
                "Không tìm thấy dữ liệu tờ trình");

            return;
        }

        var lcListId =
            dataItem.Id;

        var lcMainPosName =
            dataItem.MainPosName || "";

        $.ajax({

            url:
                '/Report/GenerateFileReport_UserIDC',

            type:
                'POST',

            data:
            {
                pId:
                    "91",

                pMainPosName:
                    "000301",

                pFunctionType:
                    'ADDNEW_USER'
            },

            xhrFields:
            {
                responseType:
                    'blob'
            },

            success:
                function (
                    data,
                    status,
                    xhr) {

                    var fileName =
                        "To_Trinh_Dieu_Chuyen_POS_"
                        + lcListId
                        + ".pdf";

                    var disposition =
                        xhr.getResponseHeader(
                            "Content-Disposition");

                    if (disposition) {

                        var utf8Match =
                            disposition.match(
                                /filename\*\=UTF-8''(.+)/);

                        if (
                            utf8Match
                            &&
                            utf8Match.length > 1) {
                            fileName =
                                decodeURIComponent(
                                    utf8Match[1]);
                        }
                        else {

                            var asciiMatch =
                                disposition.match(
                                    /filename="?([^";]+)"?/);

                            if (
                                asciiMatch
                                &&
                                asciiMatch.length > 1) {
                                fileName =
                                    asciiMatch[1];
                            }
                        }
                    }

                    var blob =
                        new Blob(
                            [data],
                            {
                                type:
                                    xhr.getResponseHeader(
                                        "Content-Type")
                                    ||
                                    "application/pdf"
                            });

                    var url =
                        window.URL
                            .createObjectURL(
                                blob);

                    var link =
                        document
                            .createElement("a");

                    link.href =
                        url;

                    link.download =
                        fileName;

                    document.body
                        .appendChild(
                            link);

                    link.click();

                    window.URL
                        .revokeObjectURL(
                            url);

                    link.remove();
                },

            error:
                function () {

                    alert(
                        "Không tải được file tờ trình điều chuyển dữ liệu POS. Vui lòng kiểm tra lại!");
                }
        });
    }

    function downloadTransferFile(id) {

        if (!id) {
            alert("Không tồn tại hồ sơ");
            return;
        }
        window.location = '/TransferDataPos/DownloadTransferFile?documentId=' + id;
    }

    function onShowApproveTransferDetail(e) {

        e.preventDefault();

        var dataItem =
            this.dataItem(
                $(e.currentTarget)
                    .closest("tr"));

        if (!dataItem) {

            return;
        }

        showApproveTransferDetail(dataItem.Id, "2");
    }

    function onSaveGridIDC(e) {
        if (e != null && e.response != null) {
            if (!e.response.Errors) {
                if (e.type == "create") {
                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_handlerIDC(e) {
        if (e.errors) {
            var message = "Errors:\n";
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
            console.error("Kendo Grid Error:", e.errors);  // Debug console để xem lỗi backend (F12)
        }
    }

    $(document).ready(function () {
        $(".k-grid-excel").after("<label id='lbl_space' style='padding-top:5px;padding-left: 10px;width:70%; font-size: 11px; font-weight: bold; color: blue;text-align:center;line-height: 25px;'>DANH SÁCH YÊU CẦU ĐIỀU CHUYỂN DỮ LIỆU KHÁC POS</label>");
    });

    function refreshGridIDC() {

        var grid =
            $("#gridMainTransPointWork")
                .data("kendoGrid");

        if (grid) {

            grid.dataSource.read();

            grid.refresh();
        }
    }
</script>