            height: ($(window).height() * 0.95) + "px",
            title: "Số liệu chi tiết yêu cầu điều chuyển dữ liệu khác pos",
            content: {
                url: '@Url.Action("ShowTransferDataLoanDetail", "TransferDataPos")',
                data: {
                    pId: dataItem.Id,
                    pFromPos: dataItem.FromPosCode
                }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseTransPointWork,
            actions: ["Refresh", "Close"]
