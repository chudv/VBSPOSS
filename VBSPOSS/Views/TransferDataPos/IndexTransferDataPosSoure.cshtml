    function showEditIDC(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "[" + dataItem.FullName + "]";
        var grid = $("#gridMainIDC").data("kendoGrid");
        // Kiểm tra trạng thái trước khi trình duyệt
        var deletedStatuses = [0, 1, 2, 4, 5];
        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.IsDeleted == 1) {
                alert("Tạo lập yêu cầu thay đổi người dùng" + sMessInfor + " đã được đánh dấu xóa rồi. Không thực hiện thay đổi!");
            }
            else if (dataItem.Status == 1 || dataItem.Status == 5) {
                alert("Người dùng " + sMessInfor + " đang tạo lập, không thể thực hiện yêu cầu thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 2) {
                alert("Người dùng " + sMessInfor + " đã trình duyệt, không thể thực hiện yêu cầu thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 4) {
                alert("Người dùng " + sMessInfor + " đã được từ chối, không thể thực hiện yêu cầu thay đổi chức năng. Vui lòng kiểm tra lại!");
            }
            return;
        }
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_ApprovalTemp").val();
        mainWindow.kendoWindow({
            width: "1000px",
            height: "700px",
            title: "Yêu cầu chỉnh tờ trình điều chuyển dữ liệu khác pos",
            content: {
                url: '@Url.Action("ShowTransferDataPosMaster", "TransferDataPos")',
                data: { pId: dataItem.Id }
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseTransPointWork,
            actions: ["Refresh", "Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    }
</script>
