    function uploadToTrinh(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Tờ trình [" + dataItem.Id + "]";
        if (dataItem.IsDeleted == true) {
            alert(sMessInfor + " đã được đánh dấu xóa nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "3") {
            alert(sMessInfor + " đã được phê duyệt nên không thể cập nhật lại file.");
        }

        // else if (dataItem.FunctionType != "ADDNEW_USER") {
