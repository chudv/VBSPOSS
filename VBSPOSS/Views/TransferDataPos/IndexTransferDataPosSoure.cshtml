        mainWindow.data("kendoWindow").wrapper.css({ height: 600, width: 1024 });
        mainWindow.data("kendoWindow").center().open().title("Chi tiết điều chuyển dữ liệu khác pos (thôn)");
    }

    function onCloseTransPointWork() {
        if (dataChangeTransPointWork == true) {
            refreshGridTransPointWork();
            dataChangeTransPointWork = false;
        }
    }

    function doCompleteWindow() {
        mainWindow.data("kendoWindow").close();
    }


    //Popup hiển thị danh sách dữ liệu xác nhận: Loan, casa, tide,...
    function showDataDetailLoan(e) {
