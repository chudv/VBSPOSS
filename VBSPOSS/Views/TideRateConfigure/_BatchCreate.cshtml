    function onProductGridDataBound(e) {

        //$("#chkSelectAll").prop("checked", false);

        var grid = this;

        // Bắt sự kiện change của tất cả checkbox
        grid.tbody.find(".chkSelect").off("change").on("change", function (ev) {
            var row = $(this).closest("tr");
            if ($(this).is(":checked")) {
                grid.select(row); // tick = chọn row
            } else {
                grid.clearSelection(); // bỏ chọn tất cả
                // tick lại các checkbox đang checked
                grid.tbody.find(".chkSelect:checked").each(function () {
                    grid.select($(this).closest("tr"));
                });
            }
            updateSelectedProducts(grid);
            ev.stopPropagation(); // ngăn click row
        });

        // Khi click row, đồng bộ checkbox
        grid.tbody.find("tr").off("click").on("click", function (e) {
            if ($(e.target).is("input:checkbox")) return; // bỏ qua nếu click checkbox
            var row = $(this);
            var checkbox = row.find(".chkSelect");
            var isSelected = row.hasClass("k-state-selected");
            checkbox.prop("checked", isSelected);
            updateSelectedProducts(grid);
        });

        updateSelectedProducts(grid); // cập nhật lần đầu
    }

    function updateSelectedProducts(grid) {
        var selectedRows = grid.select();
        var productCodes = [];

        selectedRows.each(function () {
            var dataItem = grid.dataItem(this);
            productCodes.push(dataItem.AccountTypeCode);
        });



        if (productCodes.length === 0) {
            // Khi chưa chọn gì → hiển thị tổng số sản phẩm
            $("#selectedProducts").text("Tổng số sản phẩm: " + grid.dataSource.total());
        } else {
            // Khi đã chọn → hiển thị danh sách product code
            $("#selectedProducts").text("Sản phẩm đã chọn: " + productCodes.join(", "));

              var total = $("#grdProductGrid tbody .chkSelect").length;
    //     var checked = $("#grdProductGrid tbody .chkSelect:checked").length;

         $("#chkSelectAll").prop("checked", total > 0 && total === productCodes.length);
        }



    }


    function updateSelectedTerms(grid) {
        var selectedRows = grid.select();
        var termCodes = [];

        var txtSoThangGui = $("#DepositTermUnit").data("kendoNumericTextBox");

        var defaultTermValue = 0;
        selectedRows.each(function () {
            var dataItem = grid.dataItem(this);
            termCodes.push(dataItem.TermValue + dataItem.TermUnitCode);
            if (defaultTermValue ===0 || defaultTermValue > dataItem.MinTermValue) {
                txtSoThangGui.value(dataItem.MinTermValue); 
                txtSoThangGui.trigger("change"); 
                defaultTermValue = dataItem.MinTermValue;
            }
            
        });

        if (termCodes.length === 0) {
            // Khi chưa chọn gì → hiển thị tổng số sản phẩm
            $("#selectedTerms").text("Tổng số kỳ hạn: " + grid.dataSource.total());
        } else {
            // Khi đã chọn → hiển thị danh sách product code
            $("#selectedTerms").text("Kỳ hạn đã chọn: " + termCodes.join(", "));
        }
    }


