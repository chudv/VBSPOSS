    function onSave_TideRateConfigureGrid(e) {
        try {

            var posGrade = parseInt($("#PosGrade").val());  

            // Ensure dirtyFields is initialized
            e.model.dirtyFields = e.model.dirtyFields || {};

            var num = e.values.TermIntRateNew;

            var model = e.model;
            var minRate = parseFloat(model.MinTermIntRateNew);
            var maxRate = parseFloat(model.MaxTermIntRateNew);

            if (typeof minRate !== "number" || typeof maxRate !== "number") {
                return;
            }

            var newValue = parseFloat(num);

            // console.log(minRate, typeof minRate);
            // console.log(maxRate, typeof maxRate);
            // console.log(newValue, typeof newValue);

            if (posGrade !== 3 && ( isNaN(newValue) || newValue < minRate || newValue > maxRate)) {
                    alert(
                        "Lãi suất phải nằm trong khoảng từ " +
                        kendo.toString(minRate, "n2") +
                        " đến " +
                        kendo.toString(maxRate, "n2")
                    );

                    e.preventDefault();
            } 
            else 
            {
                e.model.set("ChangeFlag", 1);
                e.model.dirtyFields["ChangeFlag"] = true;

                // Mark fields as dirty and track TermIntRateNew changes
                for (var field in e.values) {
                    if (e.values.hasOwnProperty(field)) {
                        e.model.dirtyFields[field] = true;
                        if (field === "TermIntRateNew") {
                            updatedCells.push({
                                id: e.model.id,
                                field: field
                            });
                            // Directly apply styling to the cell
                            var row = e.container.closest("tr");
                            var grid = $("#tideRateConfigureGrid").data("kendoGrid");
                            var columnIndex = grid.columns.findIndex(function (col) {
                                return col.field === "TermIntRateNew";
                            });
                            if (columnIndex !== -1) {
                                row.find("td").eq(columnIndex).addClass("row-changed");
                            }
                        }
                    }
                }
            }
            
        } catch (error) {
            console.error("Error in onSave_TideRateConfigureGrid:", error);
        }
    }

    function onSave_TideRateConfigureForm() {
        console.log("onSave_TideRateConfigureForm triggered");
        try {
            var grid = $("#tideRateConfigureGrid").data("kendoGrid");
            if (!grid) {
                console.error("Grid not found");
                alert("Lỗi: Không tìm thấy grid!");
                return;
            }

            var decisionNo = $("#CircularRefNum").val();

            if (decisionNo == null || decisionNo == '') {
                console.error("Bạn chưa nhập số Quyết định");
                alert('Bạn chưa nhập số Quyết định');
                return;
            }

            // Collect grid data
            var gridData = grid.dataSource.data().toJSON();
            console.log("Grid data:", gridData);

            // Collect form data
            var formData = $("#addTideRateConfigureBatchForm").serializeArray();
            var formModel = {};

            var applyPosLst = $("#ApplyPosList").data("kendoMultiSelect").value();


            if (applyPosLst == null || applyPosLst.length == 0) {
                alert('Bạn chưa chọn POS áp dụng');
                return;
            }

            $.each(formData, function (index, field) {
               // alert('field.value ' + field.value);
                formModel[field.name] = field.value;
                // Convert date fields to ISO format
                if (field.name === "EffectiveDate" || field.name === "ExpiredDate" || field.name === "CircularDate") {
                    var date = kendo.parseDate(field.value, "dd/MM/yyyy");
                    if (date) {
                        formModel[field.name] = kendo.toString(date, "yyyy-MM-ddTHH:mm:ssZ");
                    } else {
                        console.warn(`Failed to parse date for ${field.name}: ${field.value}`);
                        formModel[field.name] = null;
                    }
                }
                // Convert numeric fields
                if (field.name === "AmoutSlab" || field.name === "NewInterestRate") {
                    var num = parseFloat(field.value);
                    formModel[field.name] = isNaN(num) ? null : num;
                }

                if (field.name === "ApplyPosList" ) {

                    formModel[field.name] = applyPosLst;
                }
            });
            console.log("Form data:", formModel);

            // Combine form and grid data
            var submitData = {
                model: formModel,
                gridItems: gridData
            };
            console.log("Submit data:", submitData);

            // Send AJAX request
            $.ajax({
                url: '@Url.Action("SaveBatchTideRateConfigure", "TideRateConfigure")',
                type: "POST",
                data: JSON.stringify(submitData),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    console.log("Save successful:", response);
                    alert("Bạn đã tạo thay đổi lãi suất theo quyết định " +  decisionNo + " thành công!");
                    //grid.dataSource.read(); // Refresh grid
                    //updatedCells = []; // Clear highlighted cells
                    dataChangeTideRateConfigure = true;
                    mainWindow.data("kendoWindow").close();
                },
                error: function (xhr, status, error) {
                    console.error("Save failed:", error, xhr.responseText);
                    alert("Lỗi khi lưu dữ liệu: " + (xhr.responseText || error));
                }
            });
        } catch (error) {
            console.error("Error in onSave_TideRateConfigureForm:", error);
            alert("Lỗi: " + error.message);
        }
    }


    function onSave_TideRateConfigureTemp() {
        console.log("onSave_TideRateConfigureTemp triggered");
        try {

            var grid = $("#grdDepositTermGrid").data("kendoGrid");
            var selectedRows = grid.select();
            var selectedItems = [];

            selectedRows.each(function () {
                var dataItem = grid.dataItem(this);

                selectedItems.push({
                    Id: dataItem.Id,
                    TermUnitCode: dataItem.TermUnitCode,
                    TermValue: dataItem.TermValue,
                    InclusionFlag: dataItem.InclusionFlag
                });
            });

            var interestRate = parseFloat( $("#NewInterestRate").val());
            var beforeTermInterestRate = parseFloat( $("#BeforeTermNewInterestRate").val());
            var partialInterestRate = parseFloat( $("#PartialNewInterestRate").val());
            var depositType = $("#DepositType").val();

            if (interestRate == null ) {
                console.error("Bạn chưa nhập lãi suất");
                alert('Bạn chưa nhập lãi suất');
                return;
            }

            //alert(selectedItems.length);

            if (selectedItems.length ===0) {
                alert('Bạn chưa chọn kỳ hạn!');
                return;
            }

            // Combine form and grid data
            var submitData = {
                depositTerms: selectedItems,
                interestRate: interestRate,
                beforeTermInterestRate: beforeTermInterestRate,
               partialInterestRate: partialInterestRate,
               depositType: depositType
            };
            console.log("Submit data:", submitData);

            // Send AJAX request
            $.ajax({
                url: '@Url.Action("SaveTideRateTemp", "TideRateConfigure")',
                type: "POST",
                data: JSON.stringify(submitData),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    console.log("Save successful:", response);
                    alert(response.Message);
                    $("#SourceFlag").val("1");
                    //grid.dataSource.read(); // Refresh grid
                    //updatedCells = []; // Clear highlighted cells
                    //dataChange = true;
                    onLoadData_TideRateConfigure();
                },
                error: function (xhr, status, error) {
                    console.error("Save failed:", error, xhr.responseText);
                    alert((xhr.responseText || error));
                }
            });
        } catch (error) {
            console.error("Error in onSave_TideRateConfigureForm:", error);
            alert("Lỗi: " + error.message);
        }
    }


