                // tick lại các checkbox đang checked
                grid.tbody.find(".chkSelect:checked").each(function () {
                    grid.select($(this).closest("tr"));
                });
            }
            ev.stopPropagation(); // ngăn click row
            updateSelectedTerms(grid);
        });

        // Khi click row, đồng bộ checkbox
        grid.tbody.find("tr").off("click").on("click", function (e) {
            if ($(e.target).is("input:checkbox")) return; // bỏ qua nếu click checkbox
            var row = $(this);
            var checkbox = row.find(".chkSelect");
            var isSelected = row.hasClass("k-state-selected");
            checkbox.prop("checked", isSelected);
            updateSelectedTerms(grid);
        });

        updateSelectedTerms(grid);
    }

    function onNewInterestRateChanged(e) {
        var txtLsTraSau = $("#NewInterestRate").data("kendoNumericTextBox");
        var lsTraSau = txtLsTraSau.value(); // giá trị đã nhập
       // alert(lsTraSau);

        var txtSoThangGui = $("#DepositTermUnit").data("kendoNumericTextBox");
        var soThangGui = txtSoThangGui.value();

        if (soThangGui <= 0 || soThangGui == null) {
            alert("Số tháng gửi phải lớn hơn 0. Hệ thống sẽ tự động đặt lại = 1.");

            txtSoThangGui.value(1); // set mặc định
            txtSoThangGui.trigger("change"); // đồng bộ UI
            return; // ⛔ dừng xử lý để tránh chia cho 0
        }

        // set vào ô BeforeTermNewInterestRate
        var beforeTerm = $("#BeforeTermNewInterestRate").data("kendoNumericTextBox");


        var lsTraSauTyLe = lsTraSau/100;
        var lsTraTruoc = tinhLaiSuatTraTruoc(lsTraSauTyLe, soThangGui);
        beforeTerm.value(lsTraTruoc);

        // set vào ô PartialNewInterestRate
        var partial = $("#PartialNewInterestRate").data("kendoNumericTextBox");

        var lsDinhKy = tinhLaiSuatDinhKy(lsTraSauTyLe, soThangGui);
        partial.value(lsDinhKy);
    }

    //Hàm tính lãi suất quy đổi sang trả trước
    function tinhLaiSuatTraTruoc(lsTraSauTyLe, soThangGui) {
        if (soThangGui <= 0) return 0;

        const result = lsTraSauTyLe / (1 + lsTraSauTyLe * soThangGui/12  ) * 100;
        return Math.floor(result * 100) / 100;//Number(result.toFixed(2));
    }


    //Tính lãi suất định kỳ từ lãi suất đầu kỳ
     
    function tinhLaiSuatDinhKy(lsTraSauTyLe, soThangGui) {
        if (soThangGui <= 0) return 0;
        if (lsTraSauTyLe < 0) return 0;

        // Công thức: ( (1 + r/n)^(1/n) - 1 ) × 12 × 100
        const effective = (Math.pow(1 + lsTraSauTyLe / 12 * soThangGui, 1 / soThangGui) - 1) * 12 * 100;

        return Math.floor(effective * 100) / 100 ; //Number(effective.toFixed(2));
    }
</script>

