            if (!circularRefNum || !circularDate) return;

            $.ajax({
                url: "/TideRateConfigure/CheckCircular",
                type: "GET",
                data: {
                    circularRefNum: circularRefNum,
                    circularDate: kendo.toString(circularDate, "yyyy-MM-dd")
                },
                success: function (res) {

                    if (res.isExists) {
                        $("#qd-status")
                            .html("⚠️")
                            .removeClass()
                            .addClass("qd-invalid")
                            .attr("title", "Quyết định đã tồn tại với ngày này")
                            .show();
                    } else {
                        $("#qd-status")
                            .html("✔")
                            .removeClass()
                            .addClass("qd-valid")
                            .attr("title", "Quyết định hợp lệ")
                            .show();
                    }
                }
            });
        });

        var numeric = $("#DepositTermUnit").data("kendoNumericTextBox");
        numeric.bind("spin", onDepositTermSpin);


        var numeric = $("#TermBasis").data("kendoNumericTextBox");
        numeric.bind("spin", onTermBasisSpin);


        $("#selectAllPos").on("change", function () {
            var checked = this.checked;
            var multiSelect = $("#ApplyPosList").data("kendoMultiSelect");

            if (multiSelect) {
                if (checked) {
                    var dataSource = multiSelect.dataSource.data();
                    var allValues = dataSource.map(function(item) { return item.id; });
                    multiSelect.value(allValues);
                } else {
                    multiSelect.value([]);
                }
            }
        });
    });

</script>