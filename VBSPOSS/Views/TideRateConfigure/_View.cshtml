<script>
    $(document).ready(function () {
        countChangedRows();
    });

    function countChangedRows() {
        var grid = $("#tideRateConfigureGrid").data("kendoGrid");
        if (!grid) return;

        // Lấy toàn bộ dữ liệu trên Grid (vì bạn đang ServerOperation(false))
        var data = grid.dataSource.view();

        // Đếm số dòng có ChangeFlag = 1
        var total = data.length;
        var count = data.filter(x => x.ChangeFlag === 1).length;

        // Gán vào label hiển thị
        $("#lblChangedCount").text("(Số kỳ hạn thay đổi: " + count + "/" + total + ")");
    }
</script>