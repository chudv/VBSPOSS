                                columns.Bound(c => c.TermAccountSubTypeCode).Hidden().Title("Loại TK phụ").Width(140).HtmlAttributes(new { style = "text-align: center;" }).Locked(true);
                                                                                                                                                                                          @* columns.Command(command => { command.Edit(); }).Title("Thao tác").Width(200).HtmlAttributes(new { style = "text-align: center;" }); *@
                                columns.Bound(c => c.ChangeFlag).Hidden();
                            })
                            .ToolBar(toolbar => toolbar.Excel().HtmlAttributes(new { id = "btnExportExcel", style = "height: 25px;width: 110px; font-weight:bold; color: blue;font-family:Tahoma; font-size: 12px;font-weight:bold;!important;", title = "Xuất dữ liệu trên lưới ra file excel" }).Text("Xuất excel"))
