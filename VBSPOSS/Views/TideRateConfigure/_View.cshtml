@model VBSPOSS.ViewModels.InterestRateConfigMasterViewModel
@using Kendo.Mvc.UI
@using VBSPOSS.Constants
@using VBSPOSS.Data.Models
@using VBSPOSS.ViewModels

@{
    Layout = null; // Giữ là partial view
}


<link rel="stylesheet" href="@Url.Content("~/css/kendo_cust_style.css")" />
<link rel="stylesheet" href="@Url.Content("~/css/my_cust_style.css")" />

<style>
    .view_form.row {
        width: 100% !important;
        margin-left: 0;
        margin-right: 0;
    }

    .view_form.button {
        /* width: 100px !important; */
        height: 25px !important;
        margin-left: 5px;
        margin-right: 5px;
    }

    .section-header {
        /*  padding: 10px 0;
                    margin-top: 10px; */
        border-bottom: 1px dotted #d9534f; /* giống màu đỏ trong hình */
    }

    .section-title {
        color: blue;
        font-weight: bold;
    }

    .row-changed {
        color: red !important;
    }

    #tabstrip h2 {
        font-size: 42px;
        font-style: normal;
        font-weight: 100;
        line-height: 50.4px;
        margin: 0;
    }

    #tabstrip h2 span {
        background: none;
        padding-left: 5px;
        vertical-align: top;
    }


    .k-grid .btn-download.k-button {
        background: url('../images/download_icon.png') no-repeat center center;
        background-size: 15px 15px;
        width: 15px;
        height: 15px;
        border: none;
    }
</style>


<script>
    var rowNumber = 1;

    function paraTideConfigureViewGridData() {
        return {
            idList: $("#IdList").val(),
        };
    }

    function paraAttachFileGridData() {
        return {
            documentNumber: $("#CircularRefNum").val(),
        };
    }

    function onRowBound_TideRateViewGrid(e) {
        try {
            var grid = this;  // "this" chính là Kendo Grid

            // Duyệt qua tất cả các dataItem của grid
            grid.dataSource.data().forEach(function (dataItem) {
                // Nếu ChangeFlag = 1 (hoặc == true tùy kiểu dữ liệu của bạn)
                if (dataItem.ChangeFlag === 1 || dataItem.ChangeFlag === true) {
                    // Tìm row tương ứng bằng uid
                    var uid = dataItem.uid;
                    var row = grid.tbody.find("tr[data-uid='" + uid + "']");

                    if (row.length) {
                        // Thêm class để thay đổi style (bạn có thể đặt tên class tùy ý)
                        row.addClass("row-changed");

                        // Nếu muốn highlight cả những ô đã thay đổi trước đó (giữ lại logic cũ của bạn)
                        // thì vẫn giữ phần re-apply cho TermIntRateNew ở đây
                }
            }
            });


            countChangedRows();

        } catch (error) {
            console.error("Error in onRowBound_TideRateConfigureGrid:", error);
        }
    }


    function onRowBound_AttachFileGrid(e) {
        rowNumber = 1;
    }


    function onDownloadFile(e) {
        e.preventDefault(); // ⛔ chặn postback

        var grid = $("#tideFileUploadGrid").data("kendoGrid");
        var dataItem = grid.dataItem($(e.currentTarget).closest("tr"));

        if (!dataItem || !dataItem.FileId) {
            kendo.alert("Không tìm thấy file!");
            return;
        }

        window.location.href =
            '@Url.Action("DownloadFile", "TideRateConfigure")' +'?fileId=' + dataItem.FileId;
    }
</script>

<form id="viewTideRateConfigureBatchForm">
