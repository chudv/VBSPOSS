                            .Read(read => read.Action("LoadTideConfigureViewGridData", "TideRateConfigure").Type(HttpVerbs.Post).Data("paraTideConfigureViewGridData"))                                                                                                                                                                        
                            .Model(model => model.Id(p => p.Id)) // Sử dụng Id
                            )
                            .AutoBind(true)
