	function deleteItem(e) {
		e.preventDefault();
		var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
		var sMessInfor = "[" + dataItem.CircularRefNum + "]";

		var deletedStatuses = [0, 2, 3, 4];
		if (deletedStatuses.includes(dataItem.Status)) {
			alert("Cấu hình lãi suất " + sMessInfor + " đã được đánh dấu xóa rồi hoặc đang chờ duyệt hoặc đã được phê duyệt. Không thực hiện đánh dấu xóa!");
			return;
		}

		var grid = this;

		var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa cấu hình lãi suất " + sMessInfor + " không?");

		if (isConfirm) {
			
			kendo.ui.progress(grid.element, true);

			$.ajax({
				url: '@Url.Action("DeleteInterestRateConfigByDocumentId", "TideRateConfigure")',
				type: "POST",
				data: JSON.stringify({
					IdList: dataItem.IdList,
				}),
				contentType: "application/json; charset=utf-8",
				headers: {
					"RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
				},
				success: function (result) {
					kendo.ui.progress(grid.element, false); // Hide loading indicator
					console.log("Delete success result:", result);
					if (result.success) {
						alert("Xóa cấu hình lãi suất " + sMessInfor + " thành công!");
						refreshGridTideRateConfigure(); // Refresh the grid
					} else {
						alert("Xóa cấu hình lãi suất " + sMessInfor + " thất bại! Lỗi: " + (result.message || "Không xác định"));
					}
				},
				error: function (xhr, status, error) {
					kendo.ui.progress(grid.element, false); // Hide loading indicator
					console.error("Delete error:", xhr, status, error);
					alert("Xóa cấu hình lãi suất " + sMessInfor + " có lỗi! Chi tiết: " + (xhr.responseText || error));
				}
			});
		} else {
			alert("Thao tác bị hủy bỏ!");
		}
	}

	function submitForApproval(e) {
		e.preventDefault();
		var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
		var sMessInfor = "[" + dataItem.CircularRefNum + "]";

		// Kiểm tra trạng thái trước khi trình duyệt
		if (dataItem.Status == 0) {
			alert("Cấu hình lãi suất theo Quyết định " + sMessInfor + " đã đóng. Không thể trình duyệt!");
			return;
		}

		if (dataItem.Status >= 2) {
			alert("Cấu hình lãi suất  theo Quyết định " + sMessInfor + " đã trình duyệt hoặc đã phê duyệt. Không thể trình duyệt lại!");
			return;
		}

		
		if (mainWindow.data("kendoWindow")) {
			mainWindow.data("kendoWindow").destroy();
		}

		var formattedDate = kendo.toString(dataItem.EffectiveDate, "yyyyMMdd");

		mainWindow.kendoWindow({
			width: "1250px",
			height: "700px",
			title: "Trình duyệt thay đổi lãi suất tiền gửi CKH",
			content: {
				url: '@Url.Action("ShowApprovalScreen", "TideRateConfigure")',
				data: { id: dataItem.Id, circularRefNum: dataItem.CircularRefNum, effectDate: formattedDate , idList: dataItem.IdList  , pFlagCall: "1"}
			},
			resizable: false,
			visible: false,
			modal: true,
			close: onCloseTideRateConfigure,
			actions: ["Close"],
			error: function (e) {
				notification.show({
					message: "Có lỗi xảy ra: " + e.xhr.statusText,
					type: "error"
				}, "error");
				mainWindow.data("kendoWindow").close();
			}
		});
		mainWindow.data("kendoWindow").center().open();
		
	}

	function submitForAuthorize(e) {
		e.preventDefault();
		var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
		var sMessInfor = "[" + dataItem.CircularRefNum + "]";

		// Kiểm tra trạng thái trước khi trình duyệt
		if (dataItem.Status == 0) {
			alert("Cấu hình lãi suất theo Quyết định " + sMessInfor + " đã đóng. Không thể trình duyệt!");
