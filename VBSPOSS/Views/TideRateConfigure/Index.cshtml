    function showDetails(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }

		var formattedDate = kendo.toString(dataItem.EffectiveDate, "yyyyMMdd");


        mainWindow.kendoWindow({
            width: "1250px",
            height: "700px",
            title: "Chi tiết cấu hình lãi suất",
            content: {
                url: '@Url.Action("ShowBatchConfigDetail", "TideRateConfigure")',
				data: { id: dataItem.Id, circularRefNum: dataItem.CircularRefNum , effectDate: formattedDate, idList: dataItem.IdList  , pFlagCall: "1"}
            },
            resizable: false,
            visible: false,
            modal: true,
            close: onCloseTideRateConfigure,
            actions: ["Close"],
            error: function (e) {
                notification.show({
                    message: "Có lỗi xảy ra: " + e.xhr.statusText,
                    type: "error"
                }, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    }

