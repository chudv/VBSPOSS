	function refreshGridTideRateConfigure() {
		var grid = $("#gridMainTideRateConfgiure").data("kendoGrid");
		if (grid != null) {
			grid.dataSource.read();
		}
	}

	function onSearchTideRateConfigure(e) {
		refreshGridTideRateConfigure();
	}

	function onRowBoundTideRateConfigure(e) {
		var rows = e.sender.tbody.children();
		var isRed = true;
		for (var j = 0; j < rows.length; j++) {
			var row = $(rows[j]);
			var dataItem = e.sender.dataItem(row);
			var trangthaiRow = dataItem.get("Status");
			if (trangthaiRow == "C" || trangthaiRow == null || trangthaiRow == 0 || trangthaiRow == 4)
				row.css({ "background-color": "#f8f9fa", "color": "#6c757d" });
			if (trangthaiRow != null && trangthaiRow == 4)
				row.css({ "background-color": "#fff5f5", "color": "#dc3545" });
			if (trangthaiRow != null && trangthaiRow == 3) // Đã duyệt 
				row.css({ "background-color": "#e8f5e9", "color": "#2e7d32" });

		}

		var grid = this;
		grid.tbody.find("tr").each(function () {
			var dataItem = grid.dataItem(this);
			//alert(userPermission.ReportPermissionFlag);
			if (userPermission && userPermission.EditPermissionFlag == 0) {
				$(this).find(".k-grid-ViewEdit").hide();
			}
			if (userPermission && userPermission.DeletePermissionFlag == 0) {
				$(this).find(".k-grid-Delete").hide();
			}

			if (userPermission && userPermission.AuthorizePermissionFlag == 0) {
				$(this).find(".k-grid-Authorize").hide();
			}

			if (userPermission && userPermission.ReportPermissionFlag == 0) {
				$(this).find(".k-grid-Approval").hide();
			}
		});
	}

	var dataChangeTideRateConfigure = false;


	function onCloseTideRateConfigure() {
		if (dataChangeTideRateConfigure == true) {
			refreshGridTideRateConfigure();
