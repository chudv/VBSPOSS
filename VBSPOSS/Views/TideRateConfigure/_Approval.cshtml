<script>
    $(document).ready(function () {
        countChangedRows();

        // Click nút "Chọn file"
        $("#btnChooseFile").click(function () {
            $("#fileUpload").click();
        });

        // Khi chọn file
        $("#fileUpload").on("change", function () {
            if (this.files && this.files.length > 0) {
                $("#fileName").text(this.files[0].name);
                $("#btnRemoveFile").show();
            } else {
                resetFile();
            }
        });

        // Click nút xóa
        $("#btnRemoveFile").click(function () {
            resetFile();
        });

        function resetFile() {
            $("#fileUpload").val("");   // xóa file
            $("#fileName").text("Chưa chọn file");
            $("#btnRemoveFile").hide();
        }

            $("#fileUpload").on("change", function () {
            if (!this.files || this.files.length === 0) return;

            var file = this.files[0];
            var fileName = file.name.toLowerCase();

            if (!fileName.endsWith(".pdf")) {
                alert("Chỉ cho phép upload file PDF");
                resetFile();
                return;
            }

            $("#fileName").text(file.name);
            $("#btnRemoveFile").show();
        });
    });

    function countChangedRows() {
        var grid = $("#tideRateConfigureGrid").data("kendoGrid");
        if (!grid) return;

        // Lấy toàn bộ dữ liệu trên Grid (vì bạn đang ServerOperation(false))
        var data = grid.dataSource.view();

        // Đếm số dòng có ChangeFlag = 1
        var total = data.length;
        var count = data.filter(x => x.ChangeFlag === 1).length;

        // Gán vào label hiển thị
        $("#lblChangedCount").text("(Số kỳ hạn thay đổi: " + count + "/" + total + ")");
    }


    $(function () {
        $("#trcApprovalForm").submit(function (event) {
            event.preventDefault();

        var fileInput = $("#fileUpload")[0];
        if (!fileInput || fileInput.files.length === 0) {
            alert("Vui lòng đính kèm file tờ trình (PDF) trước khi trình duyệt!");
            return false;
        }

        // (optional) check loại file lần nữa
        var file = fileInput.files[0];
        if (file.type !== "application/pdf") {
            alert("Chỉ cho phép upload file PDF!");
            return false;
        }

        var decisionRef = $("#CircularRefNum").val();
        var token = $('input[name="__RequestVerificationToken"]').val();

        alert('token' + token);
            var dataString;
            var action = this.action;
            var contentType;
            var processData;
            if (this.enctype == "multipart/form-data") {
                dataString = new FormData($(this).get(0));
                //contentType = false;
                //processData = false;
            } else {
            }

            $.ajax({
                url: this.action,
                type: this.method,
                data: dataString,
                contentType: false,   // BẮT BUỘC
                processData: false,   // BẮT BUỘC
                headers: {
            'RequestVerificationToken': token
        },
                success: function (result) {

                    if (result && result.Errors) {
                        // var errorMessages = [];

                        // for (var key in result.Errors) {
                        //     if (result.Errors.hasOwnProperty(key)) {
                        //         errorMessages = errorMessages.concat(result.Errors[key]);
                        //     }
                        // }

                        //alert(errorMessages.join("\n"));
                        alert(JSON.stringify(result.Errors));
                        return;
                    }
                    alert("Trình duyệt thay đổi lãi suất theo văn bản " + decisionRef +  " thành công");
                    dataChangeTideRateConfigure = true;
                    mainWindow.data("kendoWindow").close();
                },
                error: function () {
                    alert("Lỗi khi cập nhật dữ liệu");
                }
            });
            return false;
        });
    });



    $("#btnPrintReport").click(function () {

        var circularRefNum = $("#CircularRefNum").val();
        var listId = $("#IdList").val();

        //alert('listId' + listId + 'circularRefNum ' + circularRefNum);

        $.ajax({
            url: '/Report/GenerateToTrinh_Tide',
            type: 'POST',
            data: { listId: listId, circularRefNum: circularRefNum },
            xhrFields: {
                responseType: 'blob'   // BẮT BUỘC
            },
            success: function (data, status, xhr) {

                var fileName = "to_trinh.pdf";
                var disposition = xhr.getResponseHeader("Content-Disposition");

                if (disposition) {

                    // Ưu tiên filename*=UTF-8''
                    var utf8Match = disposition.match(/filename\*\=UTF-8''(.+)/);
                    if (utf8Match && utf8Match.length > 1) {
                        fileName = decodeURIComponent(utf8Match[1]);
                    }
                    else {
                        // fallback filename=
                        var asciiMatch = disposition.match(/filename="?([^";]+)"?/);
                        if (asciiMatch && asciiMatch.length > 1) {
                            fileName = asciiMatch[1];
                        }
                    }
                }

                var blob = new Blob([data], {
                    type: xhr.getResponseHeader("Content-Type") || "application/octet-stream"
                });

                var url = window.URL.createObjectURL(blob);
                var link = document.createElement("a");
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();

                window.URL.revokeObjectURL(url);
                link.remove();
            },
            error: function () {
                alert("Không tải được file");
            }
        });
    });
</script>