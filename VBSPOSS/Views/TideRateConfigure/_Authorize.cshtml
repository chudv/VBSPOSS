<script>
    $(document).ready(function () {
        countChangedRows();
    });

    function countChangedRows() {
        var grid = $("#tideRateConfigureGrid").data("kendoGrid");
        if (!grid) return;

        // Lấy toàn bộ dữ liệu trên Grid (vì bạn đang ServerOperation(false))
        var data = grid.dataSource.view();

        // Đếm số dòng có ChangeFlag = 1
        var total = data.length;
        var count = data.filter(x => x.ChangeFlag === 1).length;

        // Gán vào label hiển thị
        $("#lblChangedCount").text("(Số kỳ hạn thay đổi: " + count + "/" + total + ")");
    }


    $(function () {
        $("#trcAuthorizeForm").submit(function (event) {
            event.preventDefault();
            var dataString;
            var action = this.action;
            var contentType;
            var processData;
            if (this.enctype == "multipart/form-data") {
                dataString = new FormData($(this).get(0));
                //contentType = false;
                //processData = false;
            } else {
            }

            $.ajax({
                url: this.action,
                type: this.method,
                data: dataString,
                contentType: false,   // BẮT BUỘC
                processData: false,   // BẮT BUỘC
                success: function (result) {

                    if (result && result.Errors) {                        
                        alert(JSON.stringify(result.Errors));
                        return;
                    }

                    var rejectStatus = parseInt( $("#RejectFlag").val());
                    var decisionRef = $("#CircularRefNum").val();   

                    if (rejectStatus === 1) {
                        alert("Bạn đã từ chối thay đổi lãi suất theo văn bản " + decisionRef + " thành công");
                    } else
                    {
                        alert("Bạn đã phê duyệt thay đổi lãi suất theo văn bản " + decisionRef + " thành công");
                    }

                    dataChangeTideRateConfigure = true;
                    mainWindow.data("kendoWindow").close();
                },
                error: function () {
                    alert("Lỗi khi cập nhật dữ liệu");
                }
            });
            return false;
        });
    });
</script>