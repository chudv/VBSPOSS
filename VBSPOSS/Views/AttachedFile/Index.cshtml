@using Kendo.Mvc
@using VBSPOSS.Data.OSS.Models
@using VBSPOSS.Extensions
@using VBSPOSS.Models
@{
    ViewBag.Title = "Attached File";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    var userPermission = TempData.Get<RolePermissionModel>("UserPermission");
    TempData.Keep("UserPermission");
}
<div id="myPopup"></div>
<div id="notification"></div>
<style>
