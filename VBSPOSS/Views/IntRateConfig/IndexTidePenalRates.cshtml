@using Kendo.Mvc
@using Kendo.Mvc.UI
@using VBSPOSS.Extensions
@using VBSPOSS.Models

@{
    ViewData["Title"] = "CẤU HÌNH LÃI SUẤT RÚT TRƯỚC HẠN TIỀN GỬI CÓ KỲ HẠN";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var userPermission = TempData.Get<RolePermissionModel>("UserPermission");
    TempData.Keep("UserPermission");
}
<div id="myPopup"></div>

<style>
