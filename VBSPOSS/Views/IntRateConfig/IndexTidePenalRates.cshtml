<hr style='margin-top: 0.2em; margin-bottom: 0.3em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />

<div style="flex-grow: 1; display: flex; flex-direction: column; ">
    <div class="row" style="color: navy; padding-top: 0px;padding-bottom: 0px;">

        <div class="col-md-12">
            <div style="display: flex; align-items: center; gap: 3px; width: 100%;">

                
            <label class="lbcontrol" style="color: navy;text-align:left;width:50px;padding-top:3px;padding-right:0px;font-family:Tahoma;font-size:12px;">Đơn vị</label>
            @(Html.Kendo().ComboBox().Name("PosCode_Find")
                .Filter(FilterType.Contains)
                .Placeholder("--- Đơn vị ---")
                .DataTextField("value")
                .DataValueField("id")
                .ClearButton(false)
                .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramLoadListBranchFind"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 250px;padding-top: 0px;padding-bottom: 0px;padding-top: 0px;padding-left: 3px;padding-right: 2px; !important;max-width: 100% !important;color: green;!important; class='form - control';" })
                .Suggest(true)
                .AutoBind(true)
                .SelectedIndex(0))

            <label class="lbcontrol" style="color: navy;text-align:right;width:90px;padding-top:3px;padding-right:6px;font-family:Tahoma;font-size:12px;">Mã sản phẩm</label>
            @(Html.Kendo().TextBox()
                .Name("ProductCode_Find")
                .HtmlAttributes(new { placeholder = "Mã sản phẩm", style = "background-color:white;width: 100px;color:green;!important;padding-left:3px;padding-right: 2px;!important;" })
                .Value("")
                )
            <label class="lbcontrol" style="color: navy;text-align:right;width:85px;padding-top:3px;padding-right:6px;font-family:Tahoma;font-size:12px;">Quyết định</label>
            @(Html.Kendo().TextBox()
                .Name("CircularRefNum_Find")
                .HtmlAttributes(new { placeholder = "Số/Nội dung quyết định", style = "background-color:white;width: 250px;color:green!important;padding-left:3px;padding-right: 2px;!important;" })
                .Value("")
                )
            <label class="lbcontrol" style="color: navy;text-align:right;width:100px;padding-top:3px;padding-right:6px;font-family:Tahoma;font-size:12px;">Ngày hiệu lực</label>
            @(Html.Kendo().DatePicker()
                .Name("CircularDateBegin_Find")
                .Format("dd/MM/yyyy")
                .HtmlAttributes(new { style = "background-color: While !important; width: 105px !important; color: green; !important;", title = "Từ ngày cần tìm kiếm" })
                .Value(new DateTime(DateTime.Today.Year - 5, 1, 1))
                )
