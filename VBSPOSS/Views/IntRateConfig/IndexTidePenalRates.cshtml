            }
            else if (dataItem.Status == 1 || dataItem.Status == 5) {
                alert("Cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " đang ở trạng thái tạo lập, chưa thực hiện trình duyệt, không thể thực hiện phê duyệt. Vui lòng kiểm tra lại!");
            }
