        height: 15px;
        border: none;
    }

    .k-grid .btn-view-edit.k-button {
		background: url('../images/icon_edit.png') no-repeat center center;
		background-size: 15px 15px;
		width: 15px;
		height: 15px;
		border: none;
	}

    .k-grid .btn-delete.k-button {
		background: url('../images/icon_delete.png') no-repeat center center;
		background-size: 15px 15px;
		width: 15px;
		height: 15px;
		border: none;
	}

	.k-grid .btn-auth.k-button {
		background: url('../images/icon_auth.png') no-repeat center center;
		background-size: 15px 15px;
		width: 15px;
		height: 15px;
		border: none;
	}

	.k-grid .btn-approval.k-button {
		background: url('../images/icon_approval.png') no-repeat center center;
		background-size: 15px 15px;
		width: 15px;
		height: 15px;
		border: none;
	}

</style>

<script>
    var userPermission = @Html.Raw(Json.Serialize(userPermission ?? new RolePermissionModel()));
    var mainWindow = $("#myPopup");

    function paramLoadListBranchFind() {
        return {
            pFlagCondi: "2",
            pStatus: "O",
            pShortName: "1",
            pTitleChoice: "",
            pFlagTextShow: "1",
            pUserPosCode: "",
            pUserName: "",
            pFlagWholeBank: 1
        };
    }

    function paramLoadGridData() {
        return {
            pProductGroupCode: "",
            pPosCode: $("#PosCodeFind").val(),
            pCircularRefNum: $("#CircularRefNum_Find").val(),//CircularRefNum_Find
            pFromEffectiveDate: $("#CircularDateBegin_Find").val(),
            pToEffectiveDate: $("#CircularDateEnd_Find").val()
        };
    }

    function refreshGridTidePanelRate() {
        var grid = $("#gridMainTidePanelRate").data("kendoGrid");
        if (grid != null) {
            grid.dataSource.read();
        }
    }

    function onSearchTidePenalRate(e) {
        refreshGridTidePanelRate();
    }

    function onRowBoundTidePenalRate(e) {
        var rows = e.sender.tbody.children();
        var isRed = true;
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var statusRowValue = dataItem.get("Status");
            if (statusRowValue == 0 || statusRowValue == 4)
                row.css({ "background-color": "#f8f9fa", "color": "#6c757d" });
            if (statusRowValue != null && statusRowValue == 4)
                row.css({ "background-color": "#fff5f5", "color": "#dc3545" });
            if (statusRowValue != null && statusRowValue == 3) // Đã duyệt
                row.css({ "background-color": "#e8f5e9", "color": "green" });
            if (statusRowValue == 1 || statusRowValue == 5)
                row.css({ "background-color": "white", "color": "Navy" });
        }

        var grid = this;
        grid.tbody.find("tr").each(function () {
            var dataItem = grid.dataItem(this);
            if (userPermission && userPermission.EditPermissionFlag == 0) {
                $(this).find(".k-grid-ViewEdit").hide();
            }
            if (userPermission && userPermission.DeletePermissionFlag == 0) {
                $(this).find(".k-grid-Delete").hide();
            }

            if (userPermission && userPermission.AuthorizePermissionFlag == 0) {
                $(this).find(".k-grid-Authorize").hide();
            }

            if (userPermission && userPermission.ReportPermissionFlag == 0) {
                $(this).find(".k-grid-Approval").hide();
            }
        });
    }

    var dataChangeTidePanelRate = false;

    $(document).on('click', '#btnCreate', function (e) 
    {
        e.preventDefault();
        if (userPermission && userPermission.CreatePermissionFlag == 0) {
            alert("Bạn không có quyền thêm mới cấu hình lãi suất rút trước hạn tiền gửi CKH. Vui lòng kiểm tra lại!");
			return;
		}
        if (mainWindow.data("kendoWindow")) {
            mainWindow.data("kendoWindow").destroy();
        }
        var sFlagCall = $("#EventFlag_AddTemp").val();
        mainWindow.kendoWindow({
            width: "1050px",
            height: "750px",
            title: "Thêm mới cấu hình lãi suất rút trước hạn tiền gửi CKH",
            content: {
                url: '@Url.Action("ShowUpdateTidePenalRate", "IntRateConfig")',
                data: { pPosCode: "", pDocumentId: 0, pListId: "", pProductGroupCode: $("#ProductGroupCodeView").val(), pFlagCall: sFlagCall }
            },
            resizable: true,
            visible: false,
            close: onCloseTidePanelRate,
            modal: true,
            actions: ["Refresh", "Close"],
            error: function (e) {
                notification.show( { message: "Có lỗi xảy ra: " + e.xhr.statusText, type: "error"}, "error");
                mainWindow.data("kendoWindow").close();
            }
        });
        mainWindow.data("kendoWindow").center().open();
    });

    function onCloseTidePanelRate() {
        if (dataChangeTidePanelRate == true) {
            refreshGridTidePanelRate();
            dataChangeTidePanelRate = false;
        }
    }

    function doCompleteWindow() {
        mainWindow.data("kendoWindow").close();
    }
    
    function showEditTidePenalRate(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "Quyết định [" + dataItem.CircularRefNum + "]";
        if (dataItem.Status.toString() == "0") {
            alert(sMessInfor + " đã được đánh dấu xóa nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "3") {
            alert(sMessInfor + " đã được phê duyệt nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else if (dataItem.Status.toString() == "4") {
            alert(sMessInfor + " đã được từ chối nên không thể chỉnh sửa. Vui lòng kiểm tra lại!");
        }
        else
        {
            var sFlagCall = $("#EventFlag_EditTemp").val();
            mainWindow.kendoWindow({
                width: "1050px",
                height: "750px",
                title: "Chỉnh sửa cấu hình lãi suất rút trước hạn tiền gửi CKH",
                content: { url: "../IntRateConfig/ShowUpdateTidePenalRate", data: {pPosCode: dataItem.PosCode, pDocumentId: dataItem.DocumentId, pListId: dataItem.IdList, pProductGroupCode: $("#ProductGroupCodeView").val(), pFlagCall: sFlagCall } },
                resizable: false,
                visible: false,
                modal: true,
                close: onCloseTidePanelRate,
                actions: ["Refresh", "Close"]
            });
            mainWindow.data("kendoWindow").wrapper.css({ height: 750, width: 1050 });
            mainWindow.data("kendoWindow").center().open().title("Chỉnh sửa cấu hình lãi suất rút trước hạn tiền gửi CKH");
        }
    }

    function deleteItemTidePenalRate(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var sMessInfor = "[" + dataItem.CircularRefNum + "]";
        var grid = $("#gridMainTidePanelRate").data("kendoGrid");

        var deletedStatuses = [0, 2, 3, 4];
        if (deletedStatuses.includes(dataItem.Status)) {
            if (dataItem.Status == 0) {
                alert("Cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " đã được đánh dấu xóa rồi. Không thực hiện đánh dấu xóa!");
            }
            else if (dataItem.Status == 2) {
                alert("Cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " đang trình duyệt, không thể thực hiện đánh dấu xóa. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 3) {
                alert("Cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " đã được phê duyệt, không thể thực hiện đánh dấu xóa. Vui lòng kiểm tra lại!");
            }
            else if (dataItem.Status == 4) {
                alert("Cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " đã được từ chối, không thể thực hiện đánh dấu xóa. Vui lòng kiểm tra lại!");
            }
            return;
        }
        var isConfirm = confirm("Bạn có chắc chắn muốn đánh dấu xóa cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " không?");
        var sFlagCall = $("#EventFlag_MarkDeletedTemp").val();
        if (isConfirm) {

            kendo.ui.progress(grid.element, true);

            $.ajax({
                url: '@Url.Action("DeleteIntPenalRateConfig", "IntRateConfig")',
                type: "POST",
                data: JSON.stringify({
                    Id: dataItem.Id, DocumentId: dataItem.DocumentId, IdList: dataItem.IdList,
                }),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (result) {
                    kendo.ui.progress(grid.element, false); // Hide loading indicator
                    console.log("Delete success result:", result);
                    if (result.success) {
                        alert("Xóa cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " thành công!");
                        refreshGridTidePanelRate();
                    } else {
                        alert("Xóa cấu hình lãi suất " + sMessInfor + " thất bại! Lỗi: " + (result.message || "Không xác định"));
                    }
                },
                error: function (xhr, status, error) {
                    kendo.ui.progress(grid.element, false); // Hide loading indicator
                    console.error("Delete error:", xhr, status, error);
                    alert("Xóa cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " có lỗi! Chi tiết: " + (xhr.responseText || error));
                }
            });
        } 
        else {
            alert("Thao tác đánh dấu xóa cấu hình lãi suất rút trước hạn tiền gửi CKH " + sMessInfor + " bị hủy bỏ!");
        }
    }
    
