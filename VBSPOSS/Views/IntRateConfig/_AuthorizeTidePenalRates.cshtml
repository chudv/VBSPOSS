<script>
    function showAttachedFile(pDocumentId, pFileId, pFileNameNew) {
        var now = new Date();
        var win = window.open('../IntRateConfig/LoadPdfAttachedFile?pDocumentId=' + pDocumentId + '&' + 'pFileId=' + pFileId + '&' + 'pFileName=' + pFileNameNew + '&t=' + now.getTime(), '_blank');
        if (win) {
            win.focus();
        } else {
            alert('Please allow popups for this website');
        }
    }

    function add_download_link() {
        var lcDocumentId = $("#DocumentId").val();
        var lcFileType = "1";
        if (lcDocumentId != 0) {
            $.ajax({
                type: "GET",
                url: "../ListOfValue/GetListAttachedFileInfo_ForDocumentId?pDocumentId=" + lcDocumentId + '&' + 'pFileType=' + lcFileType,
                success: function (data) {
                    files = data;
                    if (files != null) {
                        $("#_no_file_attach_id").text("");
                        for (i = 0; i < files.length; i++) {
                            var thutu = i + 1;
                            html = '<a title="' + files[i].Description + '" href="#" onclick=showAttachedFile(' + lcDocumentId + ',' + files[i].FileId + ',"' + files[i].FileNameNew + '")' + '>' + ' [' + thutu + '] ' + "</a>&nbsp;";
                            $("#_no_file_attach_id").append(html);
                        }
                    }
                }
            });
        }
    }

    $(function () {
        $("#authorizePenalRateConfigForm").submit(function (event) {
            event.preventDefault();
            var dataString;
            var action = this.action;
            var contentType;
            var processData;
            if (this.enctype == "multipart/form-data") {
                dataString = new FormData($(this).get(0));
                //contentType = false;
                //processData = false;
            } 
            else {
            }
            $.ajax({
                url: this.action,
                type: this.method,
                data: dataString,
                contentType: false,   // BẮT BUỘC
                processData: false,   // BẮT BUỘC
                success: function (result) {
                    if (result && result.Errors) {
                        alert(JSON.stringify(result.Errors));
                        return;
                    }
                    var lcRejectStatus = $("#RejectFlag").val();
                    var lcCircularRefNum = $("#CircularRefNum").val();
                    if (lcRejectStatus == 1) {
                        alert("Bạn đã từ chối thay đổi lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn theo quyết định [" + lcCircularRefNum + "] thành công!");
                    } 
                    else {
                        alert("Bạn đã phê duyệt thay đổi lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn theo quyết định [" + lcCircularRefNum + "] thành công!");
                    }
                    dataChangeTidePanelRate = true;
                    mainWindow.data("kendoWindow").close();
                },
                error: function () {
                    alert("Lỗi khi cập nhật dữ liệu Phê duyệt/Từ chối thay đổi lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!");
                }
            });
            return false;
        });
    });

