<script>
     function refreshGridUpdateTidePenalRateConfig() {
        var objGridTidePenalRateUpdate = $("#gridUpdateTidePenalRateConfig").data("kendoGrid");
        if (objGridTidePenalRateUpdate != null) {
            objGridTidePenalRateUpdate.dataSource.read();
        }
    }

    function onSaveGridCompletedTidePenalRateConfig(e)
    {
        if (e != null && e.response != null)
        {
            if (!e.response.Errors) {
                if (e.type == "create") {

                }
                else if (e.type == "update") {
                    alert("Xử lý yêu cầu thành công!");
                }
                else if (e.type == "read") {
                }
            }
            else {
                alert(e.response.Errors);
            }
        }
    }

    function error_HandlerTidePenalRateConfig(e) {
        if (e.errors) {
            var message = "Thông báo lỗi: ";
            dataChangeDGXL = true;//Làm sao để gắn giá trị này khi thoát ra mà màn hình cha bên ngoài nó Reload đc
            $.each(e.errors, function (key, value) {
                if ('errors' in value) {
                    $.each(value.errors, function () {
                        message += this + "\n";
                    });
                }
            });
            alert(message);
        }
    }


     function paramLoadGridUpdateTidePenalRateConfig() {
        var listPosStr = $("#ListPosCodeChoice").val();
        var listProductStr = $("#ListProductCodeChoice").val();

        return {
            posCode: $("#PosCode").val(),
            productCode: $("#ProductCode").val(),
            currencyCode: $("#CurrencyCode").val(),
            effectiveDate: $("#EffectiveDate").val(),
            expiredDate: $("#ExpiredDate").val(),
            circularRefNum: $("#CircularRefNum").val(),
            circularDate: $("#CircularDate").val(),
            interestRateNew: $("#InterestRateNew").val(),
            penalIntRate: $("#PenalIntRate").val(),
            idList: $("#IdList").val(),
            pListPosCode: listPosStr,
            pListProductCodeChoice: listProductStr
        };
    }

    function onRowBoundUpdateTidePenalRateConfig(e) {
        var rows = e.sender.tbody.children();
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var statusRow = dataItem.get("Status");
            if (statusRow == 1 || statusRow == null)
                row.css({ "background-color": "white", "color": "red" });
        }
    }

    function onRejectClick() {
        $("#RejectFlag").val("1");
        var rejectReason = $("#RejectReason").val();

        if(rejectReason == "") {
            alert('Bạn chưa nhập lý do từ chối tờ trình cấu hình lãi suất rút trước hạn của sản phẩm tiền gửi CKH. Vui lòng kiểm tra lại!');
            return;
        }
    }

    function onAuthorizeClick(){
        $("#RejectFlag").val("0");
    }

</script>

