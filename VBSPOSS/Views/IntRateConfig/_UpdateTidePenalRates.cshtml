<form id="addTideRateConfigureForm">
    @Html.HiddenFor(m => m.IdList, new { @Value = Model == null ? "" : Model.IdList })
    @Html.HiddenFor(m => m.Id, new { @Value = Model == null ? 0 : Model.Id })
    @Html.HiddenFor(m => m.Status, new { @Value = Model == null ? 0 : Model.Status })
    @Html.HiddenFor(m => m.PosCode, new { @Value = Model == null ? "" : Model.PosCode })
    @Html.HiddenFor(m => m.ProductCode, new { @Value = Model == null ? "" : Model.ProductCode })
    @Html.HiddenFor(m => m.ListPosCodeChoice, new { @Value = Model == null ? "" : Model.ListPosCodeChoice })
    @Html.HiddenFor(m => m.ListProductCodeChoice, new { @Value = Model == null ? "" : Model.ListProductCodeChoice })
    @Html.HiddenFor(m => m.MinInterestRateSpread, new { @Value = Model == null ? 0 : Model.MinInterestRateSpread })
    @Html.HiddenFor(m => m.MaxInterestRateSpread, new { @Value = Model == null ? 0 : Model.MaxInterestRateSpread })
    @Html.Hidden("SourceFlag", "0")
    @Html.Hidden("FlagCallView", TempData["FlagCall"])
    @Html.AntiForgeryToken()

    <div class="row" style="padding-top: 2px; padding-left: 0px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label class="lbcontrol" style="color: navy;text-align:left;width:70px;padding-top: 7px;">Đơn vị</label>
            @(Html.Kendo().CheckBox().Name("ckb_checkallPos").Label(" ").HtmlAttributes(new { onchange = "Checked_ChoiceAllPos();", style = "color: red;text-align: center;padding-right: 5px;", title = "Chọn tất cả đơn vị (POS)" }))
            &nbsp;
            @(Html.Kendo().MultiSelectFor(m => m.ListPosCode)
                .Filter(FilterType.Contains)
                .Placeholder("--- Chọn Đơn vị áp dụng ---")
                .DataTextField("value")
                .DataValueField("id")
                .Events(e => e
                .DataBound("onMultiSelectDataBound")  // ← Thêm event dataBound
                )
                .DownArrow(true)   //Thêm dòng này để có mũi tên xuống
                .DataSource(source => { source.Read(read => { read.Action("GetListBranchs", "ListOfValue").Data("paramListBranchLoadUpd"); }).ServerFiltering(false); })
                .HtmlAttributes(new { style = "width: 910px; !important;max-width: 100% !important;color: green;text-align: left;flex: 1; padding-left: 2px; padding-right: 2px;" })
                .AutoBind(true))
        </div>
    </div>
    <div class="row" style="padding-top: 2px; padding-left: 0px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label class="lbcontrol" style="color: navy;text-align:left;width:70px;padding-top: 7px;">Sản phẩm</label>
            @(Html.Kendo().CheckBox().Name("ckb_checkallProduct").Label(" ").HtmlAttributes(new { onchange = "Checked_ChoiceAllProduct();", style = "color: red;text-align: center;padding-right: 5px;", title = "Chọn tất cả sản phẩm hoặc không cần tích chọn nếu muốn chọn tất cả" }))
            &nbsp;
            @(Html.Kendo().MultiSelectFor(m => m.ListProductCode)
                .Filter(FilterType.Contains)
                .Placeholder("--- Chọn Sản phẩm ---")
                .DataTextField("value")
                .DataValueField("id")
                .Events(e => e
                .DataBound("onMultiSelectDataBoundProduct")  // ← Thêm event dataBound
                )
                .DownArrow(true)   //Thêm dòng này để có mũi tên xuống
                .DataSource(source => { source.Read(read => { read.Action("GetListOfProducts", "ListOfValue").Data("paramProductLoadUpd"); }).ServerFiltering(false); })
                .HtmlAttributes(new { id = "ListProductCode", style = "width: 910px; !important;max-width: 100% !important;color: green;text-align: left;flex: 1; padding-left: 2px; padding-right: 2px;" })
                .AutoBind(true))
        </div>
    </div>
    <div class="row" style="padding-top: 2px; padding-left: 0px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label class="lbcontrol" style="color: navy;text-align:left;width:60px;padding-top: 7px;padding-right: 5px!important;">Loại tiền</label>
            @Html.Kendo().TextBoxFor(m => m.CurrencyCode).HtmlAttributes(new { @readonly = "readonly", style = " width: 40px; !important;max-width:100% !important;color: navy;font-family:Tahoma;padding-left: 2px!important;padding-right: 2px!important;" })
