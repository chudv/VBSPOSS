    function onSave_TidePenalRate(){

        console.log("onSave_TidePenalRate triggered");

        try {
            var lcCircularRefNum = $("#CircularRefNum").val();
            var lcCircularDate = $("#CircularDate").val();
            var lcEffectiveDate = $("#EffectiveDate").val();
            var dCircularDate = stringToDate(lcCircularDate, "dd/MM/yyyy", "/");
            var dEffectiveDate = stringToDate(lcEffectiveDate, "dd/MM/yyyy", "/");
            var lcExpiredDate = $("#ExpiredDate").val();
            var dExpiredDate = stringToDate(lcExpiredDate, "dd/MM/yyyy", "/");
            if (lcCircularRefNum == null || lcCircularRefNum == "") {
                alert('Bạn số quyết định và tiêu đề quyết định thay đổi lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn cần thêm mới. Vui lòng kiểm tra lại!');
                $('#CircularRefNum').focus();
                e.preventDefault();
                return false;
            }
            if (dEffectiveDate < dCircularDate) {
                alert("Ngày hiệu lực [" + lcEffectiveDate + "] quyết định thay đổi lãi suất nhỏ hơn ngày ký [" + dCircularDate + "] quyết định. Vui lòng kiểm tra lại!");
                $('#EffectiveDate').focus();
                e.preventDefault();
                return false;
            }
            if (dExpiredDate <= dEffectiveDate) {
                alert("Thông tin quyết định thay đổi lãi suất có Ngày hết hiệu [" + lcExpiredDate + "] lực nhỏ hơn hoặc bằng ngày hiệu lực [" + lcEffectiveDate + "]. Vui lòng kiểm tra lại!");
                $('#EffectiveDate').focus();
                e.preventDefault();
                return false;
            }

            var selectedPosCodes = [];
            $('#ListPosCode :selected').each(function (i, selected) {
                selectedPosCodes[i] = $(selected).val();
            });
            if (selectedPosCodes.length <= 0) {
                alert('Bạn chưa chọn đơn vị áp dụng để khai báo lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!');
                e.preventDefault();
                $("#ListPosCode").focus();
                return false;
            }
            var applyPosLst = $("#ListPosCode").data("kendoMultiSelect").value();

            var gridTidePenalRateConfig = $("#gridUpdateTidePenalRateConfig").data("kendoGrid");
            var selectedItems = [];
            //Lấy chi tiết danh sách SP và Lãi suất cấu hình lãi suất rút trước hạn sản phẩm tiền gửi Tide (Trên lưới)
            var allVisibleItems = gridTidePenalRateConfig.dataSource.view(); // → mảng các object dataItem
            allVisibleItems.forEach(function(dataItem) {
                selectedItems.push({
                    Id: dataItem.Id,
                    OrderNo: dataItem.OrderNo,
                    IdList: dataItem.IdList,
                    PosCode: dataItem.PosCode,
                    PosName: dataItem.PosName,
                    EffectiveDate: dataItem.EffectiveDate,
                    ProductCode: dataItem.ProductCode,
                    ProductName: dataItem.ProductName,
                    CurrencyCode: dataItem.CurrencyCode,
                    CircularRefNum: dataItem.CircularRefNum,
                    EffectiveDateText: dataItem.EffectiveDateText,
                    InterestRate: dataItem.InterestRate,
                    InterestRateNew: dataItem.InterestRateNew,
                    Status: dataItem.Status,
                    StatusUpdateCore: dataItem.StatusUpdateCore,
                    MaxInterestRateSpread: dataItem.MaxInterestRateSpread,
                    MinInterestRateSpread: dataItem.MinInterestRateSpread,
                    InterestRateHO: dataItem.InterestRateHO
                });
            });

            if (selectedItems.length == 0) {
                alert("Bạn tải dữ liệu danh sách sản phẩm cần cấu hình lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!");
                return;
            }
            //Lấy các thông tin chung cho cấu hình lãi suất rút trước hạn sản phẩm tiền gửi Tide
            var posCode = $("#PosCode").val();
            var productCode = $("#ProductCode").val();
            var currencyCode = $("#CurrencyCode").val();
            var interestRate = parseFloat( $("#InterestRateNew").val());
            var penalIntRate = parseFloat( $("#PenalIntRate").val());
            if (interestRate == null ) {
                console.error("Bạn chưa nhập lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!");
                alert("Bạn chưa nhập lãi suất rút trước hạn sản phẩm tiền gửi có kỳ hạn. Vui lòng kiểm tra lại!");
                return;
            }

            var listPosStr = "";
            $('#ListPosCode :selected').each(function (i, selected) {
                listPosStr += selectedPosCodes[i] + ";";
            });

            var selectedProductCodes = [];
            $('#ListProductCode :selected').each(function (i, selected) {
                selectedProductCodes[i] = $(selected).val();
            });
            var listProductStr = "";
            $('#ListProductCode :selected').each(function (i, selected) {
                listProductStr += selectedProductCodes[i] + ";";
            });

            // Combine form and grid data
            var submitData = {
                flagCall: $("#FlagCallView").val(),
                posCode: posCode,
                productCode: productCode,
                currencyCode: currencyCode,
                effectiveDate: lcEffectiveDate,
                expiredDate: lcExpiredDate,
                circularRefNum: lcCircularRefNum,
                circularDate: lcCircularDate,
                interestRate: interestRate,
                penalIntRate: penalIntRate,
                listItemUpdates: selectedItems,
                listPosCodeChoice: listPosStr,
                listProductCodeChoice: listProductStr
            };
            console.log("Submit data SaveTidePenalRateConfig():", submitData);

            // Send AJAX request
            $.ajax({
                url: '@Url.Action("SaveTidePenalRateConfig", "IntRateConfig")',
                type: "POST",
                data: JSON.stringify(submitData),
                contentType: "application/json; charset=utf-8",
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    console.log("Save successful:", response);
                    alert(response.Message);
                    $("#SourceFlag").val("1");
                    dataChangeTidePanelRate = true;
                    mainWindow.data("kendoWindow").close();
                },
                error: function (xhr, status, error) {
                    console.error("Save failed:", error, xhr.responseText);
                    alert("Lỗi khi lưu dữ liệu cấu hình lãi suất rút trước hạn sản phẩm tiền gửi CKH: " + (xhr.responseText || error));
                }
            });
        } catch (error) {
            console.error("Error in onSave_TidePenalRate:", error);
            alert("Lỗi cập nhật cấu hình lãi suất rút trước hạn sản phẩm tiền gửi CKH: " + error.message);
        }
    }

