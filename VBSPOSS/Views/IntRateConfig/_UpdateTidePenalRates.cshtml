            <label class="lbcontrol" style="color: navy;text-align:right;width:100px;padding-top: 7px;padding-right: 5px!important;">Số quyết định</label>
            @Html.Kendo().TextBoxFor(m => m.CircularRefNum).HtmlAttributes(new { placeholder = "Số và tiêu đề quyết định", style = " width: 200px; !important;max-width:100% !important;color: blue;font-family:Tahoma !important;padding-left: 2px!important;padding-right: 0px!important;" })
            <label class="lbcontrol" style="color: navy;text-align:right;width:70px;padding-top: 7px;padding-right: 5px!important;">Ngày ký</label>
            @Html.Kendo().DatePickerFor(m => m.CircularDate).Format("dd/MM/yyyy").HtmlAttributes(new { style = "width: 113px; !important;max-width:100% !important;font-family:Tahoma;color: blue;padding-left: 3px!important;padding-right: 3px!important;" })
        </div>
