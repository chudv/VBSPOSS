    <div class="row" style="padding-top: 2px; padding-left: 0px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            <label class="lbcontrol" style="color: navy;text-align:left;width:110px;padding-top: 7px;">Lãi suất cấu hình</label>
            @Html.Kendo().NumericTextBoxFor(m => m.InterestRateNew).Format("n2").Decimals(2).Min(0).Max(10).Step(0.1m).HtmlAttributes(new { style = "width: 95px; !important;max-width:100% !important;font-family:Tahoma;color: blue;padding-left: 3px!important;padding-right: 3px!important;text-align:right;" })
            <label class="lbcontrol" style="color: navy;text-align:right;width:120px;padding-top: 7px;padding-right: 5px!important;">Lãi phạt</label>
            @Html.Kendo().NumericTextBoxFor(m => m.PenalIntRate).Enable(false).Format("n2").Decimals(2).Min(0).Max(10).Step(0.1m).HtmlAttributes(new { style = "width: 115px; !important;max-width:100% !important;font-family:Tahoma;color: blue;padding-left: 3px!important;padding-right: 3px!important;text-align:right;" })
            <label class="lbcontrol" style="color: navy;text-align:right;width:100px;padding-top: 7px;padding-right: 5px!important;">Trạng thái</label>
            @Html.Kendo().TextBoxFor(m => m.StatusText).HtmlAttributes(new { @readonly = "readonly", style = " width: 230px; !important;max-width:100% !important;color: green;font-family:Tahoma !important;padding-left: 2px!important;padding-right: 0px!important;" })
            <label class="lbcontrol" style="color: navy;text-align:left;width:35px;padding-top: 7px;"></label>
            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                .Name("btnLoadTidePenalRate")
                .Events(ev => ev.Click("onLoadData_TidePenalRate"))
                .HtmlAttributes(new { type = "button", style = "font-weight:bold; width:105px; color: blue;padding-left: 0px; height: 25px;", title = "Tải danh sách sản phẩm Tide để cấu hình lãi suất rút trước hạn" })
                .ImageUrl(Url.Content("~/images/xem_bao_cao.png"))
                .Content("Tải dữ liệu"))
            &nbsp;&nbsp;
            @(Html.Kendo().Button()
                .Name("btnSaveTidePenalRate")
                .Events(ev => ev.Click("onSave_TidePenalRate"))
                .HtmlAttributes(new { type = "button", style = "font-weight:bold; width:90px; color: blue;padding-left: 0px; height: 25px;", title = "Cập nhật thông tin cấu hình lãi suất rút trước hạn sản phẩm Tide" })
                .ImageUrl(Url.Content("~/images/save.png"))
                .Content("Lưu lại"))
        </div>
    </div>
    <hr style='margin-top: 0.3em; margin-bottom: 0.3em; padding-top: 0px; background-color: #333; border-width: 0; color: #000000; height: 1px; line-height: 0; text-align: left; width: 100%; background-image: linear-gradient(to right, #ccc, #333, #ccc); ' />
    <div class="row" style="padding-top: 2px; padding-left: 0px; padding-bottom: 0px;">
        <div class="col-md-12" style="display: inline-flex;">
            @(Html.Kendo().Grid<UpdateTidePenalRateConfigViewModel>()
                .Name("gridUpdateTidePenalRateConfig")
                .Events(e => e.DataBound("onRowBoundUpdateTidePenalRateConfig"))
                .Columns(columns =>
                {
                    columns.Bound(c => c.OrderNo).Title("STT").Width(45).HtmlAttributes(new { style = "text-align: center;" });//.Locked(true)
                    columns.Bound(c => c.Id).Hidden();
                    columns.Bound(c => c.IdList).Hidden();
                    columns.Bound(c => c.PosCode).Hidden();
                    columns.Bound(c => c.EffectiveDate).Hidden();
                    columns.Bound(c => c.Status).Hidden();
                    columns.Bound(c => c.StatusUpdateCore).Hidden();
                    columns.Bound(c => c.MinInterestRateSpread).Hidden();
                    columns.Bound(c => c.MaxInterestRateSpread).Hidden();
                    columns.Bound(c => c.PosName).Title("Đơn vị áp dụng").Width(90).HtmlAttributes(new { style = "text-align: center;" });//.Locked(true)

                    columns.Group(groupProduct => groupProduct.Title("Sản phẩm").HtmlAttributes(new { style = "text-align: center;padding-top:0px;padding-bottom: 0px;" })//.Locked(true)
                    .Columns(infoProduct =>
                    {
                        infoProduct.Bound(x => x.ProductCode).Title("Mã SP").Width(45).HtmlAttributes(new { style = "text-align: center;" });
                        infoProduct.Bound(x => x.ProductName).Title("Tên SP").Width(260).HtmlAttributes(new { style = "text-align: left;" });
                    }));
                    columns.Bound(c => c.CurrencyCode).Title("Loại tiền tệ").Width(45).HtmlAttributes(new { style = "text-align: center;" });//.Locked(true)

                    columns.Group(groupPenalRateConfigOld => groupPenalRateConfigOld.Title("Thông tin quyết định cấu hình hiện tại").HtmlAttributes(new { style = "text-align: center;padding-top:0px;padding-bottom: 0px;" })//.Locked(true)
                    .Columns(infoRateConfigOld =>
                    {
                        infoRateConfigOld.Bound(x => x.CircularRefNum).Title("Số Quyết định").Width(165).HtmlAttributes(new { style = "text-align: left;" });
                        infoRateConfigOld.Bound(x => x.EffectiveDateText).Title("Ngày hiệu lực").Width(83).HtmlAttributes(new { style = "text-align: center;" });
                        infoRateConfigOld.Bound(x => x.InterestRate).Title("Lãi suất").Width(55).HtmlAttributes(new { style = "text-align: center;" }).Format("{0:n2}");
                        infoRateConfigOld.Bound(x => x.InterestRateHO).Title("Lãi suất HSC").Width(55).HtmlAttributes(new { style = "text-align: center;" }).Format("{0:n2}");
                    }));
                    columns.Bound(c => c.InterestRateNew).Title("Lãi suất cấu hình").Width(80).HtmlAttributes(new { style = "text-align: center;color: blue !important;", @class = "new-interest-rate" }).Format("{0:n2}");
                })
                .HtmlAttributes(new { style = "color: navy; height: 440px; width:100%; vertical-align:middle;margin: 0;padding: 0;margin-right: 0px;padding-left: 0px; padding-right: 0px;" })
                .Editable(editable => { editable.Mode(GridEditMode.InCell); })
                .Events(events => events.Edit("onEdit_TidePenalRateConfig").Save("onSave_TideRatePenalGrid"))
                .Sortable(false)
                .Scrollable()
                .Pageable(pageable => pageable.Refresh(true).ButtonCount(5))
                .DataSource(dataSource => dataSource
                .Ajax()
               // .Batch(true)
                .ServerOperation(false)
                .Model(model =>
                {
                    model.Id(p => p.Id);
                    model.Field(p => p.OrderNo).Editable(false);
                    model.Field(p => p.PosName).Editable(false);
                    model.Field(p => p.ProductCode).Editable(false);
                    model.Field(p => p.ProductName).Editable(false);
                    model.Field(p => p.CurrencyCode).Editable(false);
                    model.Field(p => p.EffectiveDateText).Editable(false);
                    model.Field(p => p.CircularRefNum).Editable(false);
                    model.Field(p => p.InterestRate).Editable(false);
                })
                .Events(e => e.RequestEnd("onSaveGridCompletedTidePenalRateConfig").Error("error_HandlerTidePenalRateConfig"))
                .Read(read => read.Action("LoadGridData_UpdateTidePenalRateConfig", "IntRateConfig").Type(HttpVerbs.Post).Data("paramLoadGridUpdateTidePenalRateConfig"))
