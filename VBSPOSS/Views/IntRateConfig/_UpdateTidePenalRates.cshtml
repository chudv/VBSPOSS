            //     }
            // }

            var model = e.model;

            var rateHO = parseFloat(model.InterestRateHO);
            var minRate = rateHO - parseFloat(model.MinInterestRateSpread);
            var maxRate = rateHO + parseFloat(model.MaxInterestRateSpread);
            var num = e.values.TermIntRateNew;
            var newValue = parseFloat(num);
            if (isNaN(newValue) || newValue < minRate || newValue > maxRate) {
                alert("Lãi suất cấu hình mới phải nằm trong khoảng từ lãi suất tối thiểu " + kendo.toString(minRate, "n2") + " đến lãi suất tối đa " + kendo.toString(maxRate, "n2") + ". Vui lòng kiểm tra lại!");
