<script>
    $(document).ready(function () {
        const flagCallView = $("#FlagCallView").val();
        if(flagCallView=="2")
        {
            refreshGridUpdateTidePenalRateConfig();
            $("#btnLoadTidePenalRate").data("kendoButton").enable(false);
            
            $("#ListProductCode").data("kendoMultiSelect").readonly(true);
            $("#ckb_checkallProduct").prop("disabled", true);

            $("#ListPosCode").data("kendoMultiSelect").readonly(true);
            $("#ckb_checkallPos").prop("disabled", true);
        }
    });
</script>