    function find_ReplaceALL(string, target, replacement) {
        if (string != "") {
            var i = 0, length = string.length;
            for (i; i < length; i++) {
                string = string.replace(target, replacement);
            }
        }
        return string;
    }

    function stringToDate(_date, _format, _delimiter) {
        var formatLowerCase = _format.toLowerCase();
        var formatItems = formatLowerCase.split(_delimiter);
        var dateItems = _date.split(_delimiter);
        var monthIndex = formatItems.indexOf("mm");
        var dayIndex = formatItems.indexOf("dd");
        var yearIndex = formatItems.indexOf("yyyy");
        var month = parseInt(dateItems[monthIndex]);
        month -= 1;
        var formatedDate = new Date(dateItems[yearIndex], month, dateItems[dayIndex]);
        return formatedDate;
    }

    function padTo2Digits(num) {
        return num.toString().padStart(2, '0');
    }

    function convertDateToString(inputDate, outFormat) {
        var iDate = 0;
        var iMonth = 0;
        var iYear = 0;
        var lcDate="";
        var lcMonth="";
        var lcYear = "";
        var lcResult = "";
        var formatLowerCase = outFormat.toLowerCase();

        iDate = inputDate.getDate();
        iMonth = inputDate.getMonth() + 1;
        iYear = inputDate.getFullYear();

        lcDate = iDate.toString().padStart(2, '0');
        lcMonth = iMonth.toString().padStart(2, '0');
        lcYear = iYear.toString();
        if(outFormat == "ddmmyyyy")
        lcResult = lcDate + lcMonth + lcYear;
        else if (outFormat == "dd/mm/yyyy")
        lcResult = lcDate + "/" + lcMonth + "/" + lcYear;
        else if (outFormat == "dd-mm-yyyy")
        lcResult = lcDate + "-" + lcMonth + "-" + lcYear;
        else if (outFormat == "dd.mm.yyyy")
        lcResult = lcDate + "." + lcMonth + "." + lcYear;
        return lcResult;
    }

