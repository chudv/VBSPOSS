@{
    ViewBag.Title = "Danh sách chức năng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .k-grid-header th.k-header {
        text-align: center !important;
    }
    /* .k-grid tbody .k-button, .k-ie8 .k-grid tbody button.k-button {
        background: none !important;
        border: none;
        padding: 0 !important;
        font: inherit;
        cursor: pointer;
    } */

    /* .red {
        color: red;
    } */

    .style1 {
        font-weight: bold;
        color: blueviolet;
    }

    /* .row {
        display: inline-flex;
        padding: 5px;
    } */

    
</style>


<script>
    function onRowBound(e) {

        var rows = e.sender.tbody.children();
        for (var j = 0; j < rows.length; j++) {
            var row = $(rows[j]);
            var dataItem = e.sender.dataItem(row);
            var isParent = dataItem.get("IsParent");
            if (isParent == true || isParent == 1)
                row.addClass('style1');
        }
    }

    function getStatusDesc(value) {
        if (value == 0) {
            return "Đóng";
        } else {
            return "Hoạt động";
        }
    }
</script>

<div class="row">
    <div class="col-md-12">
        @(Html.Kendo().Grid<VBSPOSS.Data.Models.MenuRoleView>()
            .Name("MainGrid")
            .Events(e => e.DataBound("onRowBound"))
            .Columns(columns =>
            {
                columns.Command(command =>
                {
                    command.Edit().Text(" ").UpdateText(" ").CancelText(" ");
                    command.Destroy().Text(" ");
                }).Title("Sự kiện").Width(80).HtmlAttributes(new { style = "text-align: center;" });
                columns.Bound(c => c.Id).Title("Mã số").Hidden();
                columns.Bound(c => c.Text).Title("Chức năng").Width(100);
                columns.Bound(c => c.Controller).Title("Controller").Width(80);
                columns.Bound(c => c.Action).Title("Action").Width(80);
                columns.Bound(c => c.ImageClass).Title("Image Class").Width(80);
                @* columns.Bound(c => c.Status).Title("Trạng thái").Width(60);
                columns.Bound(c => c.ParentId).Title("Mã cha").Width(60);
                columns.Bound(c => c.IsParent).Title("Nhóm cha").Width(60);
                columns.Bound(c => c.HasChild).Title("Có SubMenu").Width(60);
                columns.Bound(c => c.IsSelect).Title("Được lựa chọn").Width(60);
                columns.Bound(c => c.GroupOrder).Title("Thứ tự hiển thị").Width(60); *@
                columns.Bound(c => c.Status).Title("Trạng thái").Width(60).EditorTemplateName("Status")
            .ClientTemplate("#=getStatusDesc(Status)#").HtmlAttributes(new { style = "text-align: center;" });
                columns.Bound(c => c.ParentId).Title("Mã cha").Width(60).HtmlAttributes(new { style = "text-align: center;" }); ;
                columns.Bound(c => c.IsParent).Title("Nhóm cha").Width(60).HtmlAttributes(new { style = "text-align: center;" }); ;
                columns.Bound(c => c.HasChild).Title("Có SubMenu").Width(60).HtmlAttributes(new { style = "text-align: center;" }); ;
                columns.Bound(c => c.IsSelect).Title("Được lựa chọn").Width(60).HtmlAttributes(new { style = "text-align: center;" }); ;
                columns.Bound(c => c.GroupOrder).Title("Thứ tự hiển thị").Width(60).HtmlAttributes(new { style = "text-align: center;" }); ;
                //columns.Command(command => { command.Edit().Text("Sửa").UpdateText("Lưu").CancelText("Hủy"); command.Destroy().Text("Xóa"); }).Width(155).HtmlAttributes(new { style = "text-align: center;" });

            })
            .HtmlAttributes(new { style = "height: 500px;" })
            .ToolBar(toolbar =>
            {
                toolbar.Create().Text("Thêm mới").HtmlAttributes(new { style = "width: 110px; font-weight:bold; color: navy;" });
                toolbar.Excel().Text("Xuất excel").HtmlAttributes(new { style = "width: 110px; font-weight:bold; color: navy;" });
            })
            .Excel(excel => excel
            .FileName("Danh_Sach_Menu.xlsx").AllPages(true)
            )
            .Editable(editable =>
            {
                editable.Mode(GridEditMode.InLine);
                editable.DisplayDeleteConfirmation("Bạn chắc chắn muốn xóa?");
            })
            .Filterable(ftb => ftb.Mode(GridFilterMode.Row))
            .Sortable()
            .Scrollable()
            .Pageable(pageable => pageable
            .Refresh(true)
            .ButtonCount(5))
            .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(false)
            .ServerOperation(false)
            .Model(model => model.Id(p => p.Id))
            .Read(read => read.Action("LoadData", "Menu"))
            .Create(update => update.Action("Create", "Menu"))
            .Update(update => update.Action("Edit", "Menu"))
            .Destroy(update => update.Action("Delete", "Menu"))
            .PageSize(50)
            )
            .Resizable(resize => resize.Columns(true))
            .AutoBind(true)
            )
    </div>
</div>

